@model DEMO.ViewModels.BookedPatientInfo
@{
    ViewData["Title"] = "Admissions List";
    Layout = "_LayoutNurse";
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, user-scalable=yes">
    <title>Admissions List | Active Patients</title>

    <!-- Google Fonts + Font Awesome -->
    <link href="https://fonts.googleapis.com/css2?family=Inter:opsz,wght@14..32,300;14..32,400;14..32,500;14..32,600;14..32,700&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0-beta3/css/all.min.css">

    <!-- jQuery -->
    <script src="https://code.jquery.com/jquery-3.7.1.min.js" integrity="sha256-/JqT3SQfawRcv/BIHPThkBvs0OEvtFFmqPF/lYI/Cxo=" crossorigin="anonymous"></script>

    <!-- Bootstrap 5.3 + clean theme -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0-alpha1/dist/css/bootstrap.min.css" rel="stylesheet">
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0-alpha1/dist/js/bootstrap.bundle.min.js"></script>

    <!-- DataTables + BS5 integration -->
    <link rel="stylesheet" href="https://cdn.datatables.net/1.13.4/css/dataTables.bootstrap5.min.css">
    <script src="https://cdn.datatables.net/1.13.4/js/jquery.dataTables.min.js"></script>
    <script src="https://cdn.datatables.net/1.13.4/js/dataTables.bootstrap5.min.js"></script>

    <style>
        * {
            font-family: 'Inter', sans-serif;
        }

        body {
            background: #f4f7fc;
            margin: 0;
            padding: 0;
        }

        .main-container {
            max-width: 1600px;
            margin: 0 auto;
            padding: 1.8rem 1.5rem;
        }

        /* modern card style */
        .modern-card {
            background: #ffffff;
            border-radius: 28px;
            box-shadow: 0 12px 28px rgba(0, 0, 0, 0.04), 0 0 1px rgba(0, 0, 0, 0.03);
            transition: all 0.2s ease;
            border: none;
            overflow: hidden;
        }

        .card-header-custom {
            background: white;
            padding: 1.2rem 1.8rem 0.6rem 1.8rem;
            border-bottom: 2px solid #eef2fa;
        }

        .card-body-custom {
            padding: 1.6rem 1.8rem 1.8rem 1.8rem;
        }

        .page-title {
            font-weight: 700;
            font-size: 1.8rem;
            letter-spacing: -0.3px;
            background: linear-gradient(135deg, #1f4870, #1b3b5c);
            background-clip: text;
            -webkit-background-clip: text;
            color: transparent;
            margin-bottom: 0;
        }

        .filter-label {
            font-weight: 600;
            font-size: 0.8rem;
            text-transform: uppercase;
            letter-spacing: 0.4px;
            color: #4a627a;
            margin-bottom: 0.4rem;
        }

        .search-input-icon {
            position: relative;
        }

            .search-input-icon i {
                position: absolute;
                left: 14px;
                top: 50%;
                transform: translateY(-50%);
                color: #8a99b4;
                font-size: 0.9rem;
                pointer-events: none;
            }

            .search-input-icon input {
                padding-left: 40px;
                border-radius: 60px;
                border: 1px solid #e2e8f0;
                background: #ffffff;
                transition: 0.2s;
                height: 44px;
            }

                .search-input-icon input:focus {
                    border-color: #2c7da0;
                    box-shadow: 0 0 0 3px rgba(44,125,160,0.1);
                    outline: none;
                }

        .date-input-icon {
            position: relative;
        }

            .date-input-icon i {
                position: absolute;
                left: 14px;
                top: 50%;
                transform: translateY(-50%);
                color: #8a99b4;
                font-size: 0.9rem;
                pointer-events: none;
            }

            .date-input-icon input {
                padding-left: 40px;
                border-radius: 60px;
                border: 1px solid #e2e8f0;
                background: #ffffff;
                height: 44px;
            }

        /* table styling */
        .data-table-wrapper {
            overflow-x: auto;
            border-radius: 20px;
        }

        .table-admissions {
            width: 100%;
            margin-bottom: 0;
            border-collapse: separate;
            border-spacing: 0;
        }

            .table-admissions th {
                background: #f8fafd;
                color: #1f3b4c;
                font-weight: 600;
                font-size: 0.8rem;
                padding: 1rem 0.8rem;
                border-bottom: 1px solid #e9edf2;
                white-space: nowrap;
            }

            .table-admissions td {
                padding: 1rem 0.8rem;
                vertical-align: middle;
                border-bottom: 1px solid #f0f2f7;
                color: #1f2f3e;
                font-weight: 500;
                font-size: 0.9rem;
            }

        .badge-theatre, .badge-ward {
            background: #eef2ff;
            color: #1f4870;
            border-radius: 40px;
            padding: 4px 10px;
            font-size: 0.7rem;
            font-weight: 600;
            display: inline-block;
            white-space: nowrap;
        }

        .badge-bed {
            background: #e6f7ec;
            color: #1f7b4d;
            border-radius: 40px;
            padding: 4px 10px;
            font-size: 0.7rem;
            font-weight: 600;
        }

        /* action buttons group */
        .action-buttons {
            display: flex;
            flex-wrap: wrap;
            gap: 8px;
        }

        .btn-action-sm {
            border-radius: 40px;
            padding: 0.35rem 1rem;
            font-size: 0.75rem;
            font-weight: 600;
            transition: all 0.2s ease;
            white-space: nowrap;
        }

        .btn-outline-allergy {
            background: #fff;
            border: 1px solid #2c7da0;
            color: #2c7da0;
        }

            .btn-outline-allergy:hover {
                background: #2c7da0;
                color: white;
                transform: translateY(-1px);
            }

        .btn-outline-medication {
            background: #fff;
            border: 1px solid #1f7b4d;
            color: #1f7b4d;
        }

            .btn-outline-medication:hover {
                background: #1f7b4d;
                color: white;
            }

        .btn-outline-vitals {
            background: #fff;
            border: 1px solid #e67e22;
            color: #e67e22;
        }

            .btn-outline-vitals:hover {
                background: #e67e22;
                color: white;
            }

        .btn-outline-vitals-warning {
            background: #fef5e7;
            border: 1px solid #f39c12;
            color: #d35400;
        }

        .empty-state {
            text-align: center;
            padding: 3rem;
            background: #fafcff;
            border-radius: 24px;
        }

            .empty-state i {
                font-size: 3rem;
                color: #b9cded;
            }

        /* modal modern */
        .modal-content-modern {
            border-radius: 28px;
            border: none;
            box-shadow: 0 25px 45px -12px rgba(0,0,0,0.3);
            overflow: hidden;
        }

        .modal-header-modern {
            background: #1f3b4c;
            color: white;
            padding: 1rem 1.5rem;
            border-bottom: none;
        }

            .modal-header-modern .btn-close {
                filter: brightness(0) invert(1);
            }

       

        .action-buttons {
            flex-direction: column;
            gap: 5px;
        }

        .btn-action-sm {
            text-align: center;
        }

        }
    </style>
</head>
<body>

    <div class="main-container">
        <main role="main">
            <!-- Header -->
            <div class="d-flex flex-wrap justify-content-between align-items-center mb-4">
                <div>
                    <h1 class="page-title"><i class="fas fa-procedures me-2" style="color:#1f7b4d;"></i> Admissions List</h1>
                    <p class="text-muted mt-1 mb-0 small">Currently admitted patients | Manage care, vitals & medication</p>
                </div>
                <div class="mt-2 mt-sm-0">
                    <a href="@Url.Action("SurgeonHome", "Home")" class="btn btn-light rounded-pill shadow-sm px-4 py-2">
                        <i class="fas fa-arrow-left me-2"></i>Dashboard
                    </a>
                </div>
            </div>

            <!-- Filter Card -->
            <div class="modern-card mb-4">
                <div class="card-header-custom">
                    <div class="d-flex align-items-center gap-2">
                        <i class="fas fa-filter fs-5" style="color:#2c7da0;"></i>
                        <h5 class="fw-bold mb-0" style="color:#1f2f3e;">Filter Admissions</h5>
                    </div>
                </div>
                <div class="card-body-custom">
                    <div class="row g-4">
                        <div class="col-md-6">
                            <div class="filter-label"><i class="fas fa-search me-1"></i> SEARCH PATIENT / SURGEON</div>
                            <div class="search-input-icon">
                                <i class="fas fa-user-injured"></i>
                                <input type="text" class="form-control" id="searchInput" placeholder="Name, surname, surgeon...">
                            </div>
                        </div>
                        <div class="col-md-6">
                            <div class="filter-label"><i class="fas fa-calendar-day me-1"></i> SURGERY DATE</div>
                            <div class="date-input-icon">
                                <i class="fas fa-calendar-alt"></i>
                                <input type="date" class="form-control" id="dateInput">
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Admissions Table Card -->
            <div class="modern-card">
                <div class="card-header-custom">
                    <div class="d-flex justify-content-between align-items-center">
                        <div><i class="fas fa-users me-2" style="color:#1f7b4d;"></i> <strong>Active Admissions</strong></div>
                        <span class="badge bg-light text-dark rounded-pill px-3 py-2">
                            <i class="far fa-hospital"></i> @(Model.AllcombinedData?.Count ?? 0) patients
                        </span>
                    </div>
                </div>
                <div class="card-body-custom">
                    <div class="data-table-wrapper">
                        <table id="admissionsTable" class="table table-admissions" style="width:100%">
                            <thead>
                                <tr>
                                    <th>Name</th>
                                    <th>Surname</th>
                                    <th>Surgeon</th>
                                    <th>Surgery Date</th>
                                    <th>Time</th>
                                    <th>Theatre</th>
                                    <th>Ward</th>
                                    <th>Bed</th>
                                    <th>Admit Date</th>
                                    <th>Admit Time</th>
                                    <th style="min-width: 240px;">Actions</th>
                                </tr>
                            </thead>
                            <tbody>
                                @if (Model.AllcombinedData != null && Model.AllcombinedData.Count > 0)
                                {
                                    @foreach (var Data in Model.AllcombinedData)
                                    {
                                        <tr>
                                            <td class="fw-semibold">@Data.Name</td>
                                            <td>@Data.Surname</td>
                                            <td>@Data.SurgeonName @Data.SurgeonSurname</td>
                                            <td>@Data.SurgeryDate</td>
                                            <td>@Data.SurgeryTime</td>
                                            <td><span class="badge-theatre"><i class="fas fa-door-open me-1"></i> @Data.Theater</span></td>
                                            <td><span class="badge-ward"><i class="fas fa-building me-1"></i> @Data.WardName</span></td>
                                            <td><span class="badge-bed"><i class="fas fa-bed me-1"></i> @Data.BedNumber</span></td>
                                            <td>@Data.AdmitDate</td>
                                            <td>@Data.Time</td>
                                            <td>
                                                <div class="action-buttons">
                                                    <!-- Allergies & Conditions -->
                                                    <a class="btn btn-action-sm btn-outline-allergy"
                                                       asp-controller="Nurse"
                                                       asp-action="PatientAllergiesConditions"
                                                       asp-route-patientID="@Data.PatientID"
                                                       asp-route-name="@Data.Name"
                                                       asp-route-surname="@Data.Surname">
                                                        <i class="fas fa-allergies me-1"></i> Allergies
                                                    </a>
                                                    <!-- Chronic Medication -->
                                                    <a class="btn btn-action-sm btn-outline-medication"
                                                       asp-controller="Nurse"
                                                       asp-action="PatientChronicMedication"
                                                       asp-route-patientID="@Data.PatientID"
                                                       asp-route-name="@Data.Name"
                                                       asp-route-surname="@Data.Surname">
                                                        <i class="fas fa-pills me-1"></i> Medication
                                                    </a>
                                                    <!-- Vitals button dynamic style -->
                                                    <a class="btn btn-action-sm @(Data.HasVitals ? "btn-outline-vitals-warning" : "btn-outline-vitals")"
                                                       asp-controller="Nurse"
                                                       asp-action="PatientVitals"
                                                       asp-route-patientID="@Data.PatientID"
                                                       asp-route-name="@Data.Name"
                                                       asp-route-surname="@Data.Surname">
                                                        <i class="fas fa-heartbeat me-1"></i> @(Data.HasVitals ? "Retake Vitals" : "Take Vitals")
                                                    </a>
                                                </div>
                                            </td>
                                        </tr>
                                    }
                                }
                            </tbody>
                        </table>
                    </div>
                    <div id="noRecordsMessage" class="empty-state d-none">
                        <i class="fas fa-user-slash"></i>
                        <p class="mt-2 mb-0">No active admissions match your filters.</p>
                    </div>
                </div>
            </div>
        </main>
    </div>

    <script>
        $(document).ready(function () {
            // Initialize DataTable with enhanced options
            var table = $('#admissionsTable').DataTable({
                "pageLength": 10,
                "lengthMenu": [[5, 10, 15, 25, 50], [5, 10, 15, 25, 50]],
                "language": {
                    "zeroRecords": " ",
                    "info": "Showing _START_ to _END_ of _TOTAL_ admissions",
                    "search": "",
                    "searchPlaceholder": "Type to filter..."
                },
                "dom": '<"top"lf>rt<"bottom"ip><"clear">',
                "responsive": false,
                "order": [[8, 'desc']], // order by admit date desc (most recent first)
                "columnDefs": [
                    { "orderable": true, "targets": [0,1,2,3,4,8,9] },
                    { "orderable": false, "targets": [5,6,7,10] }
                ]
            });

            // Custom date filter on Surgery Date column (index 3)
            function applyCustomFilters() {
                var searchVal = $('#searchInput').val().trim();
                var dateVal = $('#dateInput').val();

                // apply global search
                table.search(searchVal).draw();

                // if date is selected, perform custom row filtering on column 3
                if (dateVal) {
                    $.fn.dataTable.ext.search.push(function(settings, data, dataIndex) {
                        var surgeryDateRaw = data[3]; // Surgery Date column
                        if (!surgeryDateRaw) return true;
                        // parse date: assume format MM/DD/YYYY or YYYY-MM-DD
                        var formattedTableDate = surgeryDateRaw;
                        var parts = surgeryDateRaw.split("/");
                        if (parts.length === 3) {
                            formattedTableDate = parts[2] + '-' + ('0' + parts[0]).slice(-2) + '-' + ('0' + parts[1]).slice(-2);
                        }
                        return formattedTableDate === dateVal;
                    });
                    table.draw();
                    $.fn.dataTable.ext.search.pop();
                } else {
                    table.draw(); // redraw without custom date filter
                }
                toggleEmptyState();
            }

            $('#searchInput').on('keyup', function () {
                table.search($(this).val()).draw();
                toggleEmptyState();
            });

            $('#dateInput').on('change', function () {
                applyCustomFilters();
            });

            function toggleEmptyState() {
                var info = table.page.info();
                if (info.recordsDisplay === 0) {
                    $('#noRecordsMessage').removeClass('d-none');
                    $('#admissionsTable').hide();
                } else {
                    $('#noRecordsMessage').addClass('d-none');
                    $('#admissionsTable').show();
                }
            }

            // initial check: if no data or all data filtered
            if (@(Model.AllcombinedData?.Count ?? 0) === 0) {
                $('#admissionsTable').hide();
                $('#noRecordsMessage').removeClass('d-none');
            } else {
                $('#admissionsTable').show();
                toggleEmptyState();
            }

            // optional: hide initial empty message if rows exist
            setTimeout(() => toggleEmptyState(), 200);
        });
    </script>

    <!-- optional fallback for any modal functionality (discharge / edit references from original, kept hidden but not breaking) -->
    <div style="display: none;">
        <!-- Hidden modals to avoid broken references (original page had edit modals, we keep placeholders to avoid JS errors) -->
        <div class="modal fade" id="editBookingModal" tabindex="-1"></div>
        <div class="modal fade" id="confirmEditBookingModal" tabindex="-1"></div>
        <div class="modal fade" id="addPrescriptionModal" tabindex="-1"></div>
        <div class="modal fade" id="confirmAddPrescriptionModal" tabindex="-1"></div>
        <div class="modal fade" id="confirmDischargeModal" tabindex="-1"></div>
    </div>

</body>
</html>
