@using DEMO.ViewModels
@{
    ViewData["Title"] = "Surgery Bookings";
    Layout = "_LayoutNurse";
}
@model ViewBookings
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Surgery Bookings</title>
    <!-- jQuery -->
    <script src="https://code.jquery.com/jquery-3.5.1.js"></script>

    <!-- DataTables CSS -->
    <link rel="stylesheet" href="https://cdn.datatables.net/1.11.5/css/jquery.dataTables.css">

    <!-- DataTables JS -->
    <script src="https://cdn.datatables.net/1.11.5/js/jquery.dataTables.js"></script>

    <!-- Bootstrap CSS -->
    <link rel="stylesheet" href="https://stackpath.bootstrapcdn.com/bootstrap/5.1.3/css/bootstrap.min.css">

    <!-- Bootstrap JS -->
    <script src="https://stackpath.bootstrapcdn.com/bootstrap/5.1.3/js/bootstrap.bundle.min.js">
    </script>
    <!-- Bootstrap 5 (CORRECT CDN) -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.1.3/dist/css/bootstrap.min.css" rel="stylesheet">

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.1.3/dist/js/bootstrap.bundle.min.js"></script>
    <style>
        /* ---------- General Table ---------- */
        #example {
            display: none; /* Hide initially */
        }

        table.display {
            width: 100%;
            border-collapse: collapse;
        }

            table.display th, table.display td {
                text-align: left;
                padding: 12px;
            }

            table.display thead {
                background-color: #1f1f1f;
                color: #fff;
            }

            table.display tr:nth-child(even) {
                background-color: #f2f2f2;
            }

        /* ---------- Form Container ---------- */
        .p-3.mt-5.border {
            border-radius: 10px;
            box-shadow: 0px 5px 15px rgba(0,0,0,0.1);
        }

        /* ---------- Input Fields ---------- */
        .form-control {
            border-radius: 6px;
            padding: 8px 12px;
            border: 1px solid #ced4da;
            transition: 0.3s;
        }

            .form-control:focus {
                border-color: #007bff;
                box-shadow: 0 0 5px rgba(0,123,255,0.3);
            }

        /* ---------- Buttons ---------- */
        .btn-primary {
            background-color: #007bff;
            border-color: #007bff;
            border-radius: 6px;
            padding: 6px 12px;
            transition: 0.3s;
        }

            .btn-primary:hover {
                background-color: #0056b3;
                border-color: #0056b3;
            }

        .btn-secondary {
            border-radius: 6px;
            padding: 6px 12px;
        }

        /* ---------- Modal Styling ---------- */
        .modal-lg, .modal-lg-custom {
            max-width: 50% !important; /* 50% width for all large modals */
            width: 50% !important;
        }

        .modal-dialog-centered {
            display: flex;
            align-items: center;
            min-height: calc(100% - 60px); /* Adjust based on header/footer */
        }

        .modal-content {
            width: 100%; /* Fit content inside new modal width */
            border-radius: 10px;
            border: none;
            box-shadow: 0px 10px 30px rgba(0, 0, 0, 0.2);
            background-color: #fff;
        }

        /* Modal Headers */
        .modal-header {
            background-color: #1f1f1f;
            color: #fff;
            border-bottom: none;
            border-top-left-radius: 10px;
            border-top-right-radius: 10px;
        }

            .modal-header .btn-close {
                filter: invert(1);
            }

        /* Modal Body */
        .modal-body {
            padding: 20px;
            max-height: 60vh;
            overflow-y: auto;
        }

        /* Modal Footer */
        .modal-footer {
            border-top: none;
            justify-content: flex-start;
        }

        /* ---------- Form Radio Inputs ---------- */
        .form-check-input {
            margin-right: 5px;
        }

        .form-check-label {
            font-weight: 500;
        }

        /* ---------- Error Messages ---------- */
        .text-danger {
            font-size: 0.85rem;
        }

        /* ---------- Row Adjustments ---------- */
        .row {
            margin-left: 0;
            margin-right: 0;
        }
    </style>
</head>
<body>
    <div class="container">
        <main role="main" class="pb-5">
            <div class="row" style="width:auto">
                <div class="col">
                    <div class="p-3 mt-5 border" style="background-color: white;">
                        <form id="searchForm">
                            <h2>Surgery List</h2>
                            <div class="form-group row">
                                <div class="col-4">
                                    <label for="searchInput" class="form-label">Search</label>
                                    <input type="text" class="form-control" id="searchInput" placeholder="Search" style="width:300px">
                                </div>
                                <div class="col-4">
                                    <label for="dateInput" class="form-label">Date</label>
                                    <input type="date" class="form-control" id="dateInput" style="width:300px">
                                </div>
                            </div>
                        </form>
                    </div>
                </div>
            </div>
            <div class="row" style="width:auto">
                <div class="col">
                    <div class="p-3 mt-5 border" style="background-color: white;">
                        <table id="example" class="display" style="width:100%">
                            <thead>
                                <tr>

                                    <th scope="col">Name</th>
                                    <th scope="col">Surname</th>
                                    <th scope="col">Surgeon Name</th>
                                    <th scope="col">Surgery Date</th>
                                    <th scope="col">Surgery Time</th>
                                    <th scope="col">Theatre</th>
                                    <th scope="col">Actions</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var Data in Model.AllcombinedData)
                                {
                                    <tr>
                                        <td>@Data.PatientName</td>
                                        <td>@Data.PatientSurname</td>
                                        <td>@Data.AccountName @Data.AccountSurname</td>
                                        <td>@Data.SurgeryDate</td>
                                        <td>@Data.SurgeryTime</td>
                                        <td>@Data.Theater</td>
                                        <td>
                                            <button class="btn btn-success"
                                                    onclick="openAdmitModal('@Data.PatientID','@Data.BookingID','@Data.PatientName','@Data.PatientSurname','@Data.AccountName @Data.AccountSurname')">
                                                Admit
                                            </button>
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>
          
        </main>
    </div>

    <!-- Admity Modal -->
    <div class="modal fade" id="admitModal" tabindex="-1">
        <div class="modal-dialog modal-lg modal-dialog-centered">
            <div class="modal-content">

                <div class="modal-header">
                    <h5 class="modal-title">Admit Patient</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                </div>

                <div class="modal-body">
                    <form method="post" asp-action="AdmitPatient" asp-controller="Nurse">

                        <!-- Patient Info -->
                       
                        <div class="form-group row">
                            <h5 class="modal-title">Patient Info</h5>
                            <div class="col-4">
                                <label>Name</label>
                                <input type="text" class="form-control" id="nameInput" readonly style="width:250px">
                            </div>

                            <div class="col-4">
                                <label>Surname</label>
                                <input type="text" class="form-control" id="surnameInput" readonly style="width:250px">
                            </div>

                            <div class="col-4">
                                <label>Surgeon</label>
                                <input type="text" class="form-control" id="surgeonInput" readonly style="width:250px">
                            </div>
                        </div>
                        <!-- Contact -->
                        <div class="form-group row">
                            <div class="col-6">
                                <label>Contact Number</label>
                                <input type="text" class="form-control" name="ContactNumber" required style="width:250px">
                            </div>
                        </div>
                        <br />
                        <!-- Address -->
                        <div class="form-group row">
                            <h5 class="modal-title">Address</h5>
                            <div class="col-4">
                                <label>Province</label>
                                <select class="form-control" id="provincetSelect" name="ProvinceID" style="width:250px" required>
                                    <option value="">Select a Description</option>
                                    @foreach (var province in Model.AllProvince)
                                    {
                                        <option value="@province.ProvinceID" data-search="@province.ProvinceName.ToLower()">@province.ProvinceName</option>
                                    }
                                </select>
                            </div>

                            <div class="col-4">
                                <label>City</label>
                                <select class="form-control" id="citySelect" name="CityID" style="width:250px" required>
                                    <option value="">Select City</option>
                                </select>
                            </div>

                            <div class="col-4">
                                <label>Suburb</label>
                                <select class="form-control" id="suburbSelect" name="suburbID" style="width:250px" required>
                                    <option value="">Select Suburb</option>
                                </select>
                            </div>

                            <div class="col-6">
                                <label>Street Name</label>
                                <input type="text" class="form-control" name="StreetName" required style="width:250px">
                            </div>

                        </div>
                        <br />
                        <!-- Ward and Bed -->
                        <div class="form-group row">

                            <div class="col-4">
                                <label>Ward</label>
                                <select class="form-control" id="wardSelect" name="wardID" style="width:250px" required>
                                    <option value="">Select a Description</option>
                                    @foreach (var ward in Model.AllWards)
                                    {
                                        <option value="@ward.WardId" data-search="@ward.WardName.ToLower()">@ward.WardName</option>
                                    }
                                </select>
                            </div>

                            <div class="col-4">
                                <label>Bed</label>
                                <select class="form-control" id="bedSelect" name="bedID" style="width:250px" required>
                                    <option value="">Select Bed</option>
                                </select>
                            </div>

                        </div>

                        <!-- Hidden Fields -->
                        <input type="hidden" id="PatientID" name="PatientID">
                        <input type="hidden" id="BookingID" name="BookingID">
                        <input type="hidden" name="AccountID" value="@ViewBag.UserAccountID">
                        <div class="modal-footer">
                            <button type="submit" class="btn btn-primary">Admit Patient</button>
                            <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Close</button>
                        </div>

                    </form>
                </div>

            </div>
        </div>
    </div>
    <script>
        $(document).ready(function () {
            var table = $('#example').DataTable({
                "language": {
                    "zeroRecords": "No matching records found"
                }
            });

            // Custom search function for the search input and date input
            $('#searchInput, #dateInput').on('keyup change', function () {
                var searchText = $('#searchInput').val().trim(); // Trim whitespace from search input
                var dateText = $('#dateInput').val(); // Get the selected date in YYYY-MM-DD format

                // If a date is selected, proceed with date filtering
                if (dateText) {
                    // Iterate through each row in the Date column (assuming it's the 4th column, index 3)
                    table.column(3).data().each(function (value, index) {
                        // Assume the date format in the table is MM/DD/YYYY
                        var tableDate = value.trim(); // Get the date from the table cell
                        var parts = tableDate.split("/"); // Split the date into month, day, year

                        if (parts.length === 3) {
                            // Reformat the date from MM/DD/YYYY to YYYY-MM-DD to match the date input
                            var reformattedDate = parts[2] + '-' + ('0' + parts[0]).slice(-2) + '-' + ('0' + parts[1]).slice(-2);

                            // Compare the reformatted table date with the selected date
                            if (reformattedDate === dateText) {
                                table.row(index).nodes().to$().show(); // Show matching row
                            } else {
                                table.row(index).nodes().to$().hide(); // Hide non-matching row
                            }
                        }
                    });
                } else {
                    // If no date is selected, reset the rows visibility
                    table.rows().nodes().to$().show();
                }

                // Apply text search to all columns
                table.search(searchText).draw();

                // Control table visibility based on inputs and search results
                if (searchText === '' && dateText === '') {
                    $('#example').hide(); // Hide table if both search inputs are empty
                } else {
                    $('#example').show(); // Show table if either input is not empty

                    // Hide table if there are no matching records after filtering
                    if (table.page.info().recordsDisplay === 0) {
                        $('#example').hide();
                    }
                }
            });

        });
    </script>
    <script>
                function openAdmitModal(patientId, bookingId, name, surname, surgeon) {
            document.getElementById("PatientID").value = patientId;
            document.getElementById("BookingID").value = bookingId;
            document.getElementById("nameInput").value = name;
            document.getElementById("surnameInput").value = surname;
            document.getElementById("surgeonInput").value = surgeon;

            var modal = new bootstrap.Modal(document.getElementById('admitModal')); 
            modal.show();


        }
    </script>
    <script>
        document.getElementById("wardSelect").addEventListener("change", function () {
            var wardId = this.value;

            var bedSelect = document.getElementById("bedSelect");
            bedSelect.innerHTML = '<option value="">Loading...</option>';

            if (wardId !== "") {
                fetch('/Nurse/GetBedsByWard?wardId=' + wardId)
                    .then(response => response.json())
                    .then(data => {
                        bedSelect.innerHTML = '<option value="">Select Bed</option>';

                        data.forEach(bed => {
                            var option = document.createElement("option");
                            option.value = bed.bedId;
                            option.text = bed.number;
                            bedSelect.appendChild(option);
                        });
                    })
                    .catch(error => {
                        console.error('Error:', error);
                    });
            } else {
                bedSelect.innerHTML = '<option value="">Select Bed</option>';
            }
        });

            // Province → City
        document.getElementById("provincetSelect").addEventListener("change", function () {
            var provinceId = this.value;

            var citySelect = document.getElementById("citySelect");
            var suburbSelect = document.getElementById("suburbSelect");

            citySelect.innerHTML = '<option>Loading...</option>';
            suburbSelect.innerHTML = '<option>Select Suburb</option>';

            if (provinceId !== "") {
                fetch('@Url.Action("GetCitiesByProvince", "Nurse")?provinceId=' + provinceId)
                    .then(response => response.json())
                    .then(data => {
                        citySelect.innerHTML = '<option value="">Select City</option>';

                        data.forEach(city => {
                            var option = document.createElement("option");
                            option.value = city.cityId;
                            option.text = city.cityName;
                            citySelect.appendChild(option);
                        });
                    })
                    .catch(err => {
                        console.error(err);
                        citySelect.innerHTML = '<option>Error loading cities</option>';
                    });
            }
        });

        // City → Suburb
        document.getElementById("citySelect").addEventListener("change", function () {
            var cityId = this.value;

            var suburbSelect = document.getElementById("suburbSelect");
            suburbSelect.innerHTML = '<option>Loading...</option>';

            if (cityId !== "") {
                fetch('@Url.Action("GetSuburbsByCity", "Nurse")?cityId=' + cityId)
                    .then(response => response.json())
                    .then(data => {
                        suburbSelect.innerHTML = '<option value="">Select Suburb</option>';

                        data.forEach(suburb => {
                            var option = document.createElement("option");
                            option.value = suburb.suburbId;
                            option.text = suburb.name;
                            suburbSelect.appendChild(option);
                        });
                    })
                    .catch(err => {
                        console.error(err);
                        suburbSelect.innerHTML = '<option>Error loading suburbs</option>';
                    });
            }
        });
    </script>
</body>
</html>
