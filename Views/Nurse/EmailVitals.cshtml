@{
    ViewData["Title"] = "Send Vitals";
    Layout = "_LayoutNurse";
}
@model DEMO.Models.NurseModels.EmailVital

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">

    <!-- Bootstrap 5 -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>

    <title>Send Vitals</title>
    <style>
        body {
            background-color: #f4f7fa;
            font-family: 'Segoe UI', sans-serif;
        }

        .form-card {
            max-width: 900px;
            margin: 50px auto;
            padding: 30px 40px;
            background-color: #fff;
            border-radius: 12px;
            box-shadow: 0 5px 15px rgba(0,0,0,0.1);
        }

        h3, h4 {
            color: #0d6efd;
            margin-bottom: 20px;
        }

        .form-label {
            font-weight: 600;
        }

        input[readonly], textarea[readonly] {
            background-color: #e9ecef;
        }

        textarea {
            resize: vertical;
        }

        .btn-primary {
            background-color: #0d6efd;
            border: none;
        }

            .btn-primary:hover {
                background-color: #0b5ed7;
            }

        .section-divider {
            border-top: 2px solid #dee2e6;
            margin: 25px 0;
        }

       
    </style>
</head>
<body>
    <div class="container">
        <div class="form-card">
            <h3 class="text-center">Send Patient Vitals</h3>
            <hr class="section-divider" />

            <form method="post" action="@Url.Action("EmailVitals", "Nurse")">
                <!-- Hidden Patient ID -->
                <input type="hidden" name="AdmittedPatientID" value="@Model.AdmittedPatientID" />

                <div class="row mb-3">
                    <div class="col-md-6 mb-3">
                        <label class="form-label" for="FullName">Patient Name</label>
                        <input type="text" class="form-control" id="FullName" name="FullName" value="@Model.FullName" readonly />
                    </div>
                    <div class="col-md-3 mb-3">
                        <label class="form-label" for="WardName">Ward</label>
                        <input type="text" class="form-control" id="WardName" name="WardName" value="@Model.WardName" readonly />
                    </div>
                    <div class="col-md-3 mb-3">
                        <label class="form-label" for="Bed">Bed</label>
                        <input type="text" class="form-control" id="Bed" name="Bed" value="@Model.Bed" readonly />
                    </div>
                </div>

                <h4>Latest Vitals</h4>
                <div class="row mb-3">
                    <div class="col-md-4 mb-3">
                        <label class="form-label" for="Height">Height (cm)</label>
                        <input type="text" class="form-control" id="Height" name="Height" value="@Model.Height" readonly />
                    </div>
                    <div class="col-md-4 mb-3">
                        <label class="form-label" for="Weight">Weight (kg)</label>
                        <input type="text" class="form-control" id="Weight" name="Weight" value="@Model.Weight" readonly />
                    </div>
                    <div class="col-md-4 mb-3">
                        <label class="form-label" for="BloodPressure">Blood Pressure (mmHg)</label>
                        <input type="text" class="form-control" id="BloodPressure" name="BloodPressure" value="@Model.SystolicBloodPressure/@Model.DiastolicBloodPressure" readonly />
                    </div>
                </div>

                <div class="row mb-3">
                    <div class="col-md-4 mb-3">
                        <label class="form-label" for="HeartRate">Heart Rate (bpm)</label>
                        <input type="text" class="form-control" id="HeartRate" name="HeartRate" value="@Model.HeartRate" readonly />
                    </div>
                    <div class="col-md-4 mb-3">
                        <label class="form-label" for="BloodOxygen">Blood Oxygen (%)</label>
                        <input type="text" class="form-control" id="BloodOxygen" name="BloodOxygen" value="@Model.BloodOxygen" readonly />
                    </div>
                    <div class="col-md-4 mb-3">
                        <label class="form-label" for="Respiration">Respiration (bpm)</label>
                        <input type="text" class="form-control" id="Respiration" name="Respiration" value="@Model.Respiration" readonly />
                    </div>
                </div>

                <div class="row mb-3">
                    <div class="col-md-4 mb-3">
                        <label class="form-label" for="BloodGlucoseLevel">Blood Glucose (mg/dL)</label>
                        <input type="text" class="form-control" id="BloodGlucoseLevel" name="BloodGlucoseLevel" value="@Model.BloodGlucoseLevel" readonly />
                    </div>
                    <div class="col-md-4 mb-3">
                        <label class="form-label" for="Temperature">Temperature (°C)</label>
                        <input type="text" class="form-control" id="Temperature" name="Temperature" value="@Model.Temperature" readonly />
                    </div>
                    <div class="col-md-4 mb-3">
                        <label class="form-label" for="Notes">Notes</label>
                        <textarea class="form-control" id="Notes" name="notes" rows="3">@Model.Notes</textarea>
                    </div>
                </div>

                <div class="text-center mt-4">
                    <button type="submit" class="btn btn-primary btn-lg">Send Email</button>
                </div>
            </form>
        </div>
    </div>
</body>
</html>