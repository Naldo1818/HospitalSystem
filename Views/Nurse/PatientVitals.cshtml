@{
    ViewData["Title"] = "Patient Vitals";
    Layout = "_LayoutNurse";
}
@model DEMO.ViewModels.PatientVitalsViewModel
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, user-scalable=yes">
    <title>Patient Vitals | Clinical Monitoring</title>

    <!-- Google Fonts + Font Awesome -->
    <link href="https://fonts.googleapis.com/css2?family=Inter:opsz,wght@14..32,300;14..32,400;14..32,500;14..32,600;14..32,700&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0-beta3/css/all.min.css">

    <!-- jQuery -->
    <script src="https://code.jquery.com/jquery-3.7.1.min.js" integrity="sha256-/JqT3SQfawRcv/BIHPThkBvs0OEvtFFmqPF/lYI/Cxo=" crossorigin="anonymous"></script>

    <!-- Bootstrap 5.3 + clean theme -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0-alpha1/dist/css/bootstrap.min.css" rel="stylesheet">
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0-alpha1/dist/js/bootstrap.bundle.min.js"></script>

    <!-- DataTables + BS5 integration -->
    <link rel="stylesheet" href="https://cdn.datatables.net/1.13.4/css/dataTables.bootstrap5.min.css">
    <script src="https://cdn.datatables.net/1.13.4/js/jquery.dataTables.min.js"></script>
    <script src="https://cdn.datatables.net/1.13.4/js/dataTables.bootstrap5.min.js"></script>

    <style>
        * {
            font-family: 'Inter', sans-serif;
        }

        body {
            background: #f4f7fc;
            margin: 0;
            padding: 0;
        }

        .main-container {
            max-width: 1600px;
            margin: 0 auto;
            padding: 1.8rem 1.5rem;
        }

        /* modern card style */
        .modern-card {
            background: #ffffff;
            border-radius: 28px;
            box-shadow: 0 12px 28px rgba(0, 0, 0, 0.04), 0 0 1px rgba(0, 0, 0, 0.03);
            transition: all 0.2s ease;
            border: none;
            overflow: hidden;
        }

        .card-header-custom {
            background: white;
            padding: 1.2rem 1.8rem 0.6rem 1.8rem;
            border-bottom: 2px solid #eef2fa;
        }

        .card-body-custom {
            padding: 1.6rem 1.8rem 1.8rem 1.8rem;
        }

        .page-title {
            font-weight: 700;
            font-size: 1.8rem;
            letter-spacing: -0.3px;
            background: linear-gradient(135deg, #1f4870, #1b3b5c);
            background-clip: text;
            -webkit-background-clip: text;
            color: transparent;
            margin-bottom: 0;
        }

        .patient-badge {
            background-color: #eef2ff;
            padding: 6px 16px;
            border-radius: 40px;
            font-size: 0.85rem;
            font-weight: 500;
            color: #1e3a8a;
            display: inline-flex;
            align-items: center;
            gap: 8px;
        }

        .form-label-modern {
            font-weight: 600;
            font-size: 0.7rem;
            text-transform: uppercase;
            letter-spacing: 0.5px;
            color: #4a627a;
            margin-bottom: 0.4rem;
        }

        .vital-input-group {
            background: #fefefe;
            border-radius: 16px;
            border: 1px solid #e2e8f0;
            transition: 0.2s;
        }

            .vital-input-group:focus-within {
                border-color: #2c7da0;
                box-shadow: 0 0 0 3px rgba(44,125,160,0.08);
            }

        .form-control-vital {
            border: none;
            background: transparent;
            padding: 0.7rem 1rem;
            font-weight: 500;
            border-radius: 16px;
        }

            .form-control-vital:focus {
                outline: none;
                box-shadow: none;
                background: transparent;
            }

        .input-unit {
            font-size: 0.7rem;
            color: #8ba0bc;
            padding-right: 12px;
            font-weight: 500;
        }

        .btn-primary-soft {
            background: #1f7b4d;
            border: none;
            border-radius: 40px;
            padding: 0.6rem 2rem;
            font-weight: 600;
            transition: all 0.2s ease;
        }

            .btn-primary-soft:hover {
                background: #0f5e3a;
                transform: translateY(-1px);
                box-shadow: 0 8px 20px rgba(31,123,77,0.2);
            }

        .btn-outline-secondary-clean {
            border-radius: 40px;
            border: 1px solid #cbd5e1;
            padding: 0.55rem 1.5rem;
            font-weight: 500;
            background: white;
        }

            .btn-outline-secondary-clean:hover {
                background: #f8fafc;
                border-color: #94a3b8;
            }

        /* table styling */
        .data-table-wrapper {
            overflow-x: auto;
            border-radius: 20px;
        }

        .table-vitals {
            width: 100%;
            margin-bottom: 0;
            font-size: 0.8rem;
        }

            .table-vitals th {
                background: #f8fafd;
                color: #1f3b4c;
                font-weight: 600;
                font-size: 0.7rem;
                padding: 0.9rem 0.6rem;
                border-bottom: 1px solid #e9edf2;
                white-space: nowrap;
            }

            .table-vitals td {
                padding: 0.8rem 0.6rem;
                vertical-align: middle;
                border-bottom: 1px solid #f0f2f7;
                color: #1f2f3e;
            }

        .badge-bmi {
            background: #eef2ff;
            color: #1f4870;
            border-radius: 40px;
            padding: 4px 10px;
            font-size: 0.7rem;
            font-weight: 600;
            display: inline-block;
        }

        .btn-outline-remove-sm {
            border-radius: 40px;
            padding: 0.25rem 1rem;
            font-size: 0.7rem;
            font-weight: 600;
            border: 1px solid #f1c0c0;
            background: #fff8f8;
            color: #b91c1c;
        }

            .btn-outline-remove-sm:hover {
                background: #fee2e2;
            }

        .empty-state {
            text-align: center;
            padding: 2rem;
            background: #fafcff;
            border-radius: 24px;
        }

        hr.divider-light {
            margin: 1.2rem 0;
            background: #eef2fa;
            height: 1px;
            opacity: 0.6;
        }

        /* modal modern */
        .modal-content-modern {
            border-radius: 28px;
            border: none;
            box-shadow: 0 25px 45px -12px rgba(0,0,0,0.3);
            overflow: hidden;
        }

        .modal-header-modern {
            background: #1f3b4c;
            color: white;
            border-bottom: none;
        }

            .modal-header-modern .btn-close {
                filter: brightness(0) invert(1);
            }

        /* responsive grid */
      

        }
    </style>
</head>
<body>

    <div class="main-container">
        <main role="main">
            <!-- Header -->
            <div class="d-flex flex-wrap justify-content-between align-items-center mb-4">
                <div>
                    <h1 class="page-title"><i class="fas fa-heartbeat me-2" style="color:#e67e22;"></i> Patient Vitals</h1>
                    <div class="mt-2">
                        <span class="patient-badge">
                            <i class="fas fa-user-injured me-1"></i> @ViewBag.PatientName @ViewBag.PatientSurname
                        </span>
                        <span class="badge bg-light text-dark ms-2 rounded-pill">
                            <i class="far fa-id-card"></i> ID: @ViewBag.PatientID
                        </span>
                    </div>
                </div>
                <div class="mt-2 mt-sm-0">
                    <a href="@Url.Action("AdmittedPatients", "Nurse")" class="btn btn-light rounded-pill shadow-sm px-4 py-2">
                        <i class="fas fa-arrow-left me-2"></i>Back to Admissions
                    </a>
                </div>
            </div>

            <!-- Add Vitals Form Card -->
            <div class="modern-card mb-4">
                <div class="card-header-custom">
                    <div class="d-flex align-items-center gap-2">
                        <i class="fas fa-notes-medical fs-5" style="color:#e67e22;"></i>
                        <h5 class="fw-bold mb-0" style="color:#1f2f3e;">Record New Vitals</h5>
                    </div>
                    <p class="text-muted small mt-1 mb-0">Enter patient clinical measurements below</p>
                </div>
                <div class="card-body-custom">
                    <form id="addPatientVitals" method="post" asp-action="AddPatientVitals" asp-controller="Nurse">
                        <input type="hidden" asp-for="PatientID" value="@ViewBag.PatientID" />
                        <input type="hidden" asp-for="Date" />
                        <input type="hidden" asp-for="Time" />

                        <div class="row g-4">
                            <div class="col-md-6 col-lg-3">
                                <label class="form-label-modern"><i class="fas fa-arrow-up me-1"></i> Height</label>
                                <div class="d-flex align-items-center vital-input-group">
                                    <input asp-for="Height" class="form-control form-control-vital" type="number" step="0.1" placeholder="e.g., 175" required />
                                    <span class="input-unit">cm</span>
                                </div>
                            </div>
                            <div class="col-md-6 col-lg-3">
                                <label class="form-label-modern"><i class="fas fa-weight-hanging me-1"></i> Weight</label>
                                <div class="d-flex align-items-center vital-input-group">
                                    <input asp-for="Weight" class="form-control form-control-vital" type="number" step="0.1" placeholder="e.g., 70.5" required />
                                    <span class="input-unit">kg</span>
                                </div>
                            </div>
                            <div class="col-md-6 col-lg-3">
                                <label class="form-label-modern"><i class="fas fa-thermometer-half me-1"></i> Temperature</label>
                                <div class="d-flex align-items-center vital-input-group">
                                    <input asp-for="Temperature" class="form-control form-control-vital" type="number" step="0.1" placeholder="e.g., 36.6" required />
                                    <span class="input-unit">°C</span>
                                </div>
                            </div>
                            <div class="col-md-6 col-lg-3">
                                <label class="form-label-modern"><i class="fas fa-tachometer-alt me-1"></i> Heart Rate</label>
                                <div class="d-flex align-items-center vital-input-group">
                                    <input asp-for="HeartRate" class="form-control form-control-vital" type="number" placeholder="e.g., 72" required />
                                    <span class="input-unit">bpm</span>
                                </div>
                            </div>
                            <div class="col-md-6 col-lg-3">
                                <label class="form-label-modern"><i class="fas fa-tint me-1"></i> Systolic BP</label>
                                <div class="d-flex align-items-center vital-input-group">
                                    <input asp-for="SystolicBloodPressure" class="form-control form-control-vital" type="number" placeholder="e.g., 120" required />
                                    <span class="input-unit">mmHg</span>
                                </div>
                            </div>
                            <div class="col-md-6 col-lg-3">
                                <label class="form-label-modern"><i class="fas fa-tint me-1"></i> Diastolic BP</label>
                                <div class="d-flex align-items-center vital-input-group">
                                    <input asp-for="DiastolicBloodPressure" class="form-control form-control-vital" type="number" placeholder="e.g., 80" required />
                                    <span class="input-unit">mmHg</span>
                                </div>
                            </div>
                            <div class="col-md-6 col-lg-3">
                                <label class="form-label-modern"><i class="fas fa-lungs me-1"></i> Blood Oxygen</label>
                                <div class="d-flex align-items-center vital-input-group">
                                    <input asp-for="BloodOxygen" class="form-control form-control-vital" type="number" step="0.1" placeholder="e.g., 98" required />
                                    <span class="input-unit">%</span>
                                </div>
                            </div>
                            <div class="col-md-6 col-lg-3">
                                <label class="form-label-modern"><i class="fas fa-breathing me-1"></i> Respiration</label>
                                <div class="d-flex align-items-center vital-input-group">
                                    <input asp-for="Respiration" class="form-control form-control-vital" type="number" placeholder="e.g., 16" required />
                                    <span class="input-unit">bpm</span>
                                </div>
                            </div>
                            <div class="col-md-6 col-lg-4">
                                <label class="form-label-modern"><i class="fas fa-syringe me-1"></i> Blood Glucose</label>
                                <div class="d-flex align-items-center vital-input-group">
                                    <input asp-for="BloodGlucoseLevel" class="form-control form-control-vital" type="number" step="0.1" placeholder="e.g., 95" required />
                                    <span class="input-unit">mg/dL</span>
                                </div>
                            </div>
                        </div>

                        <div class="d-flex gap-3 mt-5">
                            <button type="button" id="openVital" class="btn btn-primary-soft px-5"><i class="fas fa-save me-2"></i>Save Vitals</button>
                            <a asp-action="AdmittedPatients" class="btn btn-outline-secondary-clean"><i class="fas fa-times me-2"></i>Cancel</a>
                        </div>
                    </form>
                </div>
            </div>

            <!-- Vitals History Card -->
            <div class="modern-card">
                <div class="card-header-custom">
                    <div class="d-flex justify-content-between align-items-center">
                        <div>
                            <i class="fas fa-chart-line me-2" style="color:#e67e22;"></i>
                            <strong>Vitals History</strong>
                        </div>
                        <span class="badge bg-light text-dark rounded-pill px-3 py-2">
                            <i class="fas fa-history"></i> @Model.PatientVitals.Count records
                        </span>
                    </div>
                </div>
                <div class="card-body-custom">
                    @if (Model.PatientVitals != null && Model.PatientVitals.Any())
                    {
                        <div class="data-table-wrapper">
                            <table id="vitalsTable" class="table table-vitals">
                                <thead>
                                    <tr>
                                        <th>Name</th>
                                        <th>Surname</th>
                                        <th>Date</th>
                                        <th>Time</th>
                                        <th>Height</th>
                                        <th>Weight</th>
                                        <th>BMI</th>
                                        <th>BP (Sys/Dia)</th>
                                        <th>HR</th>
                                        <th>SpO₂</th>
                                        <th>RR</th>
                                        <th>Glucose</th>
                                        <th>Temp</th>
                                        <th style="width:70px">Action</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach (var item in Model.PatientVitals)
                                    {
                                        <tr>
                                            <td class="fw-semibold">@item.Name</td>
                                            <td>@item.Surname</td>
                                            <td>@item.Date</td>
                                            <td>@item.Time</td>
                                            <td>@item.Height cm</td>
                                            <td>@item.Weight kg</td>
                                            <td>
                                                @{
                                                    double heightInMeters = item.Height / 100.0;
                                                    double bmi = heightInMeters > 0 ? item.Weight / (heightInMeters * heightInMeters) : 0;
                                                }
                                                <span class="badge-bmi">@bmi.ToString("0.0")</span>
                                            </td>
                                            <td>@item.SystolicBloodPressure / @item.DiastolicBloodPressure</td>
                                            <td>@item.HeartRate</td>
                                            <td>@item.BloodOxygen%</td>
                                            <td>@item.Respiration</td>
                                            <td>@item.BloodGlucoseLevel</td>
                                            <td>@item.Temperature°C</td>
                                            <td>
                                                <form asp-action="DeletetVital" asp-controller="Nurse" method="post" onsubmit="return confirm('Delete this vital record?');">
                                                    <input type="hidden" name="patientVitalsID" value="@item.PatientVitalsID" />
                                                    <input type="hidden" name="patientID" value="@item.PatientID" />
                                                    <button type="submit" class="btn btn-outline-remove-sm">
                                                        <i class="fas fa-trash-alt"></i>
                                                    </button>
                                                </form>
                                            </td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>
                    }
                    else
                    {
                        <div class="empty-state">
                            <i class="fas fa-heartbeat fa-2x text-muted"></i>
                            <p class="mt-2 mb-0">No vital records found for this patient.</p>
                            <small class="text-muted">Use the form above to record the first set of vitals.</small>
                        </div>
                    }

                    <hr class="divider-light">
                    <div class="d-flex justify-content-end">
                        <a class="btn btn-save" asp-controller="Nurse" asp-action="MainPage" style="background:#2c7da0; border-radius:40px; padding:0.6rem 2rem; color:white; font-weight:600;">
                            <i class="fas fa-check-circle me-2"></i> Finish & Exit
                        </a>
                    </div>
                </div>
            </div>
        </main>
    </div>

    <!-- Confirmation Modal -->
    <div class="modal fade" id="confirmVital" tabindex="-1" data-bs-backdrop="static">
        <div class="modal-dialog modal-dialog-centered">
            <div class="modal-content modal-content-modern">
                <div class="modal-header modal-header-modern">
                    <h5 class="modal-title fw-bold"><i class="fas fa-question-circle me-2"></i>Confirm Vital Record</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                </div>
                <div class="modal-body p-4">
                    <div class="d-flex align-items-center">
                        <i class="fas fa-stethoscope me-3 fs-1" style="color:#e67e22;"></i>
                        <span>Are you sure you want to save this vital signs record for the patient?</span>
                    </div>
                </div>
                <div class="modal-footer border-0 pt-0 pb-4 pe-4">
                    <button type="button" id="saveVitalButton" class="btn btn-primary rounded-pill px-4" style="background:#1f7b4d;">Yes, Save</button>
                    <button type="button" class="btn btn-outline-secondary rounded-pill px-4" data-bs-dismiss="modal">Cancel</button>
                </div>
            </div>
        </div>
    </div>

    <script>
        $(document).ready(function () {
            // Initialize DataTable
            $('#vitalsTable').DataTable({
                "pageLength": 6,
                "lengthMenu": [[5, 6, 10, 15], [5, 6, 10, 15]],
                "language": {
                    "zeroRecords": "No vitals recorded",
                    "info": "Showing _START_ to _END_ of _TOTAL_ entries",
                    "search": "Filter:"
                },
                "order": [[2, 'desc'], [3, 'desc']], // date desc, time desc
                "scrollX": true
            });
        });

        // Show confirmation modal
        $('#openVital').on('click', function () {
            // Simple validation for required fields
            let isValid = true;
            $('#addPatientVitals input[required]').each(function() {
                if (!$(this).val()) {
                    $(this).css('border', '1px solid #e53e3e');
                    isValid = false;
                } else {
                    $(this).css('border', '');
                }
            });
            if (!isValid) {
                alert("Please fill in all vital fields before saving.");
                return;
            }
            $('#confirmVital').modal('show');
        });

        // Confirm save via AJAX (matches original functionality with redirect)
        $('#saveVitalButton').on('click', function () {
            $.ajax({
                url: '@Url.Action("AddPatientVitals", "Nurse")',
                type: 'POST',
                data: $('#addPatientVitals').serialize(),
                success: function (response) {
                    if (response.success) {
                        window.location.href = response.redirectUrl;
                    } else {
                        alert(response.message || "Unable to save vitals. Please check values.");
                        $('#confirmVital').modal('hide');
                    }
                },
                error: function (xhr, status, error) {
                    console.error("Error:", error);
                    alert("An error occurred while saving vitals.");
                    $('#confirmVital').modal('hide');
                }
            });
        });
    </script>

</body>
</html>
