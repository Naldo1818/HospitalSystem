@{
    ViewData["Title"] = "Patient Vitals";
    Layout = "_LayoutNurse";
}
@model DEMO.ViewModels.PatientVitalsViewModel
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Patient Vitals</title>
    <link rel="stylesheet" href="https://cdn.datatables.net/1.10.21/css/jquery.dataTables.min.css">
    <script src="https://code.jquery.com/jquery-3.5.1.js"></script>
    <script src="https://cdn.datatables.net/1.10.21/js/jquery.dataTables.min.js"></script>
   
</head>
<body>
    <div class="container">
        <main role="main" class="pb-5">
            <div class="row" style="width:auto">
                <div class="col">
                    <div class="p-3 mt-5 border" style="background-color: white;">
            <h2>Add Patient Vitals</h2>

          
                <form id="addPatientVitals" method="post" asp-action="AddPatientVitals" asp-controller="Nurse">
                <!-- Hidden PatientID -->
                            <input type="hidden" asp-for="PatientID" value="@ViewBag.PatientID" />
                <input type="hidden" asp-for="Date" />
                <input type="hidden" asp-for="Time"  />
                <div class="row">

                    <div class="col-md-4">
                                    <label class="form-label">Height (cm)</label>
                                    <input asp-for="Height" class="form-control" style="width:250px" required />
                    </div>

                    <div class="col-md-4">
                                    <label class="form-label">Weight (kg)</label>
                                    <input asp-for="Weight" class="form-control" style="width:250px" required />
                    </div>

                    <div class="col-md-4">
                                    <label class="form-label">Temperature  (°C)</label>
                                    <input asp-for="Temperature" class="form-control" style="width:250px" required />
                    </div>

                    <div class="col-md-4 mt-3">
                                    <label class="form-label">Systolic Blood Pressure (mmHg)</label>
                                    <input asp-for="SystolicBloodPressure" class="form-control" style="width:250px" required />
                    </div>

                    <div class="col-md-4 mt-3">
                                    <label class="form-label">Diastolic Blood Pressure (mmHg)</label>
                                    <input asp-for="DiastolicBloodPressure" class="form-control" style="width:250px" required />
                    </div>

                    <div class="col-md-4 mt-3">
                                    <label class="form-label">Heart Rate (bpm)</label>
                                    <input asp-for="HeartRate" class="form-control" style="width:250px" required />
                    </div>

                    <div class="col-md-4 mt-3">
                                    <label class="form-label">Blood Oxygen (%)</label>
                                    <input asp-for="BloodOxygen" class="form-control" style="width:250px" required />
                    </div>

                    <div class="col-md-4 mt-3">
                                    <label class="form-label">Respiration  (bpm)</label>
                        <input asp-for="Respiration" class="form-control"  style="width:250px" required />
                    </div>

                    <div class="col-md-4 mt-3">
                                    <label class="form-label">Blood Glucose (mg/dL)</label>
                                    <input asp-for="BloodGlucoseLevel" class="form-control" style="width:250px" required />
                    </div>
                </div>
                <br />
                     <button type="button" id="openVital" class="btn btn-primary">Save Vital</button>
                     <a asp-action="Index" class="btn btn-secondary">Cancel</a>

                     </form>
                    </div>
                </div>
            </div>
            <div class="row" style="width:auto">
                <div class="col">
                    <div class="p-3 mt-5 border" style="background-color: white;">
                        <div class="table-responsive">
                            <table class="table table-bordered">
                            <thead>
                                <tr>
                                    <th scope="col">Name</th>
                                    <th scope="col">Surname</th>
                                    <th scope="col">Date</th>
                                    <th scope="col">Time</th>
                                    <th scope="col">Height cm</th>
                                    <th scope="col">Weight kg</th>
                                    <th scope="col">BMI</th>
                                    <th scope="col">Systolic Blood Pressure mmHg</th>
                                    <th scope="col">Distolic Blood Pressure mmHg</th>
                                    <th scope="col">Heart Rate bpm</th>
                                    <th scope="col">Blood Oxygen %</th>
                                    <th scope="col">Respiration Rate bpm</th>
                                    <th scope="col">Blood Glucose Level mg/dL</th>
                                    <th scope="col">Temperature °C</th>
                                    <th scope="col">Action</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var item in Model.PatientVitals)
                                {
                                    <tr>
                                        <td>@item.Name</td>
                                        <td>@item.Surname</td>
                                        <td>@item.Date</td>
                                        <td>@item.Time</td>
                                        <td>@item.Height</td>
                                        <td>@item.Weight</td>
                                            <td>
                                                @{
                                                    double heightInMeters = item.Height / 100.0;
                                                    double bmi = heightInMeters > 0
                                                    ? item.Weight / (heightInMeters * heightInMeters)
                                                    : 0;
                                                }
                                                @bmi.ToString("0.00")
                                            </td>
                                        <td>@item.SystolicBloodPressure</td>
                                        <td>@item.DiastolicBloodPressure</td>
                                        <td>@item.HeartRate</td>
                                        <td>@item.BloodOxygen</td>
                                        <td>@item.Respiration</td>
                                        <td>@item.BloodGlucoseLevel</td>
                                        <td>@item.Temperature</td>
                                        
                                        <td>
                                                <form asp-action="DeletetVital" asp-controller="Nurse" method="post">
                                                    <input type="hidden" name="patientVitalsID" value="@item.PatientVitalsID" />
                                                    <input type="hidden" name="patientID" value="@item.PatientID" />

                                                    <button type="submit" class="btn btn-danger">Remove</button>
                                                </form>
                                        </td>

                                    </tr>
                                }
                            </tbody>
                        </table>
                        </div>
                        <div class="form-group row">
                            <div class="col-4">
                                <br>
                                <a class="btn btn-primary" aria-hidden="true" asp-controller="Home" asp-action="SurgeonHome">Save</a>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
            <!-- Confirmation Modal -->
            <div class="modal fade" id="confirmVital" tabindex="-1" role="dialog" aria-labelledby="confirmVital" aria-hidden="true">
                <div class="modal-dialog modal-dialog-centered" role="document">
                    <div class="modal-content">
                        <div class="modal-header">
                            <h5 class="modal-title" id="confirmVital">Confirm Save</h5>
                            <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                        </div>
                        <div class="modal-body">
                            Are you sure you want to add this Vital Record?
                        </div>
                        <div class="modal-footer">
                            <button type="button" id="saveVitalButton" class="btn btn-primary">Yes</button>
                            <button type="button" class="btn btn-secondary" data-dismiss="modal" id="cancelSaveButton">No</button>
                        </div>
                    </div>
                </div>
            </div>
            <script>
                // Show confirmation modal
                $('#openVital').on('click', function () {
                    $('#confirmVital').modal('show');
                });

                // Close modal when clicking "No"
                $('#cancelSaveButton').on('click', function () {
                    $('#confirmVital').modal('hide');
                });

                // Confirm save
                                           $('#saveVitalButton').on('click', function () {
                    $.ajax({
                        url: '@Url.Action("AddPatientVitals", "Nurse")',
                        type: 'POST',
                        data: $('#addPatientVitals').serialize(),
                        success: function (response) {
                            if (response.success) {
                                // Redirect to EmailVitals using URL from server
                                window.location.href = response.redirectUrl;
                            } else {
                                alert(response.message || "Something went wrong. her");
                            }
                        },
                        error: function (xhr, status, error) {
                            console.log("Error occurred:", error);
                        }
                    });
                });
            </script>
        </main>
    </div>
</body>
</html>
