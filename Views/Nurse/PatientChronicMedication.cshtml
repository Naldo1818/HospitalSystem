@{
    ViewData["Title"] = "Patient Chronic Medication";
    Layout = "_Layout2";
}
@model DEMO.ViewModels.PatientChronicMedicationVM

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Patient Chronic Medication </title>
   

    <!-- jQuery -->
    <script src="https://code.jquery.com/jquery-3.5.1.js"></script>

    <!-- DataTables -->
    <link rel="stylesheet" href="https://cdn.datatables.net/1.11.5/css/jquery.dataTables.css">
    <script src="https://cdn.datatables.net/1.11.5/js/jquery.dataTables.js"></script>

    <!-- Bootstrap 5 -->
    <link rel="stylesheet" href="https://stackpath.bootstrapcdn.com/bootstrap/5.1.3/css/bootstrap.min.css">
    <script src="https://stackpath.bootstrapcdn.com/bootstrap/5.1.3/js/bootstrap.bundle.min.js"></script>
</head>

<body>
    <div class="container">
        <main role="main" class="pb-5">

            <!-- ================= ADD MEDICATION ================= -->
            <div class="row">
                <div class="col">
                    <div class="p-3 mt-5 border bg-white">

                        <form id="AddChronicMedicationForm" method="post" asp-action="AddChronicMedication" asp-controller="Nurse">
                            <h2>Patient Chronic Medication - @ViewBag.PatientName @ViewBag.PatientSurname</h2>

                            <div class="form-group row">

                                <!-- Search -->
                                <div class="col-4">
                                    <label class="form-label mt-3">Search Chronic Medication</label>
                                    <input id="searchChronicMedicationInput"
                                           class="form-control"
                                           type="search"
                                           placeholder="Search..."
                                           onkeyup="filterChronicMedicationNames()"
                                           style="width:250px">
                                </div>

                                <!-- Dropdown -->
                                <div class="col-4">
                                    <label class="form-label mt-3">Chronic Medication</label>
                                    <select class="form-control"
                                            id="CMedicationID"
                                            name="CMedicationID"
                                            required style="width:250px">

                                        <option value="">Select Medication</option>

                                        @foreach (var med in Model.AllChronicMedication)
                                        {
                                            <option value="@med.CMedicationID">
                                                @med.CMedicationName
                                            </option>
                                        }
                                    </select>
                                </div>

                                <!-- Button -->
                                <div class="col-4 mt-5">
                                    <input type="hidden" name="PatientID" value="@ViewBag.PatientID" />
                                    <button type="button" id="openTreatmentButton" class="btn btn-primary">
                                        Add
                                    </button>
                                </div>

                            </div>
                        </form>

                    </div>
                </div>
            </div>

            <!-- ================= TABLE ================= -->
            <div class="row">
                <div class="col">
                    <div class="p-3 mt-5 border bg-white">

                        <table id="medTable" class="table table-striped">
                            <thead>
                                <tr>
                                    <th>Name</th>
                                    <th>Surname</th>
                                    <th>Medication</th>
                                    <th>Form</th>
                                    <th>Schedule</th>
                                    <th>Action</th>
                                </tr>
                            </thead>

                            <tbody>
                                @foreach (var item in Model.PatientMedicationlist)
                                {
                                    <tr>
                                        <td>@item.Name</td>
                                        <td>@item.Surname</td>
                                        <td>@item.CMedicationName</td>
                                        <td>@item.CMedicationForm</td>
                                        <td>@item.Schedule</td>
                                        <td>
                                            <form asp-action="DeletePatientMedication" asp-controller="Nurse" method="post">
                                                <input type="hidden" name="patientConditionsID" value="@item.patientConditionsID" />
                                                <input type="hidden" name="patientID" value="@item.PatientID" />
                                                <button type="submit" class="btn btn-danger">Remove</button>
                                            </form>
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>

                        <a class="btn btn-primary" asp-controller="Nurse" asp-action="AdmittedPatients">
                            Save
                        </a>

                    </div>
                </div>
            </div>

            <!-- ================= MODAL ================= -->
            <div class="modal fade" id="confirmTreatmentModal" tabindex="-1">
                <div class="modal-dialog modal-dialog-centered">
                    <div class="modal-content">

                        <div class="modal-header">
                            <h5 class="modal-title">Confirm</h5>
                            <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                        </div>

                        <div class="modal-body">
                            Are you sure you want to add this medication?
                        </div>

                        <div class="modal-footer">
                            <button type="button" id="saveTreatmentButton" class="btn btn-primary">Yes</button>
                            <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">No</button>
                        </div>

                    </div>
                </div>
            </div>

        </main>
    </div>

    <!-- ================= SCRIPT ================= -->
    <script>

        $(document).ready(function () {
            $('#medTable').DataTable();
        });

        // Open modal
        $('#openTreatmentButton').click(function () {
            $('#confirmTreatmentModal').modal('show');
        });

        // Confirm save
        $('#saveTreatmentButton').click(function () {

            $.ajax({
                url: '@Url.Action("AddChronicMedication", "Nurse")',
                type: 'POST',
                data: $('#AddChronicMedicationForm').serialize(),
                success: function () {
                    location.reload(); // refresh page
                },
                error: function (err) {
                    console.log(err);
                }
            });

        });

        // Filter dropdown
        function filterChronicMedicationNames() {

            let input = $('#searchChronicMedicationInput').val().toLowerCase();

            $('#ChronicMedicationSelect option').each(function () {
                let text = $(this).text().toLowerCase();
                $(this).toggle(text.includes(input));
            });
        }

    </script>

</body>
</html>