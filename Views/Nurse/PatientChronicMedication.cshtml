@{
    ViewData["Title"] = "Patient Chronic Medication";
    Layout = "_LayoutNurse";
}
@model DEMO.ViewModels.PatientChronicMedicationVM
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, user-scalable=yes">
    <title>Patient Chronic Medication | Medication Management</title>

    <!-- Google Fonts + Font Awesome -->
    <link href="https://fonts.googleapis.com/css2?family=Inter:opsz,wght@14..32,300;14..32,400;14..32,500;14..32,600;14..32,700&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0-beta3/css/all.min.css">

    <!-- jQuery -->
    <script src="https://code.jquery.com/jquery-3.7.1.min.js" integrity="sha256-/JqT3SQfawRcv/BIHPThkBvs0OEvtFFmqPF/lYI/Cxo=" crossorigin="anonymous"></script>

    <!-- Bootstrap 5.3 + clean theme -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0-alpha1/dist/css/bootstrap.min.css" rel="stylesheet">
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0-alpha1/dist/js/bootstrap.bundle.min.js"></script>

    <!-- DataTables + BS5 integration -->
    <link rel="stylesheet" href="https://cdn.datatables.net/1.13.4/css/dataTables.bootstrap5.min.css">
    <script src="https://cdn.datatables.net/1.13.4/js/jquery.dataTables.min.js"></script>
    <script src="https://cdn.datatables.net/1.13.4/js/dataTables.bootstrap5.min.js"></script>

    <style>
        * {
            font-family: 'Inter', sans-serif;
        }

        body {
            background: #f4f7fc;
            margin: 0;
            padding: 0;
        }

        .main-container {
            max-width: 1400px;
            margin: 0 auto;
            padding: 1.8rem 1.5rem;
        }

        /* modern card style */
        .modern-card {
            background: #ffffff;
            border-radius: 28px;
            box-shadow: 0 12px 28px rgba(0, 0, 0, 0.04), 0 0 1px rgba(0, 0, 0, 0.03);
            transition: all 0.2s ease;
            border: none;
            overflow: hidden;
        }

        .card-header-custom {
            background: white;
            padding: 1.2rem 1.8rem 0.6rem 1.8rem;
            border-bottom: 2px solid #eef2fa;
        }

        .card-body-custom {
            padding: 1.6rem 1.8rem 1.8rem 1.8rem;
        }

        .page-title {
            font-weight: 700;
            font-size: 1.8rem;
            letter-spacing: -0.3px;
            background: linear-gradient(135deg, #1f4870, #1b3b5c);
            background-clip: text;
            -webkit-background-clip: text;
            color: transparent;
            margin-bottom: 0;
        }

        .patient-badge {
            background-color: #eef2ff;
            padding: 6px 16px;
            border-radius: 40px;
            font-size: 0.85rem;
            font-weight: 500;
            color: #1e3a8a;
            display: inline-flex;
            align-items: center;
            gap: 8px;
        }

        .form-label-modern {
            font-weight: 600;
            font-size: 0.8rem;
            text-transform: uppercase;
            letter-spacing: 0.4px;
            color: #4a627a;
            margin-bottom: 0.5rem;
        }

        .search-input-icon {
            position: relative;
        }

            .search-input-icon i {
                position: absolute;
                left: 14px;
                top: 50%;
                transform: translateY(-50%);
                color: #8a99b4;
                font-size: 0.9rem;
                pointer-events: none;
            }

            .search-input-icon input {
                padding-left: 40px;
                border-radius: 60px;
                border: 1px solid #e2e8f0;
                background: #ffffff;
                transition: 0.2s;
                height: 44px;
            }

                .search-input-icon input:focus {
                    border-color: #2c7da0;
                    box-shadow: 0 0 0 3px rgba(44,125,160,0.1);
                    outline: none;
                }

        .nice-select {
            border-radius: 16px;
            border: 1px solid #e2e8f0;
            background: #fafcff;
            padding: 0.6rem 1rem;
            font-weight: 500;
            color: #1f2a44;
            transition: 0.2s;
            height: 44px;
        }

            .nice-select:focus {
                border-color: #2c7da0;
                box-shadow: 0 0 0 3px rgba(44,125,160,0.1);
                outline: none;
            }

        .btn-primary-soft {
            background: #1f7b4d;
            border: none;
            border-radius: 40px;
            padding: 0.55rem 1.8rem;
            font-weight: 600;
            transition: all 0.2s ease;
        }

            .btn-primary-soft:hover {
                background: #0f5e3a;
                transform: translateY(-1px);
                box-shadow: 0 8px 20px rgba(31,123,77,0.2);
            }

        .btn-outline-remove {
            border-radius: 40px;
            padding: 0.35rem 1.2rem;
            font-size: 0.75rem;
            font-weight: 600;
            border: 1px solid #f1c0c0;
            background: #fff8f8;
            color: #b91c1c;
            transition: all 0.15s;
        }

            .btn-outline-remove:hover {
                background: #fee2e2;
                border-color: #f5acac;
                color: #991b1b;
            }

        .btn-save {
            background: #2c7da0;
            border: none;
            border-radius: 40px;
            padding: 0.6rem 2rem;
            font-weight: 600;
            color: white;
            transition: 0.2s;
        }

            .btn-save:hover {
                background: #1f5e7a;
                transform: translateY(-1px);
            }

        /* table styling */
        .data-table-wrapper {
            overflow-x: auto;
            border-radius: 20px;
            margin-bottom: 1.5rem;
        }

        .table-medication {
            width: 100%;
            margin-bottom: 0;
            border-collapse: separate;
            border-spacing: 0;
        }

            .table-medication th {
                background: #f8fafd;
                color: #1f3b4c;
                font-weight: 600;
                font-size: 0.8rem;
                padding: 1rem 1rem;
                border-bottom: 1px solid #e9edf2;
            }

            .table-medication td {
                padding: 1rem 1rem;
                vertical-align: middle;
                border-bottom: 1px solid #f0f2f7;
                color: #1f2f3e;
                font-weight: 500;
            }

        .badge-form {
            background: #eef2ff;
            color: #1f4870;
            border-radius: 40px;
            padding: 4px 12px;
            font-size: 0.7rem;
            font-weight: 600;
            display: inline-block;
        }

        .badge-schedule {
            background: #e6f7ec;
            color: #1f7b4d;
            border-radius: 40px;
            padding: 4px 12px;
            font-size: 0.7rem;
            font-weight: 600;
        }

        .empty-state {
            text-align: center;
            padding: 2.5rem;
            background: #fafcff;
            border-radius: 24px;
        }

            .empty-state i {
                font-size: 3rem;
                color: #b9cded;
            }

        hr.divider-light {
            margin: 1rem 0;
            background: #eef2fa;
            height: 1px;
            opacity: 0.6;
        }

        /* modal modern */
        .modal-content-modern {
            border-radius: 28px;
            border: none;
            box-shadow: 0 25px 45px -12px rgba(0,0,0,0.3);
            overflow: hidden;
        }

        .modal-header-modern {
            background: #1f3b4c;
            color: white;
            padding: 1rem 1.5rem;
            border-bottom: none;
        }

            .modal-header-modern .btn-close {
                filter: brightness(0) invert(1);
            }

        .col-4 {
            margin-bottom: 1rem;
        }

        }
    </style>
</head>
<body>

    <div class="main-container">
        <main role="main">
            <!-- Header -->
            <div class="d-flex flex-wrap justify-content-between align-items-center mb-4">
                <div>
                    <h1 class="page-title"><i class="fas fa-pills me-2" style="color:#1f7b4d;"></i> Chronic Medication</h1>
                    <div class="mt-2">
                        <span class="patient-badge">
                            <i class="fas fa-user-injured me-1"></i> @ViewBag.PatientName @ViewBag.PatientSurname
                        </span>
                        <span class="badge bg-light text-dark ms-2 rounded-pill">
                            <i class="far fa-id-card"></i> Patient ID: @ViewBag.PatientID
                        </span>
                    </div>
                </div>
                <div class="mt-2 mt-sm-0">
                    <a href="@Url.Action("AdmittedPatients", "Nurse")" class="btn btn-light rounded-pill shadow-sm px-4 py-2">
                        <i class="fas fa-arrow-left me-2"></i>Back to Admissions
                    </a>
                </div>
            </div>

            <!-- Add Medication Card -->
            <div class="modern-card mb-4">
                <div class="card-header-custom">
                    <div class="d-flex align-items-center gap-2">
                        <i class="fas fa-plus-circle fs-5" style="color:#1f7b4d;"></i>
                        <h5 class="fw-bold mb-0" style="color:#1f2f3e;">Add Chronic Medication</h5>
                    </div>
                    <p class="text-muted small mt-1 mb-0">Search and select from the formulary to prescribe maintenance medication</p>
                </div>
                <div class="card-body-custom">
                    <form id="AddChronicMedicationForm" method="post" asp-action="AddChronicMedication" asp-controller="Nurse">
                        <div class="row g-4 align-items-end">
                            <!-- Search field -->
                            <div class="col-md-5">
                                <label class="form-label-modern"><i class="fas fa-search me-1"></i> SEARCH MEDICATION</label>
                                <div class="search-input-icon">
                                    <i class="fas fa-capsules"></i>
                                    <input id="searchChronicMedicationInput"
                                           class="form-control"
                                           type="search"
                                           placeholder="Type to filter medications..."
                                           onkeyup="filterChronicMedicationNames()">
                                </div>
                            </div>

                            <!-- Dropdown -->
                            <div class="col-md-5">
                                <label class="form-label-modern"><i class="fas fa-list-ul me-1"></i> SELECT MEDICATION</label>
                                <select class="form-select nice-select"
                                        id="CMedicationID"
                                        name="CMedicationID"
                                        required>
                                    <option value="">-- Choose chronic medication --</option>
                                    @foreach (var med in Model.AllChronicMedication)
                                    {
                                        <option value="@med.CMedicationID" data-search="@med.CMedicationName.ToLower()">
                                            @med.CMedicationName (@med.CMedicationForm)
                                        </option>
                                    }
                                </select>
                            </div>

                            <!-- Button -->
                            <div class="col-md-2">
                                <input type="hidden" name="PatientID" value="@ViewBag.PatientID" />
                                <button type="button" id="openTreatmentButton" class="btn btn-primary-soft w-100">
                                    <i class="fas fa-plus me-2"></i>Add
                                </button>
                            </div>
                        </div>
                    </form>
                </div>
            </div>

            <!-- Current Medications Card -->
            <div class="modern-card">
                <div class="card-header-custom">
                    <div class="d-flex justify-content-between align-items-center">
                        <div>
                            <i class="fas fa-clipboard-list me-2" style="color:#1f7b4d;"></i>
                            <strong>Current Prescriptions</strong>
                        </div>
                        <span class="badge bg-light text-dark rounded-pill px-3 py-2">
                            <i class="fas fa-prescription"></i> @Model.PatientMedicationlist.Count medications
                        </span>
                    </div>
                </div>
                <div class="card-body-custom">
                    @if (Model.PatientMedicationlist.Any())
                    {
                        <div class="data-table-wrapper">
                            <table id="medTable" class="table table-medication">
                                <thead>
                                    <tr>
                                        <th>Patient Name</th>
                                        <th>Surname</th>
                                        <th>Medication</th>
                                        <th>Form</th>
                                        <th>Schedule</th>
                                        <th style="width: 100px;">Action</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach (var item in Model.PatientMedicationlist)
                                    {
                                        <tr>
                                            <td><span class="fw-semibold">@item.Name</span></td>
                                            <td>@item.Surname</td>
                                            <td><i class="fas fa-capsules me-1 text-muted"></i> @item.CMedicationName</td>
                                            <td><span class="badge-form">@item.CMedicationForm</span></td>
                                            <td><span class="badge-schedule"><i class="far fa-clock me-1"></i> @item.Schedule</span></td>
                                            <td>
                                                <form asp-action="DeletePatientMedication" asp-controller="Nurse" method="post" onsubmit="return confirm('Permanently remove this medication?');">
                                                    <input type="hidden" name="patientConditionsID" value="@item.patientConditionsID" />
                                                    <input type="hidden" name="patientID" value="@item.PatientID" />
                                                    <button type="submit" class="btn btn-outline-remove">
                                                        <i class="fas fa-trash-alt me-1"></i> Remove
                                                    </button>
                                                </form>
                                            </td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>
                    }
                    else
                    {
                        <div class="empty-state">
                            <i class="fas fa-prescription-bottle"></i>
                            <p class="mt-2 mb-0 text-secondary">No chronic medications prescribed for this patient.</p>
                            <small class="text-muted">Use the form above to add maintenance medication.</small>
                        </div>
                    }

                    <hr class="divider-light">
                    <div class="d-flex justify-content-end">
                        <a class="btn btn-save" asp-controller="Nurse" asp-action="AdmittedPatients">
                            <i class="fas fa-check-circle me-2"></i> Save & Continue
                        </a>
                    </div>
                </div>
            </div>
        </main>
    </div>

    <!-- Confirm Add Modal -->
    <div class="modal fade" id="confirmTreatmentModal" tabindex="-1" data-bs-backdrop="static">
        <div class="modal-dialog modal-dialog-centered">
            <div class="modal-content modal-content-modern">
                <div class="modal-header modal-header-modern">
                    <h5 class="modal-title fw-bold"><i class="fas fa-question-circle me-2"></i>Confirm Addition</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                </div>
                <div class="modal-body p-4">
                    <div class="d-flex align-items-center">
                        <i class="fas fa-pills me-3 fs-1" style="color:#1f7b4d;"></i>
                        <span>Are you sure you want to add this chronic medication to the patient's record?</span>
                    </div>
                </div>
                <div class="modal-footer border-0 pt-0 pb-4 pe-4">
                    <button type="button" id="saveTreatmentButton" class="btn btn-primary rounded-pill px-4" style="background:#1f7b4d;">Yes, Add</button>
                    <button type="button" class="btn btn-outline-secondary rounded-pill px-4" data-bs-dismiss="modal">Cancel</button>
                </div>
            </div>
        </div>
    </div>

    <script>
        $(document).ready(function () {
            // Initialize DataTable with clean styling
            $('#medTable').DataTable({
                "pageLength": 8,
                "lengthMenu": [[5, 8, 15, 25], [5, 8, 15, 25]],
                "language": {
                    "zeroRecords": "No medications found",
                    "info": "Showing _START_ to _END_ of _TOTAL_ entries",
                    "search": "Filter:"
                },
                "order": [[0, 'asc']]
            });
        });

        // Open confirmation modal
        $('#openTreatmentButton').click(function () {
            var selectedMed = $('#CMedicationID option:selected').text();
            if (!$('#CMedicationID').val()) {
                alert("Please select a medication before adding.");
                return;
            }
            $('#confirmTreatmentModal').modal('show');
        });

        // AJAX submit via modal confirmation
        $('#saveTreatmentButton').click(function () {
            $.ajax({
                url: '@Url.Action("AddChronicMedication", "Nurse")',
                type: 'POST',
                data: $('#AddChronicMedicationForm').serialize(),
                success: function (response) {
                    location.reload();
                },
                error: function (xhr, status, error) {
                    console.log("Add error:", error);
                    alert("An error occurred while adding medication. Please try again.");
                    $('#confirmTreatmentModal').modal('hide');
                }
            });
        });

        // Enhanced filter dropdown with search
        function filterChronicMedicationNames() {
            var input = $('#searchChronicMedicationInput').val().toLowerCase().trim();
            $('#CMedicationID option').each(function () {
                var text = $(this).text().toLowerCase();
                if ($(this).val() === "") {
                    $(this).toggle(true);
                    return;
                }
                if (text.includes(input)) {
                    $(this).show();
                } else {
                    $(this).hide();
                }
            });

            // If selected option becomes hidden, reset selection
            if ($('#CMedicationID option:selected').val() !== "" && $('#CMedicationID option:selected').is(':hidden')) {
                $('#CMedicationID').val('');
            }
        }
    </script>

</body>
</html>