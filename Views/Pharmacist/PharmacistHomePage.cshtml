@model DEMO.ViewModels.HomeViewModel
@{
    ViewData["Title"] = "Pharmacist Home";
    Layout = "_LayoutPharmacist";
}

<div class="container mt-4">

    <!-- Top Cards Section -->
    <div class="row g-3">
        <!-- Patients Card -->
        <div class="col-md-4">
            <div class="card h-100 shadow-sm text-white top-card" style="background: linear-gradient(135deg, #4e73df, #1cc88a); transform: scale(0.95); transition: transform 0.3s;">
                <img src="~/css/DnP.jpeg" class="card-img-top" alt="Doctor Patient">
                <div class="card-body text-center">
                    <h5 class="card-title">Patients</h5>
                    <p class="card-text">View patients & book surgeries.</p>
                    <a class="btn btn-light w-100 mt-2" asp-controller="Home" asp-action="PatientList">View Patients</a>
                </div>
            </div>
        </div>

        <!-- Prescriptions Card -->
        <div class="col-md-4">
            <div class="card h-100 shadow-sm text-white top-card" style="background: linear-gradient(135deg, #36b9cc, #f6c23e); transform: scale(0.95); transition: transform 0.3s;">
                <img src="~/css/DP.jpeg" class="card-img-top" alt="Doctor Prescription">
                <div class="card-body text-center">
                    <h5 class="card-title">Prescriptions</h5>
                    <p class="card-text">Track your prescriptions.</p>
                    <a class="btn btn-light w-100 mt-2" asp-controller="Home" asp-action="PrescriptionList">View Prescriptions</a>
                </div>
            </div>
        </div>

        <!-- Admissions Card -->
        <div class="col-md-4">
            <div class="card h-100 shadow-sm text-white top-card" style="background: linear-gradient(135deg, #e74a3b, #858796); transform: scale(0.95); transition: transform 0.3s;">
                <img src="~/css/HB.jpeg" class="card-img-top" alt="Hospital Bed">
                <div class="card-body text-center">
                    <h5 class="card-title">Admissions</h5>
                    <p class="card-text">Current admissions & vitals.</p>
                    <a class="btn btn-light w-100 mt-2" asp-controller="Home" asp-action="patientAddmision">View Admissions</a>
                </div>
            </div>
        </div>
    </div>
   
    <!-- Prescriptions Table -->
    <div class="row mt-4">
        <div class="col-12">
            <div class="table-responsive p-3 border bg-white shadow-sm">
                <h3 class="section-title text-center">Prescriptions List</h3>
                <input class="form-control mb-2" id="searchSurgery" placeholder="Search..." />
                <table class="table table-striped table-hover table-bordered" id="surgeryTable">
                    <thead class="table-dark">
                        <tr>
                            <th>Name</th>
                            <th>Surname</th>
                            <th>Surgeon</th>
                            <th>Date</th>
                            <th>Time</th>
                            <th>Theatre</th>
                        </tr>
                    </thead>
                    <tbody>
                       @*  @foreach (var Data in Model.AllSurgeryData)
                        {
                            <tr>
                                <td>@Data.Name</td>
                                <td>@Data.Surname</td>
                                <td>@ViewBag.UserName @ViewBag.UserSurname</td>
                                <td>@Data.SurgeryDate.ToShortDateString()</td>
                                <td>@Data.SurgeryTime</td>
                                <td>@Data.Theater</td>
                            </tr>
                        } *@
                    </tbody>
                </table>
            </div>
        </div>
    </div>

</div>
