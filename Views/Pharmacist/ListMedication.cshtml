    }

        .action-icon.view-ingredients-btn {
            background: #eef2ff;
            color: #4f46e5;
        }

            .action-icon.view-ingredients-btn:hover {
                background: #4f46e5;
                color: white;
            }

        .action-icon.restock-btn {
            background: #fef3e2;
            color: #d97706;
        }

            .action-icon.restock-btn:hover {
                background: #d97706;
                color: white;
            }

        .action-icon.delete-medication-btn {
            background: #ffe3e0;
            color: #dc2626;
        }

            .action-icon.delete-medication-btn:hover {
                background: #dc2626;
                color: white;
            }

    /* Stock Badges */
    .stock-badge {
        padding: 4px 10px;
        border-radius: 40px;
        font-size: 12px;
        font-weight: 500;
        display: inline-block;
    }

        .stock-badge.normal {
            background: #e0f5ed;
            color: #059669;
        }

        .stock-badge.low {
            background: #ffe3e0;
            color: #dc2626;
        }

    .med-name {
        font-weight: 600;
        color: #2d2a2a;
    }

    /* Form Actions */
    .form-actions {
        padding: 20px 24px;
        background: #fefaf9;
        text-align: center;
    }

    .btn-submit {
        padding: 12px 32px;
        background: linear-gradient(135deg, #c5283d, #e25c3c);
        color: white;
        border: none;
        border-radius: 40px;
        font-size: 14px;
        font-weight: 600;
        cursor: pointer;
        transition: all 0.2s;
        display: inline-flex;
        align-items: center;
        gap: 8px;
    }

        .btn-submit:hover {
            transform: translateY(-2px);
            box-shadow: 0 6px 20px rgba(197,40,61,0.3);
        }

    /* Table Card */
    .table-card {
        background: white;
        border-radius: 20px;
        overflow: hidden;
        box-shadow: 0 2px 8px rgba(0,0,0,0.04);
        border: 1px solid #f0e2df;
    }

    .table-header {
        display: flex;
        justify-content: space-between;
        align-items: center;
        padding: 18px 24px;
        border-bottom: 1px solid #f0e2df;
        background: #fefaf9;
        flex-wrap: wrap;
        gap: 16px;
    }

        .table-header h3 {
            font-size: 16px;
            font-weight: 600;
            color: #2d2a2a;
            margin: 0;
        }

    .search-wrapper-small {
        position: relative;
    }

        .search-wrapper-small i {
            position: absolute;
            left: 12px;
            top: 50%;
            transform: translateY(-50%);
            color: #c97a6b;
            font-size: 14px;
        }

        .search-wrapper-small input {
            padding: 8px 12px 8px 36px;
            border: 1px solid #f0dbd6;
            border-radius: 40px;
            font-size: 13px;
            background: white;
            width: 250px;
        }

            .search-wrapper-small input:focus {
                outline: none;
                border-color: #e25c3c;
                box-shadow: 0 0 0 2px rgba(226,92,60,0.1);
            }

    /* Modal Styles */
    .modal-header {
        background: linear-gradient(135deg, #c5283d, #e25c3c);
        padding: 16px 24px;
        border: none;
    }

    .modal-title {
        color: white;
        font-size: 18px;
        font-weight: 600;
        margin: 0;
    }

    .modal-subtitle {
        color: rgba(255,255,255,0.8);
        font-size: 12px;
        margin: 4px 0 0;
    }

    .close-btn {
        background: rgba(255,255,255,0.2);
        border: none;
        width: 32px;
        height: 32px;
        border-radius: 50%;
        color: white;
        cursor: pointer;
        transition: all 0.2s;
    }

        .close-btn:hover {
            background: rgba(255,255,255,0.3);
            transform: rotate(90deg);
        }

    .modal-footer {
        padding: 16px 24px;
        border-top: 1px solid #f0e2df;
