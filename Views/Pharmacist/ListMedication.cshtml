        }

    .loading-spinner {
        text-align: center;
        padding: 40px;
    }

    .spin {
        animation: spin 1s linear infinite;
        display: inline-block;
    }

  

    /* Delete Row Button */
    .deleteRow {
        background: #dc2626;
        color: white;
        border: none;
        padding: 4px 12px;
        border-radius: 6px;
        cursor: pointer;
        font-size: 12px;
    }

        .deleteRow:hover {
            background: #b91c1c;
        }

  

    .form-row {
        grid-template-columns: 1fr;
    }

    .selector-row {
        flex-direction: column;
    }

        .selector-row .btn-add {
            width: 100%;
        }

    .table-header {
        flex-direction: column;
        align-items: stretch;
    }

    .search-wrapper-small input {
        width: 100%;
    }

    }
</style>

<script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>
<script src="https://cdn.datatables.net/1.11.5/js/jquery.dataTables.min.js"></script>
<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.1.3/dist/js/bootstrap.bundle.min.js"></script>

<script>
    let ingredientsList = [];

    $(document).ready(function() {
        // Initialize DataTable
        var table = $('#medicationTable').DataTable({
            pageLength: 10,
            info: false,
            lengthChange: false,
            searching: false,
            ordering: true,
            language: {
                zeroRecords: "<div class='text-center py-4'><i class='bi bi-inbox' style='font-size: 24px; color: #c97a6b;'></i><p class='mt-2 text-muted'>No medications found</p></div>",
                paginate: {
                    previous: "<i class='bi bi-chevron-left'></i>",
                    next: "<i class='bi bi-chevron-right'></i>"
                }
            },
            dom: '<"table-responsive"t><"pagination-wrapper"p>'
        });

        // Custom search
        $('#tableSearch').on('keyup', function() {
            table.search(this.value).draw();
        });

        // Add ingredient row
        $('#addRow').click(function() {
            let id = $('#activeIngredient').val();
            let text = $('#activeIngredient option:selected').text();

            if (id) {
                ingredientsList.push({
                    ActiveingredientID: parseInt(id),
                    ActiveIngredientStrength: 1
                });

                $('#dynamicTable tbody').append(`
                    <tr>
                        <td>${text}</td>
                        <td><button class="deleteRow"><i class="bi bi-trash"></i> Delete</button></td>
                    </tr>
                `);
                $('#activeIngredient').val('');
            }
        });

        // Delete ingredient row
        $('#dynamicTable').on('click', '.deleteRow', function() {
            let index = $(this).closest('tr').index();
            ingredientsList.splice(index, 1);
            $(this).closest('tr').remove();
        });

        // Open confirm modal
        $('#openMedicationButton').click(function() {
            if (!$('input[name="medicationName"]').val()) {
                alert('Please enter medication name');
                return;
            }
            var modal = new bootstrap.Modal(document.getElementById('confirmMedicationModal'));
            modal.show();
        });

        // Save medication
        $('#saveMedicationButton').click(function() {
            let data = {
                MedicationName: $('input[name="medicationName"]').val(),
                MedicationForm: $('select[name="medicationForm"]').val(),
                Schedule: parseInt($('select[name="schedule"]').val()),
                StockonHand: parseInt($('input[name="Stockonhand"]').val()),
                ReorderLevel: parseInt($('input[name="Re-orderlevel"]').val()),
                Ingredients: ingredientsList
            };

            $.ajax({
                url: '/Pharmacist/AddMedication',
                type: 'POST',
                contentType: 'application/json',
                data: JSON.stringify(data),
                success: function() {
                    alert("Medication added successfully!");
                    location.reload();
                },
                error: function(err) {
                    console.log(err);
                    alert("Error adding medication");
                }
            });
        });

        // Restock functionality
        let restockMedicationId = null;

        $(document).on('click', '.restock-btn', function() {
            restockMedicationId = $(this).data('medication-id');
            let medName = $(this).data('medication-name');
            $('#restockMedId').val(restockMedicationId);
            $('#restockMedName').text(medName);
            let now = new Date().toISOString().slice(0, 16);
            $('#restockDateTime').val(now);
            var modal = new bootstrap.Modal(document.getElementById('restockModal'));
            modal.show();
        });

        $('#saveRestockBtn').click(function() {
            let data = {
                MedicationID: parseInt($('#restockMedId').val()),
                Amount: parseInt($('#restockAmount').val()),
                OrderDate: new Date($('#restockDateTime').val()).toISOString(),
                AccountID: 1
            };

            if (!data.Amount || data.Amount <= 0) {
                alert("Please enter a valid amount.");
                return;
            }

            $.ajax({
                url: '/Pharmacist/OrderStock',
                type: 'POST',
                contentType: 'application/json',
                data: JSON.stringify(data),
                success: function(response) {
                    if (response.success) {
                        bootstrap.Modal.getInstance(document.getElementById('restockModal')).hide();
                        if (response.redirectUrl) {
                            window.location.href = response.redirectUrl;
                        } else {
                            alert("Stock ordered successfully!");
                            location.reload();
                        }
                    } else {
                        alert(response.message);
                    }
                },
                error: function() {
                    alert("Error placing stock order.");
                }
            });
        });

        // View ingredients
        $(document).on('click', '.view-ingredients-btn', function() {
            let medId = $(this).data('medication-id');
            let medName = $(this).data('medication-name');

            $('#modalMedName').text(medName);
            $('#ingredientModalBody').empty();
            $('#ingredientLoadingMsg').show();

            $.ajax({
                url: '/Pharmacist/GetMedicationIngredients',
                type: 'GET',
                data: { medicationId: medId },
                success: function(data) {
                    $('#ingredientLoadingMsg').hide();
                    if (data.length === 0) {
                        $('#ingredientModalBody').append('<tr><td colspan="3" class="text-center text-muted">No ingredients found</td></tr>');
                    } else {
                        data.forEach(function(item) {
                            $('#ingredientModalBody').append(`
                                <tr>
                                    <td>${item.medicationName}</td>
                                    <td>${item.activeIngredientName}</td>
                                    <td>${item.activeIngredientStrength}</td>
                                </tr>
                            `);
                        });
                    }
                    var modal = new bootstrap.Modal(document.getElementById('activeIngredientModal'));
                    modal.show();
                },
                error: function() {
                    $('#ingredientLoadingMsg').hide();
                    $('#ingredientModalBody').append('<tr><td colspan="3" class="text-danger text-center">Failed to load ingredients</td></tr>');
                    var modal = new bootstrap.Modal(document.getElementById('activeIngredientModal'));
                    modal.show();
                }
            });
        });

        // Delete medication
        let medicationToDeleteId = null;

        $(document).on('click', '.delete-medication-btn', function() {
            medicationToDeleteId = $(this).data('medication-id');
            let medName = $(this).data('medication-name');
            $('#deleteMedName').text(medName);
            var modal = new bootstrap.Modal(document.getElementById('deleteMedicationModal'));
            modal.show();
        });

        $('#confirmDeleteBtn').click(function() {
            if (!medicationToDeleteId) return;
            $.ajax({
                url: '/Pharmacist/DeleteMedication',
                type: 'POST',
                contentType: 'application/json',
                data: JSON.stringify(medicationToDeleteId),
                success: function(response) {
                    if (response.success) {
                        bootstrap.Modal.getInstance(document.getElementById('deleteMedicationModal')).hide();
                        alert('Medication deleted successfully.');
                        location.reload();
                    } else {
                        alert('Error: ' + response.message);
                    }
                },
                error: function() {
                    alert('An error occurred while deleting the medication.');
                }
            });
        });
    });
</script>