    .confirm-btn {
        background: linear-gradient(135deg, #c5283d, #e25c3c);
        color: white;
    }

        .confirm-btn:hover {
            transform: translateY(-1px);
            box-shadow: 0 4px 12px rgba(197,40,61,0.3);
        }

    .delete-btn {
        background: #dc2626;
        color: white;
    }

        .delete-btn:hover {
            background: #b91c1c;
        }

    .secondary-btn {
        background: #f0e2df;
        color: #5a4a47;
    }

        .secondary-btn:hover {
