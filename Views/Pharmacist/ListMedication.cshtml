@{
    ViewData["Title"] = "Medication";
    Layout = "_LayoutPharmacist";
}
@model DEMO.ViewModels.MedicationWithIngredientsViewModel

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">

    <!-- jQuery -->
    <script src="https://code.jquery.com/jquery-3.5.1.js"></script>

    <!-- DataTables -->
    <link rel="stylesheet" href="https://cdn.datatables.net/1.11.5/css/jquery.dataTables.css">
    <script src="https://cdn.datatables.net/1.11.5/js/jquery.dataTables.js"></script>

    <!-- Bootstrap -->
    <link rel="stylesheet" href="https://stackpath.bootstrapcdn.com/bootstrap/5.1.3/css/bootstrap.min.css">
    <script src="https://stackpath.bootstrapcdn.com/bootstrap/5.1.3/js/bootstrap.bundle.min.js"></script>

    <title>Medication Add</title>
</head>

<body>
    <div class="container mt-4">

        <!-- ================= ADD MEDICATION ================= -->
        <div class="card shadow-sm p-4">
            <form id="addMedicationForm" method="post" action="@Url.Action("AddMedication", "Admin")">

                <h3 class="mb-4">Medication Page</h3>

                <!-- Medication Section -->
                <h5>Medication Details</h5>
                <div class="row g-3 mb-4">
                    <div class="col-md-4">
                        <label for="medicationName" class="form-label">Medication Name</label>
                        <input type="text" class="form-control" name="medicationName" placeholder="Enter Medication Name" style="width:300px">
                    </div>

                    <div class="col-md-4">
                        <label class="form-label">Medication Form</label>
                        <select class="form-control" name="medicationForm" style="width:300px">
                            <option value="">Select Medication Form</option>
                            <option>Capsules</option>
                            <option>Drops</option>
                            <option>Gel</option>
                            <option>Injectable</option>
                            <option>IV Drip</option>
                            <option>Lotion</option>
                            <option>Spray</option>
                            <option>Suppository</option>
                            <option>Suspension</option>
                            <option>Syrup</option>
                            <option>Tablets</option>
                        </select>
                    </div>

                    <div class="col-md-4">
                        <label class="form-label">Schedule</label>
                        <select class="form-control" name="schedule" style="width:300px">
                            <option value="">Select Schedule</option>
                            <option value="0">Schedule 0</option>
                            <option value="1">Schedule 1</option>
                            <option value="2">Schedule 2</option>
                            <option value="3">Schedule 3</option>
                            <option value="4">Schedule 4</option>
                            <option value="5">Schedule 5</option>
                            <option value="6">Schedule 6</option>
                        </select>
                    </div>
                </div>

                <div class="row g-3 mb-4">
                    <div class="col-md-4">
                        <label for="Re-orderlevel" class="form-label">Re-order level</label>
                        <input type="text" class="form-control" name="Re-orderlevel" placeholder="Enter Re-order level" style="width:300px">
                    </div>
                    <div class="col-md-4">
                        <label for="Stockonhand" class="form-label"> Stock on hand</label>
                        <input type="text" class="form-control" name="Stockonhand" placeholder="Enter Stock on hand" style="width:300px">
                    </div>
                </div>

                <!-- Active Ingredient Section -->
                <h5>Active Ingredient</h5>
                <div class="row g-3 align-items-end mb-3">
                    <div class="col-md-6">
                        <label class="form-label">Active Ingredient</label>
                        <select class="form-control" id="activeIngredient" style="width:300px">
                            <option value="">Select Active ingredient</option>
                            @foreach (var ingredient in Model.ActiveIngredients)
                            {
                                <option value="@ingredient.ActiveingredientID">
                                    @ingredient.ActiveIngredientName
                                </option>
                            }
                        </select>
                    </div>

                    <div class="col-md-6">
                        <button type="button" id="addRow" class="btn btn-primary w-100">
                            Add Ingredient
                        </button>
                    </div>
                </div>

                <!-- Dynamic Table -->
                <table class="table table-bordered" id="dynamicTable">
                    <thead class="table-light">
                        <tr>
                            <th>Active Ingredient</th>
                            <th width="120">Actions</th>
                        </tr>
                    </thead>
                    <tbody></tbody>
                </table>

                <!-- Submit -->
                <div class="text-center mt-4">
                    <button type="button" id="openMedicationButton" class="btn btn-success px-5">
                        Add Medication
                    </button>
                </div>

            </form>
        </div>

        <!-- ================= MEDICATION LIST ================= -->
        <div class="card shadow-sm p-4 mt-5">
            <table id="medicationTable" class="table table-striped">
                <thead>
                    <tr>
                        <th>Medication Name</th>
                        <th>Medication Form</th>
                        <th>Schedule</th>
                        <th>StockonHand</th>
                        <th>ReorderLevel</th>
                        <th>Action</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var Medication in Model.AllMedication)
                    {
                        <tr>
                            <td>@Medication.MedicationName</td>
                            <td>@Medication.MedicationForm</td>
                            <td>@Medication.Schedule</td>
                            <td>@Medication.StockonHand</td>
                            <td>@Medication.ReorderLevel</td>
                            <td>
                                <button class="btn btn-primary btn-sm view-ingredients-btn"
                                        data-medication-id="@Medication.MedicationID"
                                        data-medication-name="@Medication.MedicationName">
                                    View Active Ingredient
                                </button>
                                <button class="btn btn-warning btn-sm restock-btn"
                                        data-medication-id="@Medication.MedicationID"
                                        data-medication-name="@Medication.MedicationName">
                                    Re-Stock Medication
                                </button>
                                <button class="btn btn-danger btn-sm delete-medication-btn"
                                        data-medication-id="@Medication.MedicationID"
                                        data-medication-name="@Medication.MedicationName">
                                    Delete Medication
                                </button>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>

    </div>

    <!-- ================= MODALS ================= -->
    <!-- Confirm Medication -->
    <div class="modal fade" id="confirmMedicationModal">
        <div class="modal-dialog modal-dialog-centered">
            <div class="modal-content">
                <div class="modal-header">
                    <h5>Confirm Save</h5>
                    <button class="btn-close" data-bs-dismiss="modal"></button>
                </div>
                <div class="modal-body">
                    Add this medication?
                </div>
                <div class="modal-footer">
                    <button id="saveMedicationButton" class="btn btn-primary">Yes</button>
                    <button class="btn btn-secondary" data-bs-dismiss="modal">No</button>
                </div>
            </div>
        </div>
    </div>
    <!-- Delete Medication Modal -->
    <div class="modal fade" id="deleteMedicationModal">
        <div class="modal-dialog modal-dialog-centered">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title">Confirm Delete</h5>
                    <button class="btn-close" data-bs-dismiss="modal"></button>
                </div>
                <div class="modal-body">
                    Are you sure you want to delete <strong id="deleteMedName"></strong>?
                    This action cannot be undone.
                </div>
                <div class="modal-footer">
                    <button id="confirmDeleteBtn" class="btn btn-danger">Yes, Delete</button>
                    <button class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                </div>
            </div>
        </div>
    </div>
    <!-- ================= RE-STOCK MODAL ================= -->
    <div class="modal fade" id="restockModal">
        <div class="modal-dialog modal-dialog-centered">
            <div class="modal-content">

                <div class="modal-header">
                    <h5 class="modal-title">
                        Re-Stock Medication — <span id="restockMedName"></span>
                    </h5>
                    <button class="btn-close" data-bs-dismiss="modal"></button>
                </div>

                <div class="modal-body">

                    <input type="hidden" id="restockMedId" />

                    <div class="mb-3">
                        <label class="form-label">Amount</label>
                        <input type="number" id="restockAmount" class="form-control" placeholder="Enter amount" style="width:300px">
                    </div>

                    <div class="mb-3">
                        <label class="form-label">Order Date & Time</label>
                        <input type="datetime-local" id="restockDateTime" class="form-control" style="width:300px">
                    </div>

                </div>

                <div class="modal-footer">
                    <button id="saveRestockBtn" class="btn btn-success">Save</button>
                    <button class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                </div>

            </div>
        </div>
    </div>
    <!-- Active Ingredient Modal -->
    <div class="modal fade" id="activeIngredientModal">
        <div class="modal-dialog modal-lg modal-dialog-centered">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title">Active Ingredients — <span id="modalMedName"></span></h5>
                    <button class="btn-close" data-bs-dismiss="modal"></button>
                </div>
                <div class="modal-body">
                    <div id="ingredientLoadingMsg" class="text-center text-muted py-3" style="display:none;">
                        Loading...
                    </div>
                    <table class="table table-bordered" id="ingredientModalTable">
                        <thead>
                            <tr>
                                <th>Medication</th>
                                <th>Ingredient</th>
                                <th>Strength</th>
                            </tr>
                        </thead>
                        <tbody id="ingredientModalBody">
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>

    <!-- ================= SCRIPTS ================= -->
    <script>
        let ingredientsList = [];

        $(document).ready(function () {

            // ================= RE-STOCK FUNCTION =================

            let restockMedicationId = null;

            // OPEN MODAL
            $(document).on('click', '.restock-btn', function () {

                restockMedicationId = $(this).data('medication-id');
                let medName = $(this).data('medication-name');

                $('#restockMedId').val(restockMedicationId);
                $('#restockMedName').text(medName);

                let now = new Date().toISOString().slice(0, 16);
                $('#restockDateTime').val(now);

                var modal = new bootstrap.Modal(document.getElementById('restockModal'));
                modal.show();
            });

            // SAVE RE-STOCK (ONLY ONE HANDLER ✅)
            $('#saveRestockBtn').click(function () {

                let data = {
                    MedicationID: parseInt($('#restockMedId').val()),
                    Amount: parseInt($('#restockAmount').val()),
                    OrderDate: new Date($('#restockDateTime').val()).toISOString(),
                    AccountID: 1
                };

                if (!data.Amount || data.Amount <= 0) {
                    alert("Please enter a valid amount.");
                    return;
                }

                $.ajax({
                    url: '/Pharmacist/OrderStock',
                    type: 'POST',
                    contentType: 'application/json',
                    data: JSON.stringify(data),

                    success: function (response) {
                        if (response.success) {

                            bootstrap.Modal.getInstance(
                                document.getElementById('restockModal')
                            ).hide();
        if (response.redirectUrl) {
                    window.location.href = response.redirectUrl;
                } else {
                    alert("Stock ordered successfully!");
                    location.reload();
                }

                        } else {
                            alert(response.message);
                        }
                    },

                    error: function () {
                        alert("Error placing stock order.");
                    }
                });
            });

            // ================= VIEW INGREDIENTS =================

            $(document).on('click', '.view-ingredients-btn', function () {
                let medId = $(this).data('medication-id');
                let medName = $(this).data('medication-name');

                $('#modalMedName').text(medName);
                $('#ingredientModalBody').empty();
                $('#ingredientLoadingMsg').show();

                $.ajax({
                    url: '/Pharmacist/GetMedicationIngredients',
                    type: 'GET',
                    data: { medicationId: medId },

                    success: function (data) {
                        $('#ingredientLoadingMsg').hide();

                        if (data.length === 0) {
                            $('#ingredientModalBody').append(
                                '<tr><td colspan="3" class="text-center text-muted">No ingredients found.</td></tr>'
                            );
                        } else {
                            data.forEach(function (item) {
                                $('#ingredientModalBody').append(`
                                    <tr>
                                        <td>${item.medicationName}</td>
                                        <td>${item.activeIngredientName}</td>
                                        <td>${item.activeIngredientStrength}</td>
                                    </tr>
                                `);
                            });
                        }

                        var modal = new bootstrap.Modal(document.getElementById('activeIngredientModal'));
                        modal.show();
                    },

                    error: function () {
                        $('#ingredientLoadingMsg').hide();
                        $('#ingredientModalBody').append(
                            '<tr><td colspan="3" class="text-danger text-center">Failed to load ingredients.</td></tr>'
                        );

                        var modal = new bootstrap.Modal(document.getElementById('activeIngredientModal'));
                        modal.show();
                    }
                });
            });

            // ================= DATATABLE =================
            $('#medicationTable').DataTable();

            // ================= DELETE =================

            let medicationToDeleteId = null;

            $(document).on('click', '.delete-medication-btn', function () {
                medicationToDeleteId = $(this).data('medication-id');
                let medName = $(this).data('medication-name');

                $('#deleteMedName').text(medName);

                var modal = new bootstrap.Modal(document.getElementById('deleteMedicationModal'));
                modal.show();
            });

            $('#confirmDeleteBtn').click(function () {
                if (!medicationToDeleteId) return;

                $.ajax({
                    url: '/Pharmacist/DeleteMedication',
                    type: 'POST',
                    contentType: 'application/json',
                    data: JSON.stringify(medicationToDeleteId),

                    success: function (response) {
                        if (response.success) {
                            bootstrap.Modal.getInstance(
                                document.getElementById('deleteMedicationModal')
                            ).hide();

                            alert('Medication deleted successfully.');
                            location.reload();
                        } else {
                            alert('Error: ' + response.message);
                        }
                    },

                    error: function () {
                        alert('An error occurred while deleting the medication.');
                    }
                });
            });

            // ================= ADD INGREDIENT =================

            $('#addRow').click(function () {

                let id = $('#activeIngredient').val();
                let text = $('#activeIngredient option:selected').text();

                if (id) {

                    ingredientsList.push({
                        ActiveingredientID: parseInt(id),
                        ActiveIngredientStrength: 1
                    });

                    $('#dynamicTable tbody').append(`
                        <tr>
                            <td>${text}</td>
                            <td><button class="deleteRow btn btn-danger btn-sm">Delete</button></td>
                        </tr>
                    `);
                }
            });

            $('#dynamicTable').on('click', '.deleteRow', function () {
                let index = $(this).closest('tr').index();
                ingredientsList.splice(index, 1);
                $(this).closest('tr').remove();
            });

            // ================= ADD MEDICATION =================

            $('#saveMedicationButton').click(function () {

                let data = {
                    MedicationName: $('input[name="medicationName"]').val(),
                    MedicationForm: $('select[name="medicationForm"]').val(),
                    Schedule: parseInt($('select[name="schedule"]').val()),
                    StockonHand: parseInt($('input[name="Stockonhand"]').val()),
                    ReorderLevel: parseInt($('input[name="Re-orderlevel"]').val()),
                    Ingredients: ingredientsList
                };

                $.ajax({
                    url: '/Pharmacist/AddMedication',
                    type: 'POST',
                    contentType: 'application/json',
                    data: JSON.stringify(data),

                    success: function () {
                        alert("Saved!");
                        location.reload();
                    },

                    error: function (err) {
                        console.log(err);
                    }
                });
            });

        });
    </script>
</body>
</html>