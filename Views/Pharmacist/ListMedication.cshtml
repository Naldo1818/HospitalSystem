@{
    ViewData["Title"] = "Medication";
    Layout = "_LayoutPharmacist";
}
@model DEMO.ViewModels.MedicationWithIngredientsViewModel

<div class="pharmacy-container">
    <!-- Page Header -->
    <div class="page-header">
        <div>
            <h1 class="page-title">
                <i class="bi bi-capsule me-2"></i>Medication Management
            </h1>
            <p class="page-subtitle">Add, manage, and track medication inventory</p>
        </div>
        <div class="header-stats">
            <div class="stat-badge total">
                <i class="bi bi-grid-3x3-gap-fill"></i>
                <span>Total: @Model.AllMedication?.Count()</span>
            </div>
            <div class="stat-badge low-stock">
                <i class="bi bi-exclamation-triangle-fill"></i>
                <span>Low Stock: @Model.AllMedication?.Count(m => m.StockonHand <= m.ReorderLevel)</span>
            </div>
        </div>
    </div>

    <!-- Add Medication Card -->
    <div class="form-card">
        <div class="card-header-custom">
            <i class="bi bi-plus-circle"></i>
            <h3>Add New Medication</h3>
        </div>

        <form id="addMedicationForm">
            <!-- Medication Details -->
            <div class="form-section">
                <h5 class="section-title"><i class="bi bi-info-circle"></i> Medication Details</h5>
                <div class="form-row">
                    <div class="form-group">
                        <label class="form-label">Medication Name</label>
                        <input type="text" class="form-control" name="medicationName" placeholder="Enter medication name">
                    </div>
                    <div class="form-group">
                        <label class="form-label">Medication Form</label>
                        <select class="form-control" name="medicationForm">
                            <option value="">Select form</option>
                            <option>Capsules</option>
                            <option>Drops</option>
                            <option>Gel</option>
                            <option>Injectable</option>
                            <option>IV Drip</option>
                            <option>Lotion</option>
                            <option>Spray</option>
                            <option>Suppository</option>
                            <option>Suspension</option>
                            <option>Syrup</option>
                            <option>Tablets</option>
                        </select>
                    </div>
                    <div class="form-group">
                        <label class="form-label">Schedule</label>
                        <select class="form-control" name="schedule">
                            <option value="">Select schedule</option>
                            <option value="0">Schedule 0</option>
                            <option value="1">Schedule 1</option>
                            <option value="2">Schedule 2</option>
                            <option value="3">Schedule 3</option>
                            <option value="4">Schedule 4</option>
                            <option value="5">Schedule 5</option>
                            <option value="6">Schedule 6</option>
                        </select>
                    </div>
                </div>

                <div class="form-row">
                    <div class="form-group">
                        <label class="form-label">Reorder Level</label>
                        <input type="number" class="form-control" name="Re-orderlevel" placeholder="Minimum stock level">
                    </div>
                    <div class="form-group">
                        <label class="form-label">Stock on Hand</label>
                        <input type="number" class="form-control" name="Stockonhand" placeholder="Current quantity">
                    </div>
                </div>
            </div>

            <!-- Active Ingredients -->
            <div class="form-section">
                <h5 class="section-title"><i class="bi bi-flask"></i> Active Ingredients</h5>
                <div class="ingredient-selector">
                    <div class="selector-row">
                        <select class="form-control" id="activeIngredient">
                            <option value="">Select active ingredient</option>
                            @foreach (var ingredient in Model.ActiveIngredients)
                            {
                                <option value="@ingredient.ActiveingredientID">
                                    @ingredient.ActiveIngredientName
                                </option>
                            }
                        </select>
                        <button type="button" id="addRow" class="btn-add">
                            <i class="bi bi-plus-lg"></i> Add Ingredient
                        </button>
                    </div>
                </div>

                <div class="table-wrapper">
                    <table class="data-table" id="dynamicTable">
                        <thead>
                            <tr>
                                <th>Active Ingredient</th>
                                <th width="100">Actions</th>
                            </tr>
                        </thead>
                        <tbody></tbody>
                    </table>
                </div>
            </div>

            <!-- Submit Button -->
            <div class="form-actions">
                <button type="button" id="openMedicationButton" class="btn-submit">
                    <i class="bi bi-save"></i> Add Medication
                </button>
            </div>
        </form>
    </div>

    <!-- Medication List Card -->
    <div class="table-card">
        <div class="table-header">
            <h3><i class="bi bi-grid-3x3-gap-fill me-2"></i>Medication Inventory</h3>
            <div class="search-wrapper-small">
                <i class="bi bi-search"></i>
                <input type="text" id="tableSearch" placeholder="Search medications...">
            </div>
        </div>
        <div class="table-responsive">
            <table id="medicationTable" class="data-table">
                <thead>
                    <tr>
                        <th><i class="bi bi-capsule"></i> Name</th>
                        <th><i class="bi bi-grid"></i> Form</th>
                        <th><i class="bi bi-calendar"></i> Schedule</th>
                        <th><i class="bi bi-box-seam"></i> Stock</th>
                        <th><i class="bi bi-exclamation-triangle"></i> Reorder</th>
                        <th><i class="bi bi-gear"></i> Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var Medication in Model.AllMedication)
                    {
                        bool isLowStock = Medication.StockonHand <= Medication.ReorderLevel;
                        <tr>
                            <td class="med-name">@Medication.MedicationName</td>
                            <td>@Medication.MedicationForm</td>
                            <td>Schedule @Medication.Schedule</td>
                            <td class="@(isLowStock ? "stock-low" : "stock-normal")">
                                <span class="stock-badge @(isLowStock ? "low" : "normal")">
                                    @Medication.StockonHand units
                                </span>
                            </td>
                            <td>@Medication.ReorderLevel</td>
                            <td>
                                <div class="action-buttons">
                                    <button class="action-icon view-ingredients-btn"
                                            title="View Ingredients"
                                            data-medication-id="@Medication.MedicationID"
                                            data-medication-name="@Medication.MedicationName">
                                        <i class="bi bi-eye"></i>
                                    </button>
                                    <button class="action-icon restock-btn"
                                            title="Re-stock"
                                            data-medication-id="@Medication.MedicationID"
                                            data-medication-name="@Medication.MedicationName">
                                        <i class="bi bi-arrow-repeat"></i>
                                    </button>
                                    <button class="action-icon delete-medication-btn"
                                            title="Delete"
                                            data-medication-id="@Medication.MedicationID"
                                            data-medication-name="@Medication.MedicationName">
                                        <i class="bi bi-trash"></i>
                                    </button>
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>

<!-- Confirm Add Medication Modal -->
<div class="modal fade" id="confirmMedicationModal" tabindex="-1">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content">
            <div class="modal-header">
                <div>
                    <h5 class="modal-title"><i class="bi bi-question-circle me-2"></i>Confirm Save</h5>
                    <p class="modal-subtitle">Please review before saving</p>
                </div>
                <button type="button" class="close-btn" data-bs-dismiss="modal">
                    <i class="bi bi-x-lg"></i>
                </button>
            </div>
            <div class="modal-body">
                Are you sure you want to add this medication?
            </div>
            <div class="modal-footer">
                <button id="saveMedicationButton" class="modal-btn confirm-btn">
                    <i class="bi bi-check-lg"></i> Yes, Add
                </button>
                <button class="modal-btn secondary-btn" data-bs-dismiss="modal">
                    Cancel
                </button>
            </div>
        </div>
    </div>
</div>

<!-- Delete Medication Modal -->
<div class="modal fade" id="deleteMedicationModal" tabindex="-1">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content">
            <div class="modal-header">
                <div>
                    <h5 class="modal-title"><i class="bi bi-trash me-2"></i>Confirm Delete</h5>
                    <p class="modal-subtitle">This action cannot be undone</p>
                </div>
                <button type="button" class="close-btn" data-bs-dismiss="modal">
                    <i class="bi bi-x-lg"></i>
                </button>
            </div>
            <div class="modal-body">
                Are you sure you want to delete <strong id="deleteMedName"></strong>?
            </div>
            <div class="modal-footer">
                <button id="confirmDeleteBtn" class="modal-btn delete-btn">
                    <i class="bi bi-trash"></i> Yes, Delete
                </button>
                <button class="modal-btn secondary-btn" data-bs-dismiss="modal">
                    Cancel
                </button>
            </div>
        </div>
    </div>
</div>

<!-- Restock Modal -->
<div class="modal fade" id="restockModal" tabindex="-1">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content">
            <div class="modal-header">
                <div>
                    <h5 class="modal-title"><i class="bi bi-arrow-repeat me-2"></i>Re-stock Medication</h5>
                    <p class="modal-subtitle" id="restockMedName"></p>
                </div>
                <button type="button" class="close-btn" data-bs-dismiss="modal">
                    <i class="bi bi-x-lg"></i>
                </button>
            </div>
            <div class="modal-body">
                <input type="hidden" id="restockMedId">
                <div class="form-group">
                    <label class="form-label">Amount to Add</label>
                    <input type="number" id="restockAmount" class="form-control" placeholder="Enter quantity">
                </div>
                <div class="form-group">
                    <label class="form-label">Order Date & Time</label>
                    <input type="datetime-local" id="restockDateTime" class="form-control">
                </div>
            </div>
            <div class="modal-footer">
                <button id="saveRestockBtn" class="modal-btn confirm-btn">
                    <i class="bi bi-check-lg"></i> Save
                </button>
                <button class="modal-btn secondary-btn" data-bs-dismiss="modal">
                    Cancel
                </button>
            </div>
        </div>
    </div>
</div>

<!-- Active Ingredients Modal -->
<div class="modal fade" id="activeIngredientModal" tabindex="-1">
    <div class="modal-dialog modal-lg modal-dialog-centered">
        <div class="modal-content">
            <div class="modal-header">
                <div>
                    <h5 class="modal-title"><i class="bi bi-flask me-2"></i>Active Ingredients</h5>
                    <p class="modal-subtitle" id="modalMedName"></p>
                </div>
                <button type="button" class="close-btn" data-bs-dismiss="modal">
                    <i class="bi bi-x-lg"></i>
                </button>
            </div>
            <div class="modal-body">
                <div id="ingredientLoadingMsg" class="loading-spinner" style="display:none;">
                    <i class="bi bi-arrow-repeat spin"></i> Loading...
                </div>
                <div class="table-responsive">
                    <table class="data-table" id="ingredientModalTable">
                        <thead>
                            <tr>
                                <th>Medication</th>
                                <th>Ingredient</th>
                                <th>Strength</th>
                            </tr>
                        </thead>
                        <tbody id="ingredientModalBody"></tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>
</div>

<style>
