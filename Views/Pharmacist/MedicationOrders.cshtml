@model DEMO.ViewModels.MedicationOrderViewModel

@{
    ViewData["Title"] = "Medication Orders";
    Layout = "_LayoutPharmacist";
}
<!DOCTYPE html>
<html lang="en">
<head>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet" />

    <!-- jQuery -->
    <script src="https://code.jquery.com/jquery-3.5.1.js"></script>
    <!-- Bootstrap -->
    <link rel="stylesheet" href="https://stackpath.bootstrapcdn.com/bootstrap/5.1.3/css/bootstrap.min.css">
    <script src="https://stackpath.bootstrapcdn.com/bootstrap/5.1.3/js/bootstrap.bundle.min.js"></script>
    <!-- DataTables CSS -->
    <link rel="stylesheet" href="https://cdn.datatables.net/1.13.8/css/jquery.dataTables.min.css" />
</head>

<body>
    <div class="container mt-4">
        <div class="card shadow-sm p-4">
   
        <!-- FILTER -->
        <form method="get" action="@Url.Action("MedicationOrders", "Pharmacist")" class="mb-4">
                <h3 class="mb-3">Medication Orders</h3>
            <div class="row">
                <div class="col-md-4">

                    <label class="form-label">Filter by Medication</label>

                    <select name="medicationId" class="form-control" onchange="this.form.submit()">
                        <option value="0">-- All Medications --</option>

                        @foreach (var med in Model.AllMedications)
                        {
                            <option value="@med.MedicationID"
                                    selected="@(Model.SelectedMedicationId == med.MedicationID)">
                                @med.MedicationName
                            </option>
                        }
                    </select>

                </div>
            </div>
        </form>
        </div>
                </div>
    
        <!-- TABLE -->
            <div class="row">
                <div class="col">
                    <div class="p-3 mt-5 border bg-white">
        <table id="ordersTable" class="table table-bordered table-striped">
            <thead class="table-dark">
                <tr>
                    <th>Medication</th>
                    <th>Amount Ordered</th>
                    <th>Order Date</th>
                </tr>
            </thead>

            <tbody>
                @if (Model.Orders != null && Model.Orders.Any())
                {
                    foreach (var item in Model.Orders)
                    {
                        <tr>
                            <td>@item.MedicationName</td>
                            <td>@item.Amount</td>
                            <td>@item.OrderDate.ToString("yyyy-MM-dd HH:mm")</td>
                        </tr>
                    }
                }
                else
                {
                    <tr>
                        <td colspan="3" class="text-center text-muted">
                            No medication orders found.
                        </td>
                    </tr>
                }
            </tbody>
        </table>
         </div>
          </div>
            </div>
    

    <!-- JS SCRIPTS -->
    <script src="https://code.jquery.com/jquery-3.7.1.min.js"></script>
    <script src="https://cdn.datatables.net/1.13.8/js/jquery.dataTables.min.js"></script>

    <script>
        $(document).ready(function () {
            $('#ordersTable').DataTable({
                order: [[2, "desc"]], // Order Date column
                pageLength: 10
            });
        });
    </script>

</body>
</html>
