@{
    ViewData["Title"] = "Send Medication";
    Layout = "_LayoutPharmacist";
}
@model DEMO.ViewModels.EmailMedicationViewModel

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">

    <!-- Bootstrap 5 -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>

    <title>Send Medication</title>

    <style>
        body {
            background-color: #f4f7fa;
            font-family: 'Segoe UI', sans-serif;
        }

        .form-card {
            max-width: 800px;
            margin: 50px auto;
            padding: 30px 40px;
            background-color: #fff;
            border-radius: 12px;
            box-shadow: 0 5px 15px rgba(0,0,0,0.1);
        }

        h3 {
            color: #0d6efd;
            margin-bottom: 20px;
        }

        .form-label {
            font-weight: 600;
        }

        input[readonly] {
            background-color: #e9ecef;
        }
    </style>
</head>

<body>
    <div class="container">
        <div class="form-card">
            <h3 class="text-center">Send Medication Order</h3>
            <hr />

            <form method="post" action="@Url.Action("EmailMedication", "Pharmacist")">

                <!-- Hidden Medication ID -->
                <input type="hidden" name="MedicationID" value="@Model.MedicationID" />

                <div class="mb-3">
                    <label class="form-label">Medication Name</label>
                    <input type="text" class="form-control" value="@Model.MedicationName" readonly />
                </div>

                <div class="mb-3">
                    <label class="form-label">Amount</label>
                    <input type="text" class="form-control" value="@Model.Amount" readonly />
                </div>

                <div class="mb-3">
                    <label class="form-label">Order Date</label>
                    <input type="text" class="form-control" value="@Model.OrderDate.ToString("yyyy-MM-dd HH:mm")" readonly />
                </div>

                <div class="mb-3">
                    <label class="form-label">Notes</label>
                    <textarea class="form-control" name="notes" rows="3"></textarea>
                </div>

                <div class="text-center mt-4">
                    <button type="submit" class="btn btn-primary btn-lg">
                        Send Email
                    </button>
                </div>

            </form>
        </div>
    </div>
</body>
</html>