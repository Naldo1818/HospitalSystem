<!-- Scripts -->
<script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>
<script src="https://cdn.datatables.net/1.11.5/js/jquery.dataTables.min.js"></script>
<script src="https://stackpath.bootstrapcdn.com/bootstrap/4.5.2/js/bootstrap.bundle.min.js"></script>

<script>
    $(document).ready(function() {
        // ========== INITIALIZE BOOTSTRAP TABS ==========
        $('#prescriptionTab a, #viewPrescriptionTab a').on('click', function(e) {
            e.preventDefault();
            $(this).tab('show');
        });

        $('#medicationModal .nav-tabs a, #DmedicationModal .nav-tabs a').tab();

        // ========== DATATABLES INITIALIZATION - OPTION 1 (NO INFO TEXT) ==========
        var tables = {};
        ['prescribedTable', 'acceptedTable', 'rejectedTable'].forEach(function(id) {
            if ($('#' + id).length) {
                tables[id] = $('#' + id).DataTable({
                    pageLength: 10,
                    lengthMenu: [[10, 25, 50, 100, -1], [10, 25, 50, 100, "All"]],
                    language: {
                        zeroRecords: "No records found",
                        info: "",
                        infoEmpty: "",
                        infoFiltered: "",
                        lengthMenu: "_MENU_ records per page",
                        paginate: {
                            previous: "‹",
                            next: "›"
                        }
                    },
                    dom: 't<"d-flex justify-content-between align-items-center"lip>',
                    searching: false
                });
                $('#' + id + '_filter').hide();
            }
        });

        // Search functionality
        $('#searchInput').on('keyup', function() {
            var val = this.value.trim();
            Object.values(tables).forEach(t => t.search(val).draw());
            ['prescribedRow', 'acceptedRow', 'rejectedRow'].forEach(r => {
                var hasData = $(`#${r} .data-table tbody tr:visible`).length > 0;
                $('#' + r).toggle(hasData);
            });
        });

        // Filter buttons
        $('#showPrescribed').click(() => { setActive('prescribed'); $('#prescribedRow').show(); $('#acceptedRow,#rejectedRow').hide(); });
        $('#showAccepted').click(() => { setActive('dispensed'); $('#acceptedRow').show(); $('#prescribedRow,#rejectedRow').hide(); });
        $('#showRejected').click(() => { setActive('rejected'); $('#rejectedRow').show(); $('#prescribedRow,#acceptedRow').hide(); });
        $('#showAll').click(() => { setActive('all'); $('#prescribedRow,#acceptedRow,#rejectedRow').show(); });

        function setActive(f) {
            $('.filter-btn').removeClass('active');
            if (f === 'prescribed') $('#showPrescribed').addClass('active');
            else if (f === 'dispensed') $('#showAccepted').addClass('active');
            else if (f === 'rejected') $('#showRejected').addClass('active');
            else if (f === 'all') $('#showAll').addClass('active');
        }

        // ========== HELPER FUNCTIONS FOR MODALS ==========

        function buildVitalsRow(vitals) {
            if (!vitals || Object.keys(vitals).length === 0) {
                return '<div class="vital-item">No vitals recorded</div>';
            }
            return `
                <div class="vital-item"><strong>Height</strong><br>${vitals.height || '-'} cm</div>
                <div class="vital-item"><strong>Weight</strong><br>${vitals.weight || '-'} kg</div>
                <div class="vital-item"><strong>BP</strong><br>${vitals.systolicBloodPressure || '-'}/${vitals.diastolicBloodPressure || '-'}</div>
                <div class="vital-item"><strong>Heart Rate</strong><br>${vitals.heartRate || '-'} bpm</div>
                <div class="vital-item"><strong>Oxygen</strong><br>${vitals.bloodOxygen || '-'}%</div>
                <div class="vital-item"><strong>Respiration</strong><br>${vitals.respiration || '-'}</div>
                <div class="vital-item"><strong>Glucose</strong><br>${vitals.bloodGlucoseLevel || '-'}</div>
                <div class="vital-item"><strong>Temp</strong><br>${vitals.temperature || '-'}°C</div>
            `;
        }

        function buildListItems(items, type) {
            if (!items || items.length === 0) {
                return '<em class="text-muted">No ' + type + ' found</em>';
            }

            let html = '<div style="display: flex; flex-wrap: wrap; gap: 8px;">';

            items.forEach(function(item) {
                let displayName = '-';

                if (type === 'medications') {
                    displayName = item.cMedicationName || item.CMedicationName || item.medicationName || item.MedicationName || '-';
                } else if (type === 'allergies') {
                    displayName = item.activeIngredientName || item.ActiveIngredientName || item.allergenName || item.AllergenName || '-';
                } else if (type === 'conditions') {
                    displayName = item.conditionName || item.ConditionName || item.diagnosis || item.Diagnosis || '-';
                }

                html += `<span style="background: #fef0ed; padding: 6px 14px; border-radius: 30px; font-size: 12px; color: #e25c3c; display: inline-flex; align-items: center; gap: 6px;">
                    <i class="bi bi-tag-fill" style="font-size: 10px;"></i> ${displayName}
                </span>`;
            });

            html += '</div>';
            return html;
        }

        function buildPrescriptionTable(prescriptions) {
            if (!prescriptions || prescriptions.length === 0) {
                return '<tr><td colspan="5" class="text-center text-muted">No prescription details found</td></tr>';
            }

            let html = '';
            prescriptions.forEach(function(item) {
                html += `<tr>
                    <td><strong>${item.medicationName || item.MedicationName || '-'}</strong></td>
                    <td>${item.quantity || item.Quantity || '-'}</td>
                    <td>${item.schedule || item.Schedule || '-'}</td>
                    <td>${item.medicationForm || item.MedicationForm || item.form || '-'}</td>
                    <td>${item.instructions || item.Instructions || '-'}</td>
                </tr>`;
            });
            return html;
        }

        // ========== CHECK PRESCRIPTION BUTTON HANDLER ==========

        $('.check-prescription-btn').click(function() {
            let id = $(this).data('id');
            let isWithActions = $(this).hasClass('with-actions');

            if (isWithActions) {
                $('#medications-tab').tab('show');
                $('#vitalsSection').html('<div class="vital-item">Loading vitals...</div>');
                $('#currentMedsSection').html('<em>Loading...</em>');
                $('#allergiesSection').html('<em>Loading...</em>');
                $('#conditionsSection').html('<em>Loading...</em>');
                $('#prescriptionDetailsBody').html('');
            } else {
                $('#viewMedications-tab').tab('show');
                $('#viewVitalsSection').html('<div class="vital-item">Loading vitals...</div>');
                $('#viewCurrentMedsSection').html('<em>Loading...</em>');
                $('#viewAllergiesSection').html('<em>Loading...</em>');
                $('#viewConditionsSection').html('<em>Loading...</em>');
                $('#viewPrescriptionDetailsBody').html('');
            }

            $.ajax({
                url: '@Url.Action("PrescriptionDetails", "Pharmacist")',
                type: 'POST',
                data: { id: id },
                dataType: 'json',
                success: function(response) {
                    if (response.error) {
                        alert(response.error);
                        return;
                    }

                    let patientInfo = response.patientInfo || {};
                    let prescriptionDetails = response.prescriptionDetails || [];
                    let prescriptionDate = prescriptionDetails.length > 0
                        ? (prescriptionDetails[0].dateGiven || prescriptionDetails[0].DateGiven)
                        : null;

                    if (isWithActions) {
                        $('#patientName').text(patientInfo.name || patientInfo.Name || '-');
                        $('#patientSurname').text(patientInfo.surname || patientInfo.Surname || '-');
                        $('#patientGender').text(patientInfo.gender || patientInfo.Gender || '-');
                        $('#prescriptionDate').text(prescriptionDate ? new Date(prescriptionDate).toLocaleDateString() : '-');
                        $('#vitalsSection').html(buildVitalsRow(response.patientVitals));
                        $('#currentMedsSection').html(buildListItems(response.currentMedications, 'medications'));
                        $('#allergiesSection').html(buildListItems(response.allergies, 'allergies'));
                        $('#conditionsSection').html(buildListItems(response.conditions, 'conditions'));
                        $('#prescriptionDetailsBody').html(buildPrescriptionTable(prescriptionDetails));
                        $('#dispense-btn').data('prescription-id', id).show();
                        $('#reject-btn').data('prescription-id', id).show();
                    } else {
                        $('#viewPatientName').text(patientInfo.name || patientInfo.Name || '-');
                        $('#viewPatientSurname').text(patientInfo.surname || patientInfo.Surname || '-');
                        $('#viewPatientGender').text(patientInfo.gender || patientInfo.Gender || '-');
                        $('#viewPrescriptionDate').text(prescriptionDate ? new Date(prescriptionDate).toLocaleDateString() : '-');
                        $('#viewVitalsSection').html(buildVitalsRow(response.patientVitals));
                        $('#viewCurrentMedsSection').html(buildListItems(response.currentMedications, 'medications'));
                        $('#viewAllergiesSection').html(buildListItems(response.allergies, 'allergies'));
                        $('#viewConditionsSection').html(buildListItems(response.conditions, 'conditions'));
                        $('#viewPrescriptionDetailsBody').html(buildPrescriptionTable(prescriptionDetails));
                    }
                },
                error: function(xhr, status, error) {
                    console.error("AJAX Error:", error);
                    alert("Failed to load prescription details. Please try again.");
                }
            });
        });

        // ========== MODAL BUTTON HANDLERS ==========

        $('#rejectionReasonSelect').change(function() {
            $('#customReasonContainer').toggle($(this).val() === "Other");
        });

        $('#saveRejectBtn').click(function() {
            var id = $('#rejectPrescriptionId').val();
            var reason = $('#rejectionReasonSelect').val();
            if (reason === "Other") reason = $('#customReason').val().trim();
            if (!reason) {
                alert("Please provide a reason");
                return;
            }
            $.ajax({
                url: '@Url.Action("RejectPrescriptionAjax", "Pharmacist")',
                type: 'POST',
                data: { prescriptionId: id, reason: reason },
                success: function(r) {
                    if (r.success) {
                        location.reload();
                    } else {
                        alert(r.message || "Error rejecting prescription");
                    }
                },
                error: function() {
                    alert("Something went wrong. Please try again.");
                }
            });
        });

        $('#reject-btn').click(function() {
            var id = $(this).data('prescription-id');
            if (id) {
                $('#rejectPrescriptionId').val(id);
                $('#rejectionReasonSelect').val('');
                $('#customReason').val('');
                $('#customReasonContainer').hide();
                $('#rejectReasonModal').modal('show');
            }
        });

        $('#dispense-btn').click(function() {
            var id = $(this).data('prescription-id');
            if (confirm('Are you sure you want to dispense this prescription?')) {
                $.ajax({
                    url: '@Url.Action("DispensePrescription", "Pharmacist")',
                    type: 'POST',
                    data: { prescriptionId: id },
                    success: function(r) {
                        if (r.success) {
                            alert("Prescription dispensed successfully!");
                            location.reload();
                        } else {
                            alert(r.message || "Error dispensing prescription");
                        }
                    },
                    error: function() {
                        alert("Something went wrong. Please try again.");
                    }
                });
            }
        });

        // Reset modals when closed
        $('#medicationModal, #DmedicationModal').on('hidden.bs.modal', function() {
            if ($(this).attr('id') === 'medicationModal') {
                $('#medications-tab').tab('show');
            } else {
                $('#viewMedications-tab').tab('show');
            }
            $('#dispense-btn, #reject-btn').hide();
        });
    });
</script>