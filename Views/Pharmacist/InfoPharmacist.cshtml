@{
    ViewData["Title"] = "Information Page";
    Layout = "_LayoutPharmacist";
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, viewport-fit=cover">
    <title>Bay Breeze Hospital | Essential Info</title>

    <!-- Bootstrap Icons -->
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.css">
    <!-- Google Fonts: Plus Jakarta Sans for contemporary, clean look -->
    <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@300;400;500;600;700;800&display=swap" rel="stylesheet">

    <style>
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }

        body {
            font-family: 'Plus Jakarta Sans', 'Segoe UI', system-ui, -apple-system, BlinkMacSystemFont, sans-serif;
            background: #eef5fc;
            background-image: radial-gradient(circle at 0% 20%, rgba(13, 110, 253, 0.03) 0%, rgba(255,255,255,0) 70%);
            min-height: 100vh;
            padding: 2rem 1.5rem;
            display: flex;
            align-items: center;
            justify-content: center;
            position: relative;
        }

            /* fresh wave decorative element */
            body::after {
                content: '';
                position: fixed;
                bottom: 0;
                left: 0;
                width: 100%;
                height: 180px;
                background: url('data:image/svg+xml;utf8,<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 1440 320"><path fill="rgba(13,110,253,0.05)" fill-opacity="0.4" d="M0,192L48,197.3C96,203,192,213,288,208C384,203,480,181,576,176C672,171,768,181,864,197.3C960,213,1056,235,1152,229.3C1248,224,1344,192,1392,176L1440,160L1440,320L1392,320C1344,320,1248,320,1152,320C1056,320,960,320,864,320C768,320,672,320,576,320C480,320,384,320,288,320C192,320,96,320,48,320L0,320Z"></path></svg>') no-repeat bottom;
                background-size: cover;
                pointer-events: none;
                z-index: 0;
                opacity: 0.7;
            }

        /* main card - soft neumorphism twist */
        .info-dashboard {
            max-width: 800px;
            width: 100%;
            background: rgba(255, 255, 255, 0.98);
            border-radius: 2.5rem;
            box-shadow: 0 30px 50px -20px rgba(0, 35, 70, 0.2), 0 0 0 1px rgba(255,255,255,0.6);
            overflow: hidden;
            backdrop-filter: blur(0px);
            transition: all 0.35s cubic-bezier(0.2, 0.9, 0.4, 1.1);
            position: relative;
            z-index: 2;
        }

            .info-dashboard:hover {
                transform: scale(1.01);
                box-shadow: 0 35px 55px -22px rgba(0, 55, 100, 0.3);
            }

        /* header with dual-tone */
        .hero-section {
            background: linear-gradient(125deg, #0b5e9e 0%, #1f7bc7 100%);
            padding: 2rem 2rem 1.8rem;
            position: relative;
            text-align: left;
        }

            .hero-section .badge-float {
                position: absolute;
                right: 1.5rem;
                top: 1.5rem;
                background: rgba(255,255,240,0.2);
                backdrop-filter: blur(4px);
                border-radius: 60px;
                padding: 0.3rem 1rem;
                font-size: 0.7rem;
                font-weight: 600;
                color: white;
                letter-spacing: 0.3px;
            }

        .hero-title {
            display: flex;
            align-items: center;
            gap: 12px;
            color: white;
            margin-bottom: 0.5rem;
            flex-wrap: wrap;
        }

            .hero-title i {
                font-size: 2.5rem;
                filter: drop-shadow(0 3px 3px rgba(0,0,0,0.1));
            }

            .hero-title h1 {
                font-size: 2rem;
                font-weight: 800;
                letter-spacing: -0.5px;
                word-break: keep-all;
            }

        .hero-sub {
            color: rgba(255,255,245,0.9);
            font-weight: 500;
            display: flex;
            gap: 1rem;
            flex-wrap: wrap;
            font-size: 0.85rem;
            margin-top: 8px;
        }

        /* main info area */
        .info-body {
            padding: 2rem 2rem 2rem;
        }

        /* modern 2-column grid for desktop-ish */
        .details-grid {
            display: grid;
            grid-template-columns: repeat(2, 1fr);
            gap: 1.25rem;
        }

        /* each info tile refined */
        .info-tile {
            background: #ffffff;
            border-radius: 1.25rem;
            padding: 1.2rem 1.2rem;
            transition: all 0.2s;
            border: 1px solid #eef2fc;
            box-shadow: 0 3px 10px rgba(0,0,0,0.02);
        }

            .info-tile:hover {
                border-color: #cde2fe;
                background: #fbfdff;
                box-shadow: 0 12px 18px -12px rgba(27, 90, 150, 0.12);
            }

        .tile-header {
            display: flex;
            align-items: center;
            gap: 12px;
            margin-bottom: 0.8rem;
            border-bottom: 1px dashed #eaf0f8;
            padding-bottom: 0.6rem;
        }

        .tile-icon {
            width: 40px;
            height: 40px;
            background: #eef4fe;
            border-radius: 32px;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 1.3rem;
            color: #1f7bc7;
            transition: 0.2s;
        }

        .info-tile:hover .tile-icon {
            background: #1f7bc7;
            color: white;
            transform: rotate(3deg) scale(0.96);
        }

        .tile-header h3 {
            font-size: 1.1rem;
            font-weight: 700;
            color: #1e2f3f;
            margin: 0;
        }

        .tile-content {
            color: #2c445e;
            font-size: 0.9rem;
            line-height: 1.45;
        }

            .tile-content p {
                margin-bottom: 0.3rem;
            }

        .contact-highlight {
            font-weight: 600;
            color: #0b5e9e;
        }

        .email-badge {
            background: #f0f6ff;
            padding: 0.2rem 0.6rem;
            border-radius: 30px;
            font-size: 0.8rem;
            display: inline-block;
            margin-top: 6px;
        }

        a.clean-email {
            color: #1763b0;
            text-decoration: none;
            font-weight: 500;
            border-bottom: 1px dotted #92b9f0;
        }

            a.clean-email:hover {
                color: #0c4a86;
                border-bottom-color: #0c4a86;
            }

        /* full-width special row for purchase manager (shows in grid but we can adapt) */
        .span-full {
            grid-column: span 2;
        }

        /* extra touch: service row */
        .service-links {
            margin-top: 2rem;
            background: #f9fcff;
            border-radius: 1.5rem;
            padding: 1rem 1.4rem;
            display: flex;
            justify-content: space-between;
            flex-wrap: wrap;
            gap: 12px;
            border: 1px solid #e6edf8;
        }

        .service-item {
            display: flex;
            align-items: center;
            gap: 8px;
            font-size: 0.8rem;
            font-weight: 500;
            color: #2d6a9f;
        }

            .service-item i {
                font-size: 1.1rem;
            }

        /* responsive */


        .span-full {
            grid-column: span 1;
        }

        .hero-title h1 {
            font-size: 1.5rem;
        }

        .info-body {
            padding: 1.5rem;
        }

        .hero-section {
            padding: 1.5rem;
        }

        }

        /* manager special card */
        .manager-flex {
            display: flex;
            justify-content: space-between;
            align-items: baseline;
            flex-wrap: wrap;
            margin-top: 5px;
        }

        .pill-id {
            background: #ecf3fc;
            border-radius: 20px;
            padding: 0.2rem 0.7rem;
            font-family: monospace;
            font-weight: 600;
            font-size: 0.75rem;
        }

        hr.soft-hr {
            margin: 0.5rem 0 0.8rem;
            border: 0;
            height: 1px;
            background: linear-gradient(to right, #dce5f0, transparent);
        }

        /* new decorative elements */
        .watermark-wave {
            position: absolute;
            bottom: 10px;
            right: 15px;
            opacity: 0.03;
            font-size: 5rem;
            pointer-events: none;
        }
    </style>
</head>
<body>

    <div class="info-dashboard">
        <div class="hero-section">
            <div class="badge-float">
                <i class="bi bi-shield-check"></i> Trusted Care
            </div>
            <div class="hero-title">
                <i class="bi bi-hospital"></i>
                <h1>Bay Breeze Day Hospital</h1>
            </div>
            <div class="hero-sub">
                <span><i class="bi bi-geo-alt"></i> Summerstrand, Gqeberha</span>
                <span><i class="bi bi-telephone"></i> 041 583 2121</span>
                <span><i class="bi bi-calendar-heart"></i> Compassion first</span>
            </div>
        </div>

        <div class="info-body">
            <div class="details-grid">
                <!-- ADDRESS CARD -->
                <div class="info-tile">
                    <div class="tile-header">
                        <div class="tile-icon"><i class="bi bi-building"></i></div>
                        <h3>📍 Precise Address</h3>
                    </div>
                    <div class="tile-content">
                        <p><strong>1 8th Avenue</strong></p>
                        <p>Summerstrand, Gqeberha</p>
                        <p>Eastern Cape, 6001</p>
                        <div style="margin-top: 8px; background:#F4F9FE; border-radius: 40px; padding: 4px 10px; display: inline-block; font-size: 0.7rem;">
                            <i class="bi bi-car-front-fill"></i> Parking available
                        </div>
                    </div>
                </div>

                <!-- CONTACT INFO CARD enhanced -->
                <div class="info-tile">
                    <div class="tile-header">
                        <div class="tile-icon"><i class="bi bi-headset"></i></div>
                        <h3>📞 Contact Center</h3>
                    </div>
                    <div class="tile-content">
                        <p><i class="bi bi-phone-fill"></i> <span class="contact-highlight">041 583 2121</span> (Main)</p>
                        <p><i class="bi bi-envelope"></i> <a href="mailto:baybreeze@gmail.com" class="clean-email">baybreeze@gmail.com</a></p>
                        <div class="email-badge"><i class="bi bi-clock"></i> Response &lt; 2h (business hours)</div>
                    </div>
                </div>

                <!-- PRACTICE MANAGER (detailed) -->
                <div class="info-tile">
                    <div class="tile-header">
                        <div class="tile-icon"><i class="bi bi-person-badge-fill"></i></div>
                        <h3>🩺 Practice Manager</h3>
                    </div>
                    <div class="tile-content">
                        <div class="manager-flex">
                            <span><strong>ID: PR123456</strong></span>
                            <span class="pill-id"><i class="bi bi-database"></i> Reg. HPCSA</span>
                        </div>
                        <hr class="soft-hr">
                        <p><i class="bi bi-person-circle"></i> Mrs. D. van der Merwe</p>
                        <p><small><i class="bi bi-calendar2-week"></i> Clinical governance & operations</small></p>
                    </div>
                </div>

                <!-- PURCHASE MANAGER special tile with refreshing layout -->
                <div class="info-tile">
                    <div class="tile-header">
                        <div class="tile-icon"><i class="bi bi-box-seam"></i></div>
                        <h3>📦 Purchase Manager</h3>
                    </div>
                    <div class="tile-content">
                        <p><strong>N. Mostert</strong> <span style="font-size:0.7rem;">(Procurement Head)</span></p>
                        <p><i class="bi bi-envelope-paper"></i> <a href="mailto:nmostert@nmmu.ac.za" class="clean-email">nmostert@nmmu.ac.za</a></p>
                        <div style="margin-top: 8px; background:#eef3fc; border-radius: 12px; padding: 5px 8px; font-size: 0.7rem;">
                            <i class="bi bi-truck"></i> Supplier relations & medical inventory
                        </div>
                    </div>
                </div>
            </div>

            <!-- EXTRA INFO: additional operational details in a fresh style (replaces old divider) -->
            <div style="margin: 1.5rem 0 0.5rem 0;">
                <div class="service-links">
                    <div class="service-item"><i class="bi bi-chat-right-quote-fill"></i> After-hours nurse line</div>
                    <div class="service-item"><i class="bi bi-file-medical-fill"></i> e-Referrals accepted</div>
                    <div class="service-item"><i class="bi bi-wifi"></i> Free guest Wi-Fi</div>
                    <div class="service-item"><i class="bi bi-bandaid-fill"></i> Same-day scripts</div>
                </div>
            </div>

            <!-- modern footer & visual direction -->
            <div style="display: flex; justify-content: space-between; align-items: center; flex-wrap: wrap; margin-top: 1.4rem; font-size: 0.7rem; color: #6794bc; border-top: 1px solid #eef3fc; padding-top: 1rem;">
                <span><i class="bi bi-tree-fill"></i> Coastal Healing · Since 2003</span>
                <span><i class="bi bi-shield-lock-fill"></i> Level 4 B-BBEE contributor</span>
                <span><i class="bi bi-geo-alt"></i> <a href="#" style="color:#5d86b0; text-decoration: none;">View on map</a></span>
            </div>
        </div>
        <div class="watermark-wave">🌊</div>
    </div>

</body>
</html>
