@using DEMO.ViewModels
@{
    ViewData["Title"] = "Admissions List";
    Layout = "_Layout2";
}
@model AdmissionsListViewModel
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, user-scalable=yes">
    <title>Admissions List | Patient Management</title>

    <!-- Google Fonts + Font Awesome -->
    <link href="https://fonts.googleapis.com/css2?family=Inter:opsz,wght@14..32,300;14..32,400;14..32,500;14..32,600;14..32,700&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0-beta3/css/all.min.css">

    <!-- jQuery -->
    <script src="https://code.jquery.com/jquery-3.7.1.min.js" integrity="sha256-/JqT3SQfawRcv/BIHPThkBvs0OEvtFFmqPF/lYI/Cxo=" crossorigin="anonymous"></script>

    <!-- Bootstrap 5.3 + clean theme -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0-alpha1/dist/css/bootstrap.min.css" rel="stylesheet">
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0-alpha1/dist/js/bootstrap.bundle.min.js"></script>

    <!-- DataTables + BS5 integration -->
    <link rel="stylesheet" href="https://cdn.datatables.net/1.13.4/css/dataTables.bootstrap5.min.css">
    <script src="https://cdn.datatables.net/1.13.4/js/jquery.dataTables.min.js"></script>
    <script src="https://cdn.datatables.net/1.13.4/js/dataTables.bootstrap5.min.js"></script>

    <style>
        * {
            font-family: 'Inter', sans-serif;
        }

        body {
            background: #f4f7fc;
            margin: 0;
            padding: 0;
        }

        .main-container {
            max-width: 1600px;
            margin: 0 auto;
            padding: 1.8rem 1.5rem;
        }

        /* modern card style */
        .modern-card {
            background: #ffffff;
            border-radius: 28px;
            box-shadow: 0 12px 28px rgba(0, 0, 0, 0.04), 0 0 1px rgba(0, 0, 0, 0.03);
            transition: all 0.2s ease;
            border: none;
            overflow: hidden;
        }

        .card-header-custom {
            background: white;
            padding: 1.2rem 1.8rem 0.6rem 1.8rem;
            border-bottom: 2px solid #eef2fa;
        }

        .card-body-custom {
            padding: 1.6rem 1.8rem 1.8rem 1.8rem;
        }

        .page-title {
            font-weight: 700;
            font-size: 1.8rem;
            letter-spacing: -0.3px;
            background: linear-gradient(135deg, #1f4870, #1b3b5c);
            background-clip: text;
            -webkit-background-clip: text;
            color: transparent;
            margin-bottom: 0;
        }

        .filter-label {
            font-weight: 600;
            font-size: 0.8rem;
            text-transform: uppercase;
            letter-spacing: 0.4px;
            color: #4a627a;
            margin-bottom: 0.4rem;
        }

        .search-input-icon {
            position: relative;
        }

            .search-input-icon i {
                position: absolute;
                left: 14px;
                top: 50%;
                transform: translateY(-50%);
                color: #8a99b4;
                font-size: 0.9rem;
                pointer-events: none;
            }

            .search-input-icon input {
                padding-left: 40px;
                border-radius: 60px;
                border: 1px solid #e2e8f0;
                background: #ffffff;
                transition: 0.2s;
                height: 44px;
            }

                .search-input-icon input:focus {
                    border-color: #2c7da0;
                    box-shadow: 0 0 0 3px rgba(44,125,160,0.1);
                    outline: none;
                }

        .date-input-icon {
            position: relative;
        }

            .date-input-icon i {
                position: absolute;
                left: 14px;
                top: 50%;
                transform: translateY(-50%);
                color: #8a99b4;
                font-size: 0.9rem;
                pointer-events: none;
            }

            .date-input-icon input {
                padding-left: 40px;
                border-radius: 60px;
                border: 1px solid #e2e8f0;
                background: #ffffff;
                height: 44px;
            }

        /* table styling */
        .data-table-wrapper {
            overflow-x: auto;
            border-radius: 20px;
        }

        .table-admissions {
            width: 100%;
            margin-bottom: 0;
            border-collapse: separate;
            border-spacing: 0;
        }

            .table-admissions th {
                background: #f8fafd;
                color: #1f3b4c;
                font-weight: 600;
                font-size: 0.75rem;
                padding: 1rem 0.7rem;
                border-bottom: 1px solid #e9edf2;
                white-space: nowrap;
            }

            .table-admissions td {
                padding: 0.9rem 0.7rem;
                vertical-align: middle;
                border-bottom: 1px solid #f0f2f7;
                color: #1f2f3e;
                font-size: 0.85rem;
            }

        /* badge styles */
        .badge-theatre, .badge-ward {
            background: #eef2ff;
            color: #1f4870;
            border-radius: 40px;
            padding: 4px 10px;
            font-size: 0.7rem;
            font-weight: 600;
            display: inline-block;
        }

        .badge-bed {
            background: #e6f7ec;
            color: #1f7b4d;
            border-radius: 40px;
            padding: 4px 10px;
            font-size: 0.7rem;
            font-weight: 600;
        }

        /* action buttons group - modern stacked or inline */
        .action-buttons-group {
            display: flex;
            flex-direction: column;
            gap: 8px;
            min-width: 140px;
        }

        .btn-action-sm {
            border-radius: 40px;
            padding: 0.35rem 0.9rem;
            font-size: 0.7rem;
            font-weight: 600;
            transition: all 0.2s ease;
            white-space: nowrap;
            text-align: center;
        }

        .btn-outline-edit {
            background: #fff;
            border: 1px solid #2c7da0;
            color: #2c7da0;
        }

            .btn-outline-edit:hover {
                background: #2c7da0;
                color: white;
            }

        .btn-outline-code {
            background: #fff;
            border: 1px solid #6c757d;
            color: #495057;
        }

            .btn-outline-code:hover {
                background: #6c757d;
                color: white;
            }

        .btn-outline-prescription {
            background: #fff;
            border: 1px solid #1f7b4d;
            color: #1f7b4d;
        }

            .btn-outline-prescription:hover {
                background: #1f7b4d;
                color: white;
            }

        .btn-outline-history {
            background: #fff;
            border: 1px solid #e67e22;
            color: #e67e22;
        }

            .btn-outline-history:hover {
                background: #e67e22;
                color: white;
            }

        .btn-outline-discharge {
            background: #fff;
            border: 1px solid #dc3545;
            color: #dc3545;
        }

            .btn-outline-discharge:hover {
                background: #dc3545;
                color: white;
            }

        .empty-state {
            text-align: center;
            padding: 2.5rem;
            background: #fafcff;
            border-radius: 24px;
        }

        /* modal modern */
        .modal-content-modern {
            border-radius: 28px;
            border: none;
            box-shadow: 0 25px 45px -12px rgba(0,0,0,0.3);
            overflow: hidden;
        }

        .modal-header-modern {
            background: #1f3b4c;
            color: white;
            padding: 1rem 1.5rem;
            border-bottom: none;
        }

            .modal-header-modern .btn-close {
                filter: brightness(0) invert(1);
            }

        .form-label-modern {
            font-weight: 600;
            font-size: 0.7rem;
            text-transform: uppercase;
            letter-spacing: 0.5px;
            color: #4a627a;
            margin-bottom: 0.3rem;
        }

        .radio-group-modern {
            background: #f8fafc;
            border-radius: 16px;
            padding: 10px 15px;
            display: flex;
            gap: 20px;
            border: 1px solid #e2e8f0;
        }

            .radio-group-modern .form-check {
                margin: 0;
            }

      

        .action-buttons-group {
            min-width: 120px;
        }

        }
    </style>
</head>
<body>

    <div class="main-container">
        <main role="main">
            <!-- Header -->
            <div class="d-flex flex-wrap justify-content-between align-items-center mb-4">
                <div>
                    <h1 class="page-title"><i class="fas fa-procedures me-2" style="color:#1f7b4d;"></i> Admissions Management</h1>
                    <p class="text-muted mt-1 mb-0 small">Manage active admissions, edit bookings, prescriptions & discharge</p>
                </div>
                <div class="mt-2 mt-sm-0">
                    <span class="badge bg-light text-dark rounded-pill px-3 py-2">
                        <i class="fas fa-user-md me-1"></i> @ViewBag.UserName @ViewBag.UserSurname
                    </span>
                </div>
            </div>

            <!-- Filter Card -->
            <div class="modern-card mb-4">
                <div class="card-header-custom">
                    <div class="d-flex align-items-center gap-2">
                        <i class="fas fa-filter fs-5" style="color:#2c7da0;"></i>
                        <h5 class="fw-bold mb-0" style="color:#1f2f3e;">Filter Admissions</h5>
                    </div>
                </div>
                <div class="card-body-custom">
                    <div class="row g-4">
                        <div class="col-md-6">
                            <div class="filter-label"><i class="fas fa-search me-1"></i> SEARCH PATIENT / SURGEON</div>
                            <div class="search-input-icon">
                                <i class="fas fa-user-injured"></i>
                                <input type="text" class="form-control" id="searchInput" placeholder="Name, surname, surgeon...">
                            </div>
                        </div>
                        <div class="col-md-6">
                            <div class="filter-label"><i class="fas fa-calendar-day me-1"></i> SURGERY DATE</div>
                            <div class="date-input-icon">
                                <i class="fas fa-calendar-alt"></i>
                                <input type="date" class="form-control" id="dateInput">
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Admissions Table Card -->
            <div class="modern-card">
                <div class="card-header-custom">
                    <div class="d-flex justify-content-between align-items-center">
                        <div><i class="fas fa-users me-2" style="color:#1f7b4d;"></i> <strong>Current Admissions</strong></div>
                        <span class="badge bg-light text-dark rounded-pill px-3 py-2">
                            <i class="far fa-hospital"></i> @Model.AllcombinedData.Count patients
                        </span>
                    </div>
                </div>
                <div class="card-body-custom">
                    <div class="data-table-wrapper">
                        <table id="admissionsTable" class="table table-admissions" style="width:100%">
                            <thead>
                                <tr>
                                    <th>Name</th>
                                    <th>Surname</th>
                                    <th>Surgeon</th>
                                    <th>Surgery Date</th>
                                    <th>Time</th>
                                    <th>Theatre</th>
                                    <th>Ward</th>
                                    <th>Bed</th>
                                    <th>Admit Date</th>
                                    <th>Admit Time</th>
                                    <th style="min-width: 160px;">Actions</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var Data in Model.AllcombinedData)
                                {
                                    <tr>
                                        <td class="fw-semibold">@Data.Name</td>
                                        <td>@Data.Surname</td>
                                        <td>@ViewBag.UserName @ViewBag.UserSurname</td>
                                        <td>@Data.SurgeryDate.ToShortDateString()</td>
                                        <td>@Data.SurgeryTime</td>
                                        <td><span class="badge-theatre"><i class="fas fa-door-open me-1"></i> @Data.Theater</span></td>
                                        <td><span class="badge-ward"><i class="fas fa-building me-1"></i> @Data.WardName</span></td>
                                        <td><span class="badge-bed"><i class="fas fa-bed me-1"></i> @Data.BedNumber</span></td>
                                        <td>@Data.AdmitDate</td>
                                        <td>@Data.Time</td>
                                        <td>
                                            <div class="action-buttons-group">
                                                <!-- Edit Booking -->
                                                <button class="btn btn-action-sm btn-outline-edit edit-booking-btn"
                                                        data-patient-id="@Data.PatientID"
                                                        data-name="@Data.Name"
                                                        data-surname="@Data.Surname"
                                                        data-surgery-date="@Data.SurgeryDate.ToString("yyyy-MM-dd")"
                                                        data-surgery-time="@Data.SurgeryTime"
                                                        data-theater="@Data.Theater"
                                                        data-booking-id="@Data.BookingID"
                                                        data-account-id="@Data.AccountID">
                                                    <i class="fas fa-edit me-1"></i> Edit Booking
                                                </button>

                                                <!-- Show Treatment Codes -->
                                                <a class="btn btn-action-sm btn-outline-code"
                                                   asp-controller="Home"
                                                   asp-action="CheckTreatmentCode"
                                                   asp-route-bookingId="@Data.BookingID">
                                                    <i class="fas fa-qrcode me-1"></i> Treatment Codes
                                                </a>

                                                <!-- Give Prescription -->
                                                <button class="btn btn-action-sm btn-outline-prescription add-prescription-btn"
                                                        data-name="@Data.Name"
                                                        data-surname="@Data.Surname"
                                                        data-booking-id="@Data.BookingID"
                                                        data-account-id="@Data.AccountID"
                                                        data-admitted-patient-id="@Data.AdmittedPatientID"
                                                        data-patient-id="@Data.PatientID">
                                                    <i class="fas fa-prescription me-1"></i> Prescription
                                                </button>

                                                <!-- Vitals & History -->
                                                <a class="btn btn-action-sm btn-outline-history"
                                                   asp-controller="Home"
                                                   asp-action="vitalsAndHistory"
                                                   asp-route-name="@Data.Name"
                                                   asp-route-surname="@Data.Surname"
                                                   asp-route-patientID="@Data.PatientID">
                                                    <i class="fas fa-chart-line me-1"></i> Vitals & History
                                                </a>

                                                <!-- Discharge -->
                                                <button class="btn btn-action-sm btn-outline-discharge discharge-btn"
                                                        data-booking-id="@Data.BookingID"
                                                        data-admitted-patient-id="@Data.AdmittedPatientID">
                                                    <i class="fas fa-sign-out-alt me-1"></i> Discharge
                                                </button>
                                            </div>
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                    <div id="noRecordsMessage" class="empty-state d-none">
                        <i class="fas fa-user-slash"></i>
                        <p class="mt-2 mb-0">No admissions match your filters.</p>
                    </div>
                </div>
            </div>
        </main>
    </div>

    <!-- ========= MODALS ========= -->
    <!-- Edit Booking Modal (Modern) -->
    <div class="modal fade" id="editBookingModal" tabindex="-1" data-bs-backdrop="static">
        <div class="modal-dialog modal-lg modal-dialog-centered">
            <div class="modal-content modal-content-modern">
                <div class="modal-header modal-header-modern">
                    <h5 class="modal-title fw-bold"><i class="fas fa-calendar-edit me-2"></i>Edit Surgery Booking</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                </div>
                <div class="modal-body p-4">
                    <form id="editUserForm" method="post" asp-action="EditSurgery" asp-controller="Home">
                        <input type="hidden" id="editPatientID" name="PatientID" />
                        <input type="hidden" id="editBookingID" name="BookingID" />
                        <input type="hidden" id="editAccountID" name="AccountID" />

                        <div class="row g-3">
                            <div class="col-md-4">
                                <label class="form-label-modern">Patient Name</label>
                                <input type="text" class="form-control form-control-sm" id="editNameInput" disabled style="background:#f1f5f9">
                            </div>
                            <div class="col-md-4">
                                <label class="form-label-modern">Surname</label>
                                <input type="text" class="form-control form-control-sm" id="editSurnameInput" disabled style="background:#f1f5f9">
                            </div>
                            <div class="col-md-4">
                                <label class="form-label-modern">Surgery Date</label>
                                <input type="date" class="form-control form-control-sm" id="surgeryDateInput" name="SurgeryDate">
                            </div>
                        </div>

                        <div class="row g-3 mt-2">
                            <div class="col-md-6">
                                <label class="form-label-modern">Surgery Time</label>
                                <div class="radio-group-modern">
                                    <div class="form-check">
                                        <input class="form-check-input" type="radio" name="SurgeryTime" id="editTimeAM" value="AM">
                                        <label class="form-check-label" for="editTimeAM">AM</label>
                                    </div>
                                    <div class="form-check">
                                        <input class="form-check-input" type="radio" name="SurgeryTime" id="editTimePM" value="PM">
                                        <label class="form-check-label" for="editTimePM">PM</label>
                                    </div>
                                </div>
                            </div>
                            <div class="col-md-6">
                                <label class="form-label-modern">Theatre</label>
                                <div class="radio-group-modern">
                                    <div class="form-check">
                                        <input class="form-check-input" type="radio" name="Theater" id="editTheaterDove" value="Dove Theatre">
                                        <label class="form-check-label" for="editTheaterDove">Dove</label>
                                    </div>
                                    <div class="form-check">
                                        <input class="form-check-input" type="radio" name="Theater" id="editTheaterEagle" value="Eagle Theatre">
                                        <label class="form-check-label" for="editTheaterEagle">Eagle</label>
                                    </div>
                                    <div class="form-check">
                                        <input class="form-check-input" type="radio" name="Theater" id="editTheaterHadida" value="Hadida Theatre">
                                        <label class="form-check-label" for="editTheaterHadida">Hadida</label>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </form>
                </div>
                <div class="modal-footer border-0 pt-0 pb-4 pe-4">
                    <button type="button" class="btn btn-outline-secondary rounded-pill px-4" data-bs-dismiss="modal">Cancel</button>
                    <button type="button" id="openConfirmModalButton" class="btn btn-primary rounded-pill px-4" style="background:#2c7da0;">Save Changes</button>
                </div>
            </div>
        </div>
    </div>

    <!-- Confirm Edit Booking Modal -->
    <div class="modal fade" id="confirmEditBookingModal" tabindex="-1">
        <div class="modal-dialog modal-dialog-centered">
            <div class="modal-content modal-content-modern">
                <div class="modal-header modal-header-modern">
                    <h5 class="modal-title">Confirm Changes</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                </div>
                <div class="modal-body p-4">Are you sure you want to update this surgery booking?</div>
                <div class="modal-footer border-0 pt-0 pb-4">
                    <button type="button" class="btn btn-outline-secondary rounded-pill px-4" data-bs-dismiss="modal">No</button>
                    <button type="button" id="confirmEditBookingButton" class="btn btn-primary rounded-pill px-4">Yes, Update</button>
                </div>
            </div>
        </div>
    </div>

    <!-- Add Prescription Modal -->
    <div class="modal fade" id="addPrescriptionModal" tabindex="-1">
        <div class="modal-dialog modal-lg modal-dialog-centered">
            <div class="modal-content modal-content-modern">
                <div class="modal-header modal-header-modern">
                    <h5 class="modal-title fw-bold"><i class="fas fa-prescription-bottle me-2"></i>Add Prescription</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                </div>
                <div class="modal-body p-4">
                    <form id="addPrescriptionForm" method="post" action="@Url.Action("AddPrescription", "Home")">
                        <input type="hidden" id="prescAdmittedPatientID" name="AdmittedPatientID" />
                        <input type="hidden" id="prescBookingID" name="BookingID" />
                        <input type="hidden" name="AccountID" value="@ViewBag.UserAccountID" />

                        <div class="row g-3">
                            <div class="col-md-4">
                                <label class="form-label-modern">Name</label>
                                <input type="text" class="form-control" id="prescNameInput" name="Name" disabled>
                            </div>
                            <div class="col-md-4">
                                <label class="form-label-modern">Surname</label>
                                <input type="text" class="form-control" id="prescSurnameInput" name="Surname" disabled>
                            </div>
                            <div class="col-md-4">
                                <label class="form-label-modern">Surgeon</label>
                                <input type="text" class="form-control" value="@ViewBag.UserName @ViewBag.UserSurname" disabled>
                            </div>
                            <div class="col-md-6">
                                <label class="form-label-modern">Date Given</label>
                                <input type="date" class="form-control" id="dateGiven" name="DateGiven">
                            </div>
                            <div class="col-md-6">
                                <label class="form-label-modern">Urgency (Stat)</label>
                                <div class="radio-group-modern">
                                    <div class="form-check">
                                        <input class="form-check-input" type="radio" name="Urgency" value="Yes" id="urgencyYes">
                                        <label class="form-check-label" for="urgencyYes">Yes</label>
                                    </div>
                                    <div class="form-check">
                                        <input class="form-check-input" type="radio" name="Urgency" value="No" id="urgencyNo" checked>
                                        <label class="form-check-label" for="urgencyNo">No</label>
                                    </div>
                                </div>
                            </div>
                        </div>
                        <input type="hidden" name="Status" value="Prescribed">
                    </form>
                </div>
                <div class="modal-footer border-0 pt-0 pb-4 pe-4">
                    <button type="button" class="btn btn-outline-secondary rounded-pill px-4" data-bs-dismiss="modal">Cancel</button>
                    <button type="button" id="openConfirmPrescriptionModalButton" class="btn btn-primary rounded-pill px-4" style="background:#1f7b4d;">Save Prescription</button>
                </div>
            </div>
        </div>
    </div>

    <!-- Confirm Prescription Modal -->
    <div class="modal fade" id="confirmAddPrescriptionModal" tabindex="-1">
        <div class="modal-dialog modal-dialog-centered">
            <div class="modal-content modal-content-modern">
                <div class="modal-header modal-header-modern">
                    <h5 class="modal-title">Confirm Prescription</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                </div>
                <div class="modal-body p-4">Are you sure you want to save this prescription?</div>
                <div class="modal-footer border-0 pt-0 pb-4">
                    <button type="button" class="btn btn-outline-secondary rounded-pill px-4" data-bs-dismiss="modal">No</button>
                    <button type="button" id="confirmAddPrescriptionButton" class="btn btn-primary rounded-pill px-4">Yes, Save</button>
                </div>
            </div>
        </div>
    </div>

    <!-- Discharge Confirmation Modal -->
    <div class="modal fade" id="confirmDischargeModal" tabindex="-1">
        <div class="modal-dialog modal-dialog-centered">
            <div class="modal-content modal-content-modern">
                <div class="modal-header modal-header-modern">
                    <h5 class="modal-title fw-bold"><i class="fas fa-sign-out-alt me-2"></i>Confirm Discharge</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                </div>
                <div class="modal-body p-4">Are you sure you want to discharge this patient?</div>
                <div class="modal-footer border-0 pt-0 pb-4">
                    <form id="dischargeForm" asp-action="Discharge" asp-controller="Home" method="post">
                        <input type="hidden" id="dischargeAdmittedPatientID" name="AdmittedPatientID" />
                        <button type="button" class="btn btn-outline-secondary rounded-pill px-4" data-bs-dismiss="modal">Cancel</button>
                        <button type="submit" class="btn btn-danger rounded-pill px-4">Yes, Discharge</button>
                    </form>
                </div>
            </div>
        </div>
    </div>

    <script>
        $(document).ready(function () {
            // Initialize DataTable
            var table = $('#admissionsTable').DataTable({
                "pageLength": 10,
                "lengthMenu": [[5, 10, 15, 25], [5, 10, 15, 25]],
                "language": { "zeroRecords": " ", "info": "Showing _START_ to _END_ of _TOTAL_ admissions" },
                "order": [[8, 'desc']],
                "scrollX": true
            });

            // Custom date filter
            function applyDateFilter() {
                var dateVal = $('#dateInput').val();
                if (dateVal) {
                    $.fn.dataTable.ext.search.push(function(settings, data, dataIndex) {
                        var surgeryDateRaw = data[3];
                        var formatted = surgeryDateRaw;
                        var parts = surgeryDateRaw.split("/");
                        if (parts.length === 3) {
                            formatted = parts[2] + '-' + ('0' + parts[0]).slice(-2) + '-' + ('0' + parts[1]).slice(-2);
                        }
                        return formatted === dateVal;
                    });
                    table.draw();
                    $.fn.dataTable.ext.search.pop();
                } else {
                    table.draw();
                }
                toggleEmptyState();
            }

            $('#searchInput').on('keyup', function () {
                table.search($(this).val()).draw();
                toggleEmptyState();
            });
            $('#dateInput').on('change', applyDateFilter);

            function toggleEmptyState() {
                if (table.page.info().recordsDisplay === 0) {
                    $('#noRecordsMessage').removeClass('d-none');
                    $('#admissionsTable').hide();
                } else {
                    $('#noRecordsMessage').addClass('d-none');
                    $('#admissionsTable').show();
                }
            }
            if (@Model.AllcombinedData.Count === 0) {
                $('#admissionsTable').hide();
                $('#noRecordsMessage').removeClass('d-none');
            } else {
                toggleEmptyState();
            }

            // Edit Booking Modal handling
            $(document).on('click', '.edit-booking-btn', function() {
                var btn = $(this);
                $('#editPatientID').val(btn.data('patient-id'));
                $('#editBookingID').val(btn.data('booking-id'));
                $('#editAccountID').val(btn.data('account-id'));
                $('#editNameInput').val(btn.data('name'));
                $('#editSurnameInput').val(btn.data('surname'));
                $('#surgeryDateInput').val(btn.data('surgery-date'));
                var surgeryTime = btn.data('surgery-time');
                if (surgeryTime === 'AM') $('#editTimeAM').prop('checked', true);
                else if (surgeryTime === 'PM') $('#editTimePM').prop('checked', true);
                var theater = btn.data('theater');
                if (theater === 'Dove Theatre') $('#editTheaterDove').prop('checked', true);
                else if (theater === 'Eagle Theatre') $('#editTheaterEagle').prop('checked', true);
                else if (theater === 'Hadida Theatre') $('#editTheaterHadida').prop('checked', true);
                new bootstrap.Modal(document.getElementById('editBookingModal')).show();
            });

            $('#openConfirmModalButton').on('click', function() {
                $('#confirmEditBookingModal').modal('show');
            });
            $('#confirmEditBookingButton').on('click', function() {
                $('#editUserForm').submit();
            });

            // Prescription Modal
            $(document).on('click', '.add-prescription-btn', function() {
                var btn = $(this);
                $('#prescAdmittedPatientID').val(btn.data('admitted-patient-id'));
                $('#prescBookingID').val(btn.data('booking-id'));
                $('#prescNameInput').val(btn.data('name'));
                $('#prescSurnameInput').val(btn.data('surname'));
                $('#dateGiven').val(new Date().toISOString().split('T')[0]);
                $('#urgencyNo').prop('checked', true);
                new bootstrap.Modal(document.getElementById('addPrescriptionModal')).show();
            });

            $('#openConfirmPrescriptionModalButton').on('click', function() {
                if (!$('#dateGiven').val()) { alert("Please select date given."); return; }
                $('#confirmAddPrescriptionModal').modal('show');
            });
            $('#confirmAddPrescriptionButton').on('click', function() {
                $('#addPrescriptionForm').submit();
            });

            // Discharge Modal
            $(document).on('click', '.discharge-btn', function() {
                var admittedId = $(this).data('admitted-patient-id');
                $('#dischargeAdmittedPatientID').val(admittedId);
                new bootstrap.Modal(document.getElementById('confirmDischargeModal')).show();
            });
        });
    </script>
</body>
</html>
