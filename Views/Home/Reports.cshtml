@{
    ViewData["Title"] = "Surgery List";
    Layout = "_Layout2";
}
@model DEMO.ViewModels.ReportViewModel

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">

    <title>Surgery Reports</title>

    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css">
    <script src="https://cdnjs.cloudflare.com/ajax/libs/html2pdf.js/0.9.2/html2pdf.bundle.min.js"></script>

    <style>

        body {
            background: #f4f7fb;
            font-family: 'Segoe UI',Tahoma,Geneva,Verdana,sans-serif;
        }

        .page-header {
            font-weight: 700;
            color: #0d6efd;
        }

        .report-card {
            background: white;
            border-radius: 10px;
            box-shadow: 0 4px 15px rgba(0,0,0,0.08);
            padding: 25px;
        }

        .filter-card {
            background: white;
            border-radius: 10px;
            box-shadow: 0 4px 10px rgba(0,0,0,0.08);
            padding: 20px;
        }

        .table thead {
            background: #0d6efd;
            color: white;
        }

        .summary-table thead {
            background: #198754;
        }

        .badge-info {
            background: #eef4ff;
            color: #0d6efd;
            font-weight: 500;
            padding: 8px 12px;
        }

        .print-btn {
            width: 140px;
            font-weight: 600;
        }

    </style>
</head>

<body>

    <div class="container mt-5">

        <!-- PAGE TITLE -->
        <div class="row mb-4">
            <div class="col">
                <h2 class="page-header">Surgeon Surgery Reports</h2>
            </div>
        </div>


        <!-- DATE FILTER -->
        <div class="row mb-4">
            <div class="col-md-8">

                <div class="filter-card">

                    <h5 class="mb-3">Filter Report</h5>

                    <div class="row">

                        <div class="col-md-4">
                            <label class="form-label">Start Date</label>
                            <input type="date" id="StartDateInput" class="form-control">
                        </div>

                        <div class="col-md-4">
                            <label class="form-label">End Date</label>
                            <input type="date" id="EndDateInput" class="form-control">
                        </div>
                        
                        <br />
                        <br />
                        <button class="btn btn-primary print-btn" onclick="generatePDF()">
                            Print Report
                        </button>
                   
                    </div>

                </div>

            </div>
        </div>


        <!-- REPORT CARD -->
        <div class="row">
            <div class="col">

                <div class="report-card">

                    <div class="d-flex justify-content-between align-items-center mb-3">

                        <div>
                            <h5>Report for: @ViewBag.UserName @ViewBag.UserSurname</h5>

                            <div class="mt-2">

                                <span class="badge badge-info">
                                    Generated: <span id="todayDate"></span>
                                </span>

                                <span class="badge badge-info">
                                    Date Range: <span id="selectedDateRange"></span>
                                </span>

                                <span class="badge bg-primary">
                                    Total Patients: <span id="totalPatients">0</span>
                                </span>

                            </div>

                        </div>

                    </div>


                    <!-- SURGERY TABLE -->
                    <table id="Surgeries" class="table table-striped table-hover">

                        <thead>
                            <tr>
                                <th>Date</th>
                                <th>Patient</th>
                                <th>Treatment Description</th>
                                <th>Treatment Code</th>
                            </tr>
                        </thead>

                        <tbody>

                            @foreach (var Data in Model.AllcombinedData)
                            {
                                <tr>
                                    <td>@Data.SurgeryDate</td>
                                    <td>@Data.Patient</td>
                                    <td>@Data.TreatmentName</td>
                                    <td>@Data.TreatmentCode</td>
                                </tr>
                            }

                        </tbody>

                    </table>


                    <!-- SUMMARY TABLE -->
                    <h5 class="mt-5">Treatment Summary</h5>

                    <table id="Summary" class="table table-bordered summary-table">

                        <thead>
                            <tr>
                                <th>Treatment Description</th>
                                <th>Treatment Code</th>
                                <th>Total Surgeries</th>
                            </tr>
                        </thead>

                        <tbody id="summaryBody">
                        </tbody>

                    </table>

                </div>
            </div>
        </div>

    </div>



    <script>

        document.addEventListener("DOMContentLoaded", function () {

        function filterByDate(){

        var startDate=document.getElementById('StartDateInput').value;
        var endDate=document.getElementById('EndDateInput').value;

        var rows=document.querySelectorAll('#Surgeries tbody tr');

        var uniquePatients=new Set();

        document.getElementById('summaryBody').innerHTML='';

        rows.forEach(function(row){

        var rowDate=row.cells[0].textContent;
        var formattedRowDate=new Date(rowDate).toISOString().split('T')[0];
        var patient=row.cells[1].textContent;

        if((startDate && formattedRowDate<startDate)||(endDate && formattedRowDate>endDate))
        {
        row.style.display='none';
        }
        else
        {
        row.style.display='';

        uniquePatients.add(patient);

        var treatment=row.cells[2].textContent;
        var code=row.cells[3].textContent;

        updateSummary(treatment,code);
        }

        });

        document.getElementById('totalPatients').textContent=uniquePatients.size;

        }

        function updateSummary(treatment,code){

        var summaryBody=document.getElementById('summaryBody');

        var existingRow=Array.from(summaryBody.querySelectorAll('tr'))
        .find(row=>row.dataset.code===code);

        if(existingRow)
        {
        existingRow.querySelector('td:last-child').textContent=
        parseInt(existingRow.querySelector('td:last-child').textContent)+1;
        }
        else
        {
        var newRow=document.createElement('tr');

        newRow.dataset.code=code;

        newRow.innerHTML=`
        <td>${treatment}</td>
        <td>${code}</td>
        <td>1</td>
        `;

        summaryBody.appendChild(newRow);
        }

        }

        function displaySelectedDates(){

        var startDate=document.getElementById('StartDateInput').value;
        var endDate=document.getElementById('EndDateInput').value;

        var today=new Date().toLocaleDateString();

        document.getElementById('todayDate').textContent=today;

        document.getElementById('selectedDateRange').textContent=startDate+" to "+endDate;

        }

        document.getElementById('StartDateInput').addEventListener('change',()=>{
        filterByDate();
        displaySelectedDates();
        });

        document.getElementById('EndDateInput').addEventListener('change',()=>{
        filterByDate();
        displaySelectedDates();
        });

        filterByDate();
        displaySelectedDates();

        });

    </script>



    <script>

        function generatePDF(){

        var element=document.querySelector('.report-card');

        var opt={
        margin:1,
        filename:'Surgery_Report.pdf',
        image:{type:'jpeg',quality:0.98},
        html2canvas:{scale:2},
        jsPDF:{
        unit:'in',
        format:'letter',
        orientation:'landscape'
        }
        };

        html2pdf().from(element).set(opt).save();

        }

    </script>

</body>
</html>