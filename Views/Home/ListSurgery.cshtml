@{
    ViewData["Title"] = "Surgery Bookings";
    Layout = "_Layout2";
}
@model DEMO.ViewModels.SurgeryListViewModel
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Surgery Bookings</title>
    <!-- jQuery -->
    <script src="https://code.jquery.com/jquery-3.5.1.js"></script>
    <!-- DataTables CSS -->
    <link rel="stylesheet" href="https://cdn.datatables.net/1.11.5/css/jquery.dataTables.css">
    <!-- DataTables JS -->
    <script src="https://cdn.datatables.net/1.11.5/js/jquery.dataTables.js"></script>
    <!-- Bootstrap CSS -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <!-- Bootstrap Icons -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.10.0/font/bootstrap-icons.css" rel="stylesheet">
    <!-- Bootstrap JS -->
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
    <style>
        :root {
            --primary: #4f46e5;
            --primary-hover: #4338ca;
            --secondary: #64748b;
            --success: #10b981;
            --warning: #f59e0b;
            --danger: #ef4444;
            --light-bg: #f8fafc;
            --card-bg: #ffffff;
            --border-color: #e2e8f0;
            --text-primary: #1e293b;
            --text-secondary: #64748b;
            --shadow-sm: 0 1px 2px 0 rgb(0 0 0 / 0.05);
            --shadow: 0 4px 6px -1px rgb(0 0 0 / 0.1), 0 2px 4px -2px rgb(0 0 0 / 0.1);
            --shadow-lg: 0 10px 15px -3px rgb(0 0 0 / 0.1), 0 4px 6px -4px rgb(0 0 0 / 0.1);
        }

        body {
            background: linear-gradient(135deg, #f0f4ff 0%, #e8eeff 100%);
            min-height: 100vh;
        }

        .container {
            max-width: 1400px;
            padding: 2rem 1rem;
        }

        /* ---------- Page Header ---------- */
        .page-header {
            margin-bottom: 2rem;
        }

            .page-header h2 {
                font-size: 1.875rem;
                font-weight: 700;
                color: var(--text-primary);
                margin-bottom: 0.25rem;
            }

            .page-header .subtitle {
                color: var(--text-secondary);
                font-size: 0.95rem;
            }

        /* ---------- Search Card ---------- */
        .search-card {
            background: var(--card-bg);
            border-radius: 16px;
            padding: 1.5rem 2rem;
            margin-bottom: 1.5rem;
            box-shadow: var(--shadow);
            border: 1px solid var(--border-color);
            transition: box-shadow 0.2s ease;
        }

            .search-card:hover {
                box-shadow: var(--shadow-lg);
            }

            .search-card .form-label {
                font-weight: 600;
                font-size: 0.875rem;
                color: var(--text-secondary);
                text-transform: uppercase;
                letter-spacing: 0.05em;
                margin-bottom: 0.5rem;
            }

            .search-card .form-control {
                border: 2px solid var(--border-color);
                border-radius: 10px;
                padding: 0.625rem 1rem;
                font-size: 0.95rem;
                transition: all 0.2s ease;
                background: var(--light-bg);
            }

                .search-card .form-control:focus {
                    border-color: var(--primary);
                    box-shadow: 0 0 0 3px rgba(79, 70, 229, 0.1);
                    background: white;
                }

        .search-icon {
            position: relative;
        }

            .search-icon i {
                position: absolute;
                left: 12px;
                top: 50%;
                transform: translateY(-50%);
                color: var(--text-secondary);
                z-index: 10;
            }

            .search-icon input {
                padding-left: 2.5rem;
            }

        /* ---------- Table Card ---------- */
        .table-card {
            background: var(--card-bg);
            border-radius: 16px;
            padding: 1.5rem;
            box-shadow: var(--shadow);
            border: 1px solid var(--border-color);
        }

        /* ---------- DataTable Styling ---------- */
        #example {
            display: none;
            width: 100% !important;
        }

        .dataTables_wrapper {
            font-family: 'Inter', -apple-system, BlinkMacSystemFont, sans-serif;
        }

        .dataTables_length label,
        .dataTables_filter label {
            font-weight: 500;
            color: var(--text-secondary);
        }

        .dataTables_length select,
        .dataTables_filter input {
            border-radius: 8px;
            border: 2px solid var(--border-color);
            padding: 0.4rem 0.75rem;
            background: var(--light-bg);
        }

        table.dataTable {
            border-collapse: separate;
            border-spacing: 0;
            border-radius: 12px;
            overflow: hidden;
        }

            table.dataTable thead th {
                background: linear-gradient(135deg, #1e293b 0%, #334155 100%);
                color: white;
                font-weight: 600;
                font-size: 0.85rem;
                text-transform: uppercase;
                letter-spacing: 0.05em;
                padding: 14px 16px;
                border: none;
            }

            table.dataTable tbody tr {
                transition: all 0.2s ease;
            }

                table.dataTable tbody tr:hover {
                    background-color: #f1f5f9;
                    transform: translateY(-1px);
                    box-shadow: 0 2px 8px rgba(0,0,0,0.06);
                }

            table.dataTable tbody td {
                padding: 14px 16px;
                font-size: 0.9rem;
                color: var(--text-primary);
                border-bottom: 1px solid var(--border-color);
                vertical-align: middle;
            }

            table.dataTable tbody tr:last-child td {
                border-bottom: none;
            }

        /* ---------- Action Buttons ---------- */
        .btn-group-actions {
            display: flex;
            gap: 0.5rem;
            flex-wrap: wrap;
        }

        .btn-action {
            display: inline-flex;
            align-items: center;
            gap: 0.4rem;
            padding: 0.45rem 0.85rem;
            font-size: 0.8rem;
            font-weight: 600;
            border-radius: 8px;
            transition: all 0.2s ease;
            border: none;
            text-decoration: none;
            white-space: nowrap;
        }

        .btn-edit {
            background: #eef2ff;
            color: var(--primary);
        }

            .btn-edit:hover {
                background: var(--primary);
                color: white;
                transform: translateY(-1px);
                box-shadow: 0 4px 12px rgba(79, 70, 229, 0.3);
            }

        .btn-treatment {
            background: #f0fdf4;
            color: #16a34a;
        }

            .btn-treatment:hover {
                background: #16a34a;
                color: white;
                transform: translateY(-1px);
                box-shadow: 0 4px 12px rgba(22, 163, 74, 0.3);
            }

        .btn-vitals {
            background: #fff7ed;
            color: #ea580c;
        }

            .btn-vitals:hover {
                background: #ea580c;
                color: white;
                transform: translateY(-1px);
                box-shadow: 0 4px 12px rgba(234, 88, 12, 0.3);
            }

        /* ---------- Badges ---------- */
        .badge-theatre {
            display: inline-block;
            padding: 0.25rem 0.75rem;
            border-radius: 20px;
            font-size: 0.8rem;
            font-weight: 600;
        }

        .badge-dove {
            background: #ede9fe;
            color: #7c3aed;
        }

        .badge-eagle {
            background: #dbeafe;
            color: #2563eb;
        }

        .badge-hadida {
            background: #fce7f3;
            color: #db2777;
        }

        /* ---------- Modal Styling ---------- */
        .modal-content {
            border-radius: 20px;
            border: none;
            box-shadow: 0 25px 50px -12px rgb(0 0 0 / 0.25);
            overflow: hidden;
        }

        .modal-header {
            background: linear-gradient(135deg, #1e293b 0%, #334155 100%);
            color: white;
            border-bottom: none;
            padding: 1.25rem 1.5rem;
        }

            .modal-header .modal-title {
                font-weight: 700;
                font-size: 1.2rem;
            }

            .modal-header .btn-close {
                filter: brightness(0) invert(1);
                opacity: 0.8;
            }

        .modal-body {
            padding: 1.75rem;
            background: var(--light-bg);
        }

        .modal-footer {
            padding: 1rem 1.5rem;
            background: white;
            border-top: 1px solid var(--border-color);
            gap: 0.75rem;
        }

            .modal-footer .btn {
                padding: 0.6rem 1.5rem;
                font-weight: 600;
                border-radius: 10px;
                font-size: 0.9rem;
            }

        .btn-save {
            background: var(--primary);
            color: white;
            border: none;
        }

            .btn-save:hover {
                background: var(--primary-hover);
                transform: translateY(-1px);
                box-shadow: 0 4px 12px rgba(79, 70, 229, 0.3);
            }

        .btn-cancel {
            background: white;
            color: var(--text-secondary);
            border: 2px solid var(--border-color);
        }

            .btn-cancel:hover {
                background: var(--light-bg);
                border-color: #cbd5e1;
            }

        /* ---------- Form Fields in Modal ---------- */
        .modal-body .form-label {
            font-weight: 600;
            font-size: 0.85rem;
            color: var(--text-secondary);
            margin-bottom: 0.4rem;
        }

        .modal-body .form-control {
            border-radius: 10px;
            border: 2px solid var(--border-color);
            padding: 0.6rem 0.9rem;
            transition: all 0.2s ease;
            background: white;
        }

            .modal-body .form-control:focus {
                border-color: var(--primary);
                box-shadow: 0 0 0 3px rgba(79, 70, 229, 0.1);
            }

            .modal-body .form-control:disabled {
                background: #f1f5f9;
                color: #94a3b8;
            }

        /* Radio Button Group */
        .radio-group {
            display: flex;
            gap: 1rem;
            flex-wrap: wrap;
        }

        .radio-option {
            display: flex;
            align-items: center;
            gap: 0.4rem;
            padding: 0.5rem 1rem;
            border: 2px solid var(--border-color);
            border-radius: 10px;
            cursor: pointer;
            transition: all 0.2s ease;
            background: white;
        }

            .radio-option:hover {
                border-color: var(--primary);
                background: #eef2ff;
            }

            .radio-option input[type="radio"]:checked + label {
                color: var(--primary);
                font-weight: 700;
            }

            .radio-option:has(input:checked) {
                border-color: var(--primary);
                background: #eef2ff;
            }

        /* ---------- Confirmation Modal ---------- */
        .confirm-modal .modal-content {
            border-radius: 16px;
        }

        .confirm-modal .modal-body {
            background: white;
            text-align: center;
            padding: 2rem 1.5rem;
        }

            .confirm-modal .modal-body i {
                font-size: 3rem;
                color: var(--warning);
                margin-bottom: 1rem;
            }

        /* ---------- Responsive ---------- */
        @@media (max-width: 768px) {
            .search-card .row > div {
                margin-bottom: 1rem;
            }

            .btn-group-actions {
                flex-direction: column;
            }

            .btn-action {
                justify-content: center;
            }

            .modal-lg {
                max-width: 95% !important;
            }
        }

        /* ---------- Animations ---------- */
        @@keyframes fadeInUp {
            from {
                opacity: 0;
                transform: translateY(10px);
            }

            to {
                opacity: 1;
                transform: translateY(0);
            }
        }

        .search-card, .table-card {
            animation: fadeInUp 0.5s ease forwards;
        }

        .table-card {
            animation-delay: 0.1s;
        }
    </style>
</head>
<body>
    <div class="container">
        <main role="main" class="pb-5">
            <!-- Page Header -->
            <div class="page-header">
                <h2><i class="bi bi-calendar-heart me-2"></i>Surgery Bookings</h2>
                <p class="subtitle">Manage and view all scheduled surgeries</p>
            </div>

            <!-- Search Section -->
            <div class="search-card">
                <form id="searchForm">
                    <div class="row align-items-end">
                        <div class="col-md-5 mb-3 mb-md-0">
                            <label for="searchInput" class="form-label">
                                <i class="bi bi-search me-1"></i> Search Patient
                            </label>
                            <div class="search-icon">
                                <i class="bi bi-search"></i>
                                <input type="text" class="form-control" id="searchInput" placeholder="Search by name, surname...">
                            </div>
                        </div>
                        <div class="col-md-4 mb-3 mb-md-0">
                            <label for="dateInput" class="form-label">
                                <i class="bi bi-calendar3 me-1"></i> Filter by Date
                            </label>
                            <input type="date" class="form-control" id="dateInput">
                        </div>
                        <div class="col-md-3">
                            <button type="button" class="btn btn-outline-secondary w-100" id="clearFilters">
                                <i class="bi bi-x-circle me-1"></i> Clear Filters
                            </button>
                        </div>
                    </div>
                </form>
            </div>

            <!-- Table Section -->
            <div class="table-card">
                <table id="example" class="display" style="width:100%">
                    <thead>
                        <tr>
                            <th scope="col"><i class="bi bi-person me-1"></i>Name</th>
                            <th scope="col">Surname</th>
                            <th scope="col"><i class="bi bi-heart-pulse me-1"></i>Surgeon</th>
                            <th scope="col"><i class="bi bi-calendar-check me-1"></i>Surgery Date</th>
                            <th scope="col"><i class="bi bi-clock me-1"></i>Time</th>
                            <th scope="col"><i class="bi bi-building me-1"></i>Theatre</th>
                            <th scope="col"><i class="bi bi-gear me-1"></i>Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var Data in Model.AllcombinedData)
                        {
                            <tr>
                                <td><strong>@Data.Name</strong></td>
                                <td>@Data.Surname</td>
                                <td>@ViewBag.UserName @ViewBag.UserSurname</td>
                                <td>@Data.SurgeryDate</td>
                                <td>
                                    <span class="badge @(Data.SurgeryTime == "AM" ? "bg-info text-dark" : "bg-warning text-dark")">
                                        @Data.SurgeryTime
                                    </span>
                                </td>
                                <td>
                                    <span class="badge-theatre @(Data.Theater == "Dove Theatre" ? "badge-dove" : Data.Theater == "Eagle Theatre" ? "badge-eagle" : "badge-hadida")">
                                        @Data.Theater
                                    </span>
                                </td>
                                <td>
                                    <div class="btn-group-actions">
                                        <a class="btn-action btn-edit"
                                           data-bs-toggle="modal"
                                           data-bs-target="#editBookingModal"
                                           data-name="@Data.Name"
                                           data-surname="@Data.Surname"
                                           data-surgery-date="@Data.SurgeryDate"
                                           data-surgery-time="@Data.SurgeryTime"
                                           data-theater="@Data.Theater"
                                           data-booking-id="@Data.BookingID"
                                           data-account-id="@Data.AccountID"
                                           data-patient-id="@Data.PatientID">
                                            <i class="bi bi-pencil-square"></i> Edit
                                        </a>
                                        <a class="btn-action btn-treatment"
                                           asp-controller="Home"
                                           asp-action="CheckTreatmentCode"
                                           asp-route-bookingId="@Data.BookingID">
                                            <i class="bi bi-capsule"></i> Treatment
                                        </a>
                                        <a class="btn-action btn-vitals"
                                           asp-controller="Home"
                                           asp-action="vitalsAndHistory"
                                           asp-route-name="@Data.Name"
                                           asp-route-surname="@Data.Surname"
                                           asp-route-patientID="@Data.PatientID">
                                            <i class="bi bi-clipboard2-heart"></i> Vitals
                                        </a>
                                    </div>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>

            <!-- Edit Booking Modal -->
            <div class="modal fade" id="editBookingModal" tabindex="-1" aria-labelledby="editBookingModalLabel" aria-hidden="true">
                <div class="modal-dialog modal-lg modal-dialog-centered">
                    <div class="modal-content">
                        <div class="modal-header">
                            <h5 class="modal-title" id="editBookingModalLabel">
                                <i class="bi bi-pencil-square me-2"></i>Edit Surgery Booking
                            </h5>
                            <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                        </div>
                        <div class="modal-body">
                            <form id="editUserForm" method="post" asp-action="EditSurgery" asp-controller="Home">
                                <input type="hidden" id="PatientID" name="PatientID" />
                                <input type="hidden" id="BookingID" name="BookingID" />
                                <input type="hidden" id="AccountID" name="AccountID" />
                                <input type="hidden" name="Status" value="Booked">

                                <div class="row g-3">
                                    <div class="col-md-6">
                                        <label for="nameInput" class="form-label">Patient Name</label>
                                        <input type="text" class="form-control" name="Name" id="nameInput" placeholder="Enter Name" disabled>
                                    </div>
                                    <div class="col-md-6">
                                        <label for="surnameInput" class="form-label">Patient Surname</label>
                                        <input type="text" class="form-control" name="Surname" id="surnameInput" placeholder="Enter Surname" disabled>
                                    </div>
                                    <div class="col-md-6">
                                        <label for="surgeryDateInput" class="form-label">Surgery Date</label>
                                        <input type="date" class="form-control" name="SurgeryDate" id="surgeryDateInput">
                                    </div>
                                    <div class="col-md-6">
                                        <label class="form-label">Surgery Time</label>
                                        <div class="radio-group">
                                            <label class="radio-option">
                                                <input class="form-check-input" type="radio" name="SurgeryTime" value="AM">
                                                <span><i class="bi bi-sunrise me-1"></i> AM</span>
                                            </label>
                                            <label class="radio-option">
                                                <input class="form-check-input" type="radio" name="SurgeryTime" value="PM">
                                                <span><i class="bi bi-sunset me-1"></i> PM</span>
                                            </label>
                                        </div>
                                    </div>
                                    <div class="col-12">
                                        <label class="form-label">Theatre</label>
                                        <div class="radio-group">
                                            <label class="radio-option">
                                                <input class="form-check-input" type="radio" name="Theater" value="Dove Theatre">
                                                <span><i class="bi bi-building me-1"></i> Dove Theatre</span>
                                            </label>
                                            <label class="radio-option">
                                                <input class="form-check-input" type="radio" name="Theater" value="Eagle Theatre">
                                                <span><i class="bi bi-building me-1"></i> Eagle Theatre</span>
                                            </label>
                                            <label class="radio-option">
                                                <input class="form-check-input" type="radio" name="Theater" value="Hadida Theatre">
                                                <span><i class="bi bi-building me-1"></i> Hadida Theatre</span>
                                            </label>
                                        </div>
                                    </div>
                                </div>
                            </form>
                        </div>
                        <div class="modal-footer">
                            <button type="button" class="btn btn-cancel" data-bs-dismiss="modal">
                                <i class="bi bi-x-lg me-1"></i> Cancel
                            </button>
                            <button type="button" id="openConfirmModalButton" class="btn btn-save">
                                <i class="bi bi-check-lg me-1"></i> Save Changes
                            </button>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Confirmation Modal -->
            <div class="modal fade confirm-modal" id="confirmEditBookingModal" tabindex="-1" aria-labelledby="confirmEditBookingModalLabel" aria-hidden="true">
                <div class="modal-dialog modal-dialog-centered">
                    <div class="modal-content">
                        <div class="modal-header">
                            <h5 class="modal-title" id="confirmEditBookingModalLabel">
                                <i class="bi bi-exclamation-triangle me-2"></i>Confirm Changes
                            </h5>
                            <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                        </div>
                        <div class="modal-body">
                            <i class="bi bi-question-circle"></i>
                            <h5>Are you sure?</h5>
                            <p class="text-muted">Do you want to save these changes to the surgery booking?</p>
                        </div>
                        <div class="modal-footer justify-content-center">
                            <button type="button" class="btn btn-cancel" data-bs-dismiss="modal">
                                <i class="bi bi-x-lg me-1"></i> No, Cancel
                            </button>
                            <button type="button" id="confirmEditBookingButton" class="btn btn-save">
                                <i class="bi bi-check-lg me-1"></i> Yes, Save
                            </button>
                        </div>
                    </div>
                </div>
            </div>
        </main>
    </div>

    <script>
        $(document).ready(function () {
            var table = $('#example').DataTable({
                "language": {
                    "zeroRecords": "No matching records found",
                    "search": "",
                    "searchPlaceholder": "Search records..."
                },
                "dom": '<"top"f>rt<"bottom"lip><"clear">',
                "initComplete": function() {
                    $('.dataTables_filter input').addClass('form-control');
                }
            });

            // Custom search function
            $('#searchInput, #dateInput').on('keyup change', function () {
                var searchText = $('#searchInput').val().trim();
                var dateText = $('#dateInput').val();

                if (dateText) {
                    table.column(3).data().each(function (value, index) {
                        var tableDate = value.trim();
                        var parts = tableDate.split("/");
                        if (parts.length === 3) {
                            var reformattedDate = parts[2] + '-' + ('0' + parts[0]).slice(-2) + '-' + ('0' + parts[1]).slice(-2);
                            if (reformattedDate === dateText) {
                                table.row(index).nodes().to$().show();
                            } else {
                                table.row(index).nodes().to$().hide();
                            }
                        }
                    });
                } else {
                    table.rows().nodes().to$().show();
                }

                table.search(searchText).draw();

                if (searchText === '' && dateText === '') {
                    $('#example').hide();
                } else {
                    $('#example').show();
                    if (table.page.info().recordsDisplay === 0) {
                        $('#example').hide();
                    }
                }
            });

            // Clear filters button
            $('#clearFilters').on('click', function() {
                $('#searchInput').val('');
                $('#dateInput').val('');
                table.search('').draw();
                table.rows().nodes().to$().show();
                $('#example').hide();
            });
        });

        // Edit Booking Modal
        $('#editBookingModal').on('show.bs.modal', function (event) {
            var button = $(event.relatedTarget);
            var patientID = button.data('patient-id');
            var name = button.data('name');
            var surname = button.data('surname');
            var surgeryDate = button.data('surgery-date');
            var surgeryTime = button.data('surgery-time');
            var theater = button.data('theater');
            var bookingID = button.data('booking-id');

            var localDate = new Date(surgeryDate);
            var correctedDate = new Date(localDate.getTime() - localDate.getTimezoneOffset() * 60000);
            var formattedDate = correctedDate.toISOString().split('T')[0];

            var modal = $(this);
            modal.find('#nameInput').val(name);
            modal.find('#surnameInput').val(surname);
            modal.find('#surgeryDateInput').val(formattedDate);
            modal.find('input[name="SurgeryTime"][value="' + surgeryTime + '"]').prop('checked', true);
            modal.find('input[name="Theater"][value="' + theater + '"]').prop('checked', true);
            modal.find('#PatientID').val(patientID);
            modal.find('#BookingID').val(bookingID);
            modal.find('#AccountID').val(button.data('account-id'));
        });

        $('#openConfirmModalButton').on('click', function () {
            $('#confirmEditBookingModal').modal('show');
        });

        $('#confirmEditBookingButton').on('click', function () {
            $('#editUserForm').submit();
        });
    </script>
</body>
</html>