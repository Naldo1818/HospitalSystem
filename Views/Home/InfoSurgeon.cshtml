@{
    ViewData["Title"] = "Info";
    Layout = "_Layout2";
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Bay Breeze Day Hospital</title>

    <!-- Bootstrap Icons -->
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.css">

    <style>

        body {
            font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
            margin: 0;
            padding: 0;
            min-height: 100vh;
            display: flex;
            justify-content: center;
            align-items: flex-start;
            padding-top: 120px;
            /* Soft hospital gradient background */
            background: linear-gradient(135deg, #e9f3ff, #f7fbff);
        }

        .container {
            max-width: 700px;
            width: 100%;
            padding: 35px;
            border-radius: 12px;
            background: white;
            box-shadow: 0 10px 30px rgba(0,0,0,0.1);
            transition: 0.3s;
        }

            .container:hover {
                transform: translateY(-3px);
                box-shadow: 0 15px 35px rgba(0,0,0,0.15);
            }

        h1 {
            text-align: center;
            margin-bottom: 30px;
            font-weight: 700;
            color: #0d6efd;
            letter-spacing: 1px;
        }

        .info {
            padding: 15px;
            margin-bottom: 15px;
            border-radius: 8px;
            background: #f8fbff;
            border-left: 5px solid #0d6efd;
            transition: 0.25s;
        }

            .info:hover {
                background: #eef6ff;
                transform: translateX(4px);
            }

            .info h2 {
                margin: 0;
                font-size: 1.1rem;
                color: #333;
                display: flex;
                align-items: center;
                gap: 8px;
            }

            .info p {
                margin: 6px 0;
                color: #555;
                font-size: 0.95rem;
            }

        a {
            color: #0d6efd;
            text-decoration: none;
            font-weight: 500;
        }

            a:hover {
                text-decoration: underline;
            }

        /* Divider line */
        .divider {
            height: 1px;
            background: #e0e0e0;
            margin: 20px 0;
        }

    </style>
</head>

<body>

    <div class="container">

        <h1><i class="bi bi-hospital"></i> Bay Breeze Day Hospital</h1>

        <div class="info">
            <h2><i class="bi bi-geo-alt-fill"></i> Address</h2>
            <p>1 8th Avenue</p>
            <p>Summerstrand</p>
            <p>Gqeberha</p>
            <p>Eastern Cape, 6001</p>
        </div>

        <div class="info">
            <h2><i class="bi bi-telephone-fill"></i> Contact Information</h2>
            <p><strong>Phone:</strong> 041 583 2121</p>
            <p><strong>Email:</strong> <a href="mailto:baybreeze@gmail.com">baybreeze@gmail.com</a></p>
        </div>

        <div class="info">
            <h2><i class="bi bi-person-badge-fill"></i> Practice Manager</h2>
            <p><strong>ID:</strong> PR123456</p>
        </div>

        <div class="info">
            <h2><i class="bi bi-envelope-fill"></i> Purchase Manager</h2>
            <p><strong>Email:</strong> <a href="mailto:nmostert@nmmu.ac.za">nmostert@nmmu.ac.za</a></p>
        </div>

    </div>

</body>
</html>