@{
    ViewData["Title"] = "Patient List";
    Layout = "_Layout2";
}
@model DEMO.ViewModels.PatientListViewModal

<style>
    .stats-row {
        display: grid;
        grid-template-columns: repeat(3, 1fr);
        gap: 12px;
        margin-bottom: 1.25rem;
    }

    .stat-card {
        background: var(--bs-body-bg, #fff);
        border: 1px solid #e3e6f0;
        border-radius: 12px;
        padding: 1rem 1.25rem;
    }

    .stat-label {
        font-size: 12px;
        color: #6c757d;
        margin-bottom: 4px;
    }

    .stat-value {
        font-size: 24px;
        font-weight: 600;
    }

    .table > tbody > tr:hover {
        background-color: #f8f9fc;
    }

    .table th {
        font-size: 12px;
        font-weight: 600;
        text-transform: uppercase;
        letter-spacing: 0.04em;
        color: #6c757d;
        border-bottom: 1px solid #e3e6f0;
        padding: 12px 16px;
    }

    .table td {
        padding: 12px 16px;
        vertical-align: middle;
        border-bottom: 1px solid #f0f2f8;
        font-size: 14px;
    }

    .info-box {
        background: #f8f9fc;
        border-radius: 10px;
        padding: 1rem 1.25rem;
        margin-bottom: 1.25rem;
    }

    .info-label {
        font-size: 11px;
        color: #6c757d;
        font-weight: 600;
        text-transform: uppercase;
        letter-spacing: 0.04em;
        margin-bottom: 3px;
    }

    .info-value {
        font-size: 14px;
        font-weight: 500;
    }

    .theatre-option, .time-option {
        display: flex;
        align-items: center;
        gap: 8px;
        padding: 8px 12px;
        border: 1px solid #e3e6f0;
        border-radius: 8px;
        cursor: pointer;
        font-size: 13px;
        margin-bottom: 6px;
        transition: all 0.15s;
    }

        .theatre-option:hover, .time-option:hover {
            border-color: #4e73df;
            background: #eef0fd;
        }

        .theatre-option input, .time-option input {
            accent-color: #4e73df;
        }

    .time-options-row {
        display: flex;
        gap: 8px;
    }

    .time-option {
        flex: 1;
        justify-content: center;
        margin-bottom: 0;
    }

    .form-control:focus, .form-select:focus {
        border-color: #4e73df;
        box-shadow: 0 0 0 3px rgba(78, 115, 223, 0.15);
    }

    .btn-book {
        background: #fff;
        border: 1px solid #4e73df;
        color: #4e73df;
        border-radius: 20px;
        padding: 5px 14px;
        font-size: 12px;
        font-weight: 500;
        transition: all 0.15s;
    }

        .btn-book:hover {
            background: #4e73df;
            color: #fff;
        }

    #searchInput {
        max-width: 320px;
    }

    .empty-state {
        text-align: center;
        padding: 3rem 1rem;
        color: #adb5bd;
    }

        .empty-state i {
            font-size: 2.5rem;
            display: block;
            margin-bottom: 0.5rem;
        }
</style>

<div class="container-fluid px-0">

    <!-- Page Header -->
    <div class="d-flex justify-content-between align-items-center mb-4 flex-wrap gap-3">
        <div>
            <h1 class="fw-bold mb-1" style="color:#0f2b3d; font-size:1.75rem;">
                <i class="bi bi-people-fill me-2" style="color:#4e73df;"></i>Patient Management
            </h1>
            <p class="text-secondary mb-0" style="font-size:14px;">Manage patient records and schedule surgical procedures</p>
        </div>
        <button type="button" class="btn btn-primary rounded-pill px-4 py-2"
                data-bs-toggle="modal" data-bs-target="#addPatientModal">
            <i class="bi bi-plus-circle me-2"></i>Add Patient
        </button>
    </div>

    <!-- Stats Row -->
    <div class="stats-row">
        <div class="stat-card">
            <div class="stat-label">Total Patients</div>
            <div class="stat-value" id="statTotal">@Model.AllPatients.Count()</div>
        </div>
        <div class="stat-card">
            <div class="stat-label">Male</div>
            <div class="stat-value" style="color:#4e73df;" id="statMale">@Model.AllPatients.Count(p => p.Gender == "Male")</div>
        </div>
        <div class="stat-card">
            <div class="stat-label">Female</div>
            <div class="stat-value" style="color:#e74a8b;" id="statFemale">@Model.AllPatients.Count(p => p.Gender == "Female")</div>
        </div>
    </div>

    <!-- Search Card -->
    <div class="card border-0 shadow-sm mb-4" style="border-radius:12px;">
        <div class="card-body p-3">
            <div class="d-flex align-items-center gap-2 flex-wrap">
                <i class="bi bi-search text-secondary"></i>
                <input type="text" class="form-control form-control-sm" id="searchInput"
                       placeholder="Search by 13-digit ID number..."
                       maxlength="13" oninput="handleSearch(this)" />
                <button class="btn btn-sm btn-outline-secondary rounded-pill" onclick="clearSearch()">
                    <i class="bi bi-x-circle me-1"></i>Clear
                </button>
            </div>
            <div id="searchError" class="text-danger small mt-2" style="display:none;"></div>
        </div>
    </div>

    <!-- Table Card -->
    <div class="card border-0 shadow-sm" style="border-radius:12px;">
        <div class="card-body p-0">
            <div class="table-responsive">
                <table class="table mb-0" id="patientsTable">
                    <thead>
                        <tr>
                            <th>ID Number</th>
                            <th>Name</th>
                            <th>Surname</th>
                            <th>Gender</th>
                            <th>Email</th>
                            <th>Action</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var patient in Model.AllPatients)
                        {
                            <tr class="patient-row" style="display:none;"
                                data-id="@patient.IDNumber"
                                data-patient-id="@patient.PatientID"
                                data-name="@patient.Name"
                                data-surname="@patient.Surname"
                                data-gender="@patient.Gender"
                                data-email="@patient.Email">
                                <td class="fw-medium" style="font-family:monospace; font-size:13px;">@patient.IDNumber</td>
                                <td>@patient.Name</td>
                                <td>@patient.Surname</td>
                                <td>
                                    @if (patient.Gender == "Male")
                                    {
                                        <span class="badge rounded-pill px-3 py-2"
                                              style="background:#e8f0fe; color:#1a56db; font-size:11px; font-weight:500;">
                                            <i class="bi bi-gender-male me-1"></i>Male
                                        </span>
                                    }
                                    else
                                    {
                                        <span class="badge rounded-pill px-3 py-2"
                                              style="background:#fde8f0; color:#c2185b; font-size:11px; font-weight:500;">
                                            <i class="bi bi-gender-female me-1"></i>Female
                                        </span>
                                    }
                                </td>
                                <td>
                                    <a href="mailto:@patient.Email" class="text-decoration-none"
                                       style="color:#4e73df; font-size:13px;">@patient.Email</a>
                                </td>
                                <td>
                                    <button type="button" class="btn-book book-surgery-btn"
                                            data-bs-toggle="modal"
                                            data-bs-target="#bookSurgeryModal"
                                            data-patient-id="@patient.PatientID"
                                            data-name="@patient.Name"
                                            data-surname="@patient.Surname">
                                        <i class="bi bi-scissors me-1"></i>Book Surgery
                                    </button>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>

            <div id="emptyState" class="empty-state">
                <i class="bi bi-search"></i>
                Enter a 13-digit ID number above to find a patient
            </div>

            <div id="noResultsState" class="empty-state" style="display:none;">
                <i class="bi bi-person-x"></i>
                No patient found with that ID number
            </div>
        </div>
    </div>
</div>

<!-- Book Surgery Modal -->
<div class="modal fade" id="bookSurgeryModal" tabindex="-1" aria-labelledby="bookSurgeryModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-lg modal-dialog-centered">
        <div class="modal-content border-0 shadow" style="border-radius:16px;">
            <div class="modal-header border-0 pb-0 pt-4 px-4">
                <h5 class="modal-title fw-semibold" id="bookSurgeryModalLabel">
                    <i class="bi bi-calendar-plus me-2" style="color:#4e73df;"></i>Schedule Surgery
                </h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>

            <div class="modal-body px-4 pb-2 pt-3">
                <form id="bookingForm" method="post" asp-action="BookSurgery" asp-controller="Home" asp-antiforgery="true">

                    <!-- Patient Info -->
                    <div class="info-box">
                        <div class="row g-3">
                            <div class="col-sm-4">
                                <div class="info-label">Patient Name</div>
                                <div class="info-value" id="modalPatientName">-</div>
                            </div>
                            <div class="col-sm-4">
                                <div class="info-label">Patient Surname</div>
                                <div class="info-value" id="modalPatientSurname">-</div>
                            </div>
                            <div class="col-sm-4">
                                <div class="info-label">Surgeon</div>
                                <div class="info-value">@(ViewBag.UserName + " " + ViewBag.UserSurname)</div>
                            </div>
                        </div>
                    </div>

                    <!-- Surgery Details -->
                    <div class="row g-4">
                        <div class="col-md-4">
                            <label class="form-label fw-semibold mb-2" style="font-size:13px;">
                                Theatre <span class="text-danger">*</span>
                            </label>
                            <label class="theatre-option">
                                <input type="radio" name="Theater" value="Dove Theatre" required>
                                Dove Theatre
                            </label>
                            <label class="theatre-option">
                                <input type="radio" name="Theater" value="Eagle Theatre">
                                Eagle Theatre
                            </label>
                            <label class="theatre-option">
                                <input type="radio" name="Theater" value="Hadida Theatre">
                                Hadida Theatre
                            </label>
                            <div class="text-danger small" id="theatreError" style="display:none;">Please select a theatre</div>
                        </div>

                        <div class="col-md-4">
                            <label class="form-label fw-semibold mb-2" style="font-size:13px;">
                                Surgery Date <span class="text-danger">*</span>
                            </label>
                            <input type="date" class="form-control" name="SurgeryDate" id="surgeryDate" required>
                            <div class="text-danger small" id="dateError" style="display:none;">Please select a date</div>
                        </div>

                        <div class="col-md-4">
                            <label class="form-label fw-semibold mb-2" style="font-size:13px;">
                                Time Slot <span class="text-danger">*</span>
                            </label>
                            <div class="time-options-row">
                                <label class="time-option">
                                    <input type="radio" name="SurgeryTime" value="AM" required>
                                    AM
                                </label>
                                <label class="time-option">
                                    <input type="radio" name="SurgeryTime" value="PM">
                                    PM
                                </label>
                            </div>
                            <div class="text-danger small" id="timeError" style="display:none;">Please select a time slot</div>
                        </div>
                    </div>

                    <input type="hidden" name="Status" value="Booked">
                    <input type="hidden" id="modalPatientID" name="PatientID">
                    <input type="hidden" id="AccountID" name="AccountID" value="@ViewBag.UserAccountID">
                </form>
            </div>

            <div class="modal-footer border-0 pb-4 px-4">
                <button type="button" class="btn btn-light rounded-pill px-4" data-bs-dismiss="modal">Cancel</button>
                <button type="button" class="btn btn-primary rounded-pill px-4" onclick="submitBooking()">
                    <i class="bi bi-check-lg me-1"></i>Confirm Booking
                </button>
            </div>
        </div>
    </div>
</div>

<!-- Add Patient Modal -->
<div class="modal fade" id="addPatientModal" tabindex="-1" aria-labelledby="addPatientModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-lg modal-dialog-centered">
        <div class="modal-content border-0 shadow" style="border-radius:16px;">
            <div class="modal-header border-0 pb-0 pt-4 px-4">
                <h5 class="modal-title fw-semibold" id="addPatientModalLabel">
                    <i class="bi bi-person-plus me-2" style="color:#4e73df;"></i>Register New Patient
                </h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>

            <div class="modal-body px-4 pb-2 pt-3">
                <form id="addPatientForm" method="post" asp-action="RegisterPatient" asp-controller="Home" asp-antiforgery="true">
                    <div class="row g-3">
                        <div class="col-md-4">
                            <label class="form-label fw-semibold" style="font-size:13px;">
                                First Name <span class="text-danger">*</span>
                            </label>
                            <input type="text" class="form-control" name="Name" id="addName"
                                   required maxlength="100" placeholder="First name">
                            <div class="text-danger small" id="nameError" style="display:none;">Required</div>
                        </div>
                        <div class="col-md-4">
                            <label class="form-label fw-semibold" style="font-size:13px;">
                                Last Name <span class="text-danger">*</span>
                            </label>
                            <input type="text" class="form-control" name="Surname" id="addSurname"
                                   required maxlength="100" placeholder="Last name">
                            <div class="text-danger small" id="surnameError" style="display:none;">Required</div>
                        </div>
                        <div class="col-md-4">
                            <label class="form-label fw-semibold" style="font-size:13px;">
                                ID Number <span class="text-danger">*</span>
                            </label>
                            <input type="text" class="form-control" name="IdNumber" id="addIdNumber"
                                   required pattern="^\d{13}$" maxlength="13" placeholder="13-digit ID"
                                   oninput="this.value=this.value.replace(/\D/g,'')">
                            <div class="text-danger small" id="idError" style="display:none;">Must be exactly 13 digits</div>
                        </div>
                        <div class="col-md-4">
                            <label class="form-label fw-semibold" style="font-size:13px;">
                                Gender <span class="text-danger">*</span>
                            </label>
                            <div class="d-flex gap-3 mt-1">
                                <div class="form-check">
                                    <input class="form-check-input" type="radio" name="Gender"
                                           value="Male" id="genderMale" checked>
                                    <label class="form-check-label" for="genderMale">Male</label>
                                </div>
                                <div class="form-check">
                                    <input class="form-check-input" type="radio" name="Gender"
                                           value="Female" id="genderFemale">
                                    <label class="form-check-label" for="genderFemale">Female</label>
                                </div>
                            </div>
                        </div>
                        <div class="col-md-8">
                            <label class="form-label fw-semibold" style="font-size:13px;">
                                Email Address <span class="text-danger">*</span>
                            </label>
                            <input type="email" class="form-control" name="Email" id="addEmail"
                                   required placeholder="patient@@example.com">
                            <div class="text-danger small" id="emailError" style="display:none;">Valid email required</div>
                        </div>
                    </div>
                </form>
            </div>

            <div class="modal-footer border-0 pb-4 px-4">
                <button type="button" class="btn btn-light rounded-pill px-4" data-bs-dismiss="modal">Cancel</button>
                <button type="button" class="btn btn-primary rounded-pill px-4" onclick="submitAddPatient()">
                    <i class="bi bi-save me-1"></i>Save Patient
                </button>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        // Set initial state - hide all rows on page load
        document.addEventListener('DOMContentLoaded', function() {
            var rows = document.querySelectorAll('.patient-row');
            rows.forEach(function(r) { r.style.display = 'none'; });
            document.getElementById('emptyState').style.display = 'block';
        });

        // Search function
        function handleSearch(input) {
            input.value = input.value.replace(/\D/g, '');
            var val = input.value;
            var err = document.getElementById('searchError');
            var rows = document.querySelectorAll('.patient-row');
            var emptyState = document.getElementById('emptyState');
            var noResults = document.getElementById('noResultsState');

            if (val === '') {
                rows.forEach(function (r) { r.style.display = 'none'; });
                emptyState.style.display = 'block';
                noResults.style.display = 'none';
                err.style.display = 'none';
                return;
            }

            if (!/^\d{13}$/.test(val)) {
                err.textContent = 'ID number must be exactly 13 digits';
                err.style.display = 'block';
                rows.forEach(function (r) { r.style.display = 'none'; });
                emptyState.style.display = 'none';
                noResults.style.display = 'none';
                return;
            }

            err.style.display = 'none';
            var found = 0;
            rows.forEach(function (row) {
                if (row.dataset.id && row.dataset.id.includes(val)) {
                    row.style.display = '';
                    found++;
                } else {
                    row.style.display = 'none';
                }
            });

            emptyState.style.display = 'none';
            noResults.style.display = found === 0 ? 'block' : 'none';
        }

        function clearSearch() {
            var input = document.getElementById('searchInput');
            input.value = '';
            document.getElementById('searchError').style.display = 'none';
            document.querySelectorAll('.patient-row').forEach(function (r) { r.style.display = 'none'; });
            document.getElementById('emptyState').style.display = 'block';
            document.getElementById('noResultsState').style.display = 'none';
        }

        // Book Surgery Modal handlers
        document.addEventListener('DOMContentLoaded', function() {
            var bookButtons = document.querySelectorAll('.book-surgery-btn');

            bookButtons.forEach(function(button) {
                button.addEventListener('click', handleBookClick);
            });
        });

        function handleBookClick(event) {
            var button = event.currentTarget;
            var patientID = button.getAttribute('data-patient-id');
            var name = button.getAttribute('data-name');
            var surname = button.getAttribute('data-surname');

            document.getElementById('modalPatientID').value = patientID || '';
            document.getElementById('modalPatientName').textContent = name || '-';
            document.getElementById('modalPatientSurname').textContent = surname || '-';

            var radios = document.querySelectorAll('#bookSurgeryModal input[type="radio"]');
            radios.forEach(function(r) { r.checked = false; });
            var dateInput = document.getElementById('surgeryDate');
            if (dateInput) dateInput.value = '';

            ['theatreError', 'dateError', 'timeError'].forEach(function(id) {
                var el = document.getElementById(id);
                if (el) el.style.display = 'none';
            });
        }

        function submitBooking() {
            var theatre = document.querySelector('input[name="Theater"]:checked');
            var date = document.getElementById('surgeryDate').value;
            var time = document.querySelector('input[name="SurgeryTime"]:checked');
            var patientID = document.getElementById('modalPatientID').value;

            var isValid = true;

            if (!theatre) {
                document.getElementById('theatreError').style.display = 'block';
                isValid = false;
            } else {
                document.getElementById('theatreError').style.display = 'none';
            }

            if (!date) {
                document.getElementById('dateError').style.display = 'block';
                isValid = false;
            } else {
                document.getElementById('dateError').style.display = 'none';
            }

            if (!time) {
                document.getElementById('timeError').style.display = 'block';
                isValid = false;
            } else {
                document.getElementById('timeError').style.display = 'none';
            }

            if (!patientID || patientID === '') {
                alert('Patient information is missing. Please close the modal and try again.');
                isValid = false;
            }

            if (isValid) {
                document.getElementById('bookingForm').submit();
            }
        }

        // Add Patient function
        function submitAddPatient() {
            var name = document.getElementById('addName').value.trim();
            var surname = document.getElementById('addSurname').value.trim();
            var idnum = document.getElementById('addIdNumber').value.trim();
            var email = document.getElementById('addEmail').value.trim();

            var isValid = true;

            if (!name) {
                document.getElementById('nameError').style.display = 'block';
                isValid = false;
            } else {
                document.getElementById('nameError').style.display = 'none';
            }

            if (!surname) {
                document.getElementById('surnameError').style.display = 'block';
                isValid = false;
            } else {
                document.getElementById('surnameError').style.display = 'none';
            }

            if (!/^\d{13}$/.test(idnum)) {
                document.getElementById('idError').style.display = 'block';
                isValid = false;
            } else {
                document.getElementById('idError').style.display = 'none';
            }

            if (!/^[^\s@@]+@@[^\s@@]+\.[^\s@@]+$/.test(email)) {
                document.getElementById('emailError').style.display = 'block';
                isValid = false;
            } else {
                document.getElementById('emailError').style.display = 'none';
            }

            if (isValid) {
                document.getElementById('addPatientForm').submit();
            }
        }
    </script>
}