@{
    ViewData["Title"] = "Patient List";
    Layout = "_Layout2";
}
@model DEMO.ViewModels.PatientListViewModal

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Patient List</title>

    <!-- Bootstrap CSS -->
    <link href="https://stackpath.bootstrapcdn.com/bootstrap/4.5.2/css/bootstrap.min.css" rel="stylesheet">

    <!-- DataTables CSS -->
    <link rel="stylesheet" type="text/css" href="https://cdn.datatables.net/1.11.5/css/jquery.dataTables.css">

    <!-- jQuery -->
    <script type="text/javascript" charset="utf8" src="https://code.jquery.com/jquery-3.5.1.js"></script>
    <script src="https://stackpath.bootstrapcdn.com/bootstrap/4.5.2/js/bootstrap.min.js"></script>
    <script type="text/javascript" charset="utf8" src="https://cdn.datatables.net/1.11.5/js/jquery.dataTables.js"></script>

    <style>
        /* --- Page Styling --- */
        body {
            background: #f4f6fb;
            font-family: "Segoe UI", Tahoma, Geneva, Verdana, sans-serif;
        }

        /* Page Cards */
        .page-card {
            background: white;
            border-radius: 10px;
            box-shadow: 0px 4px 12px rgba(0,0,0,0.08);
            padding: 25px;
        }

        /* Page Title */
        h2 {
            font-weight: 600;
            color: #2c3e50;
        }

        /* Buttons */
        .btn-primary {
            background: #4e73df;
            border: none;
            border-radius: 6px;
        }

            .btn-primary:hover {
                background: #2e59d9;
            }

        .btn-secondary {
            border-radius: 6px;
        }

        /* Table Styling */
        table.dataTable {
            border-collapse: collapse !important;
            width: 100% !important;
        }

            table.dataTable thead {
                background: #4e73df;
                color: white;
            }

            table.dataTable tbody tr:hover {
                background: #f1f4ff;
            }

        /* DataTable search bar */
        .dataTables_filter input {
            border-radius: 6px;
            border: 1px solid #ccc;
            padding: 5px 10px;
        }

        /* Inputs */
        .form-control {
            border-radius: 6px;
        }

            .form-control:focus {
                border-color: #4e73df;
                box-shadow: 0 0 4px rgba(78,115,223,0.3);
            }

        /* Modal styling */
        .modal-content {
            border-radius: 10px;
            border: none;
            box-shadow: 0px 10px 30px rgba(0,0,0,0.2);
        }

        .modal-header {
            background: #4e73df;
            color: white;
            border-bottom: none;
        }

        .modal-title {
            font-weight: 600;
        }

        .modal-footer {
            border-top: none;
        }

        /* Radio containers */
        #SurgeryTime,
        #Theater,
        #gender {
            border-radius: 6px;
            border: 1px solid #ccc;
            background: #fafafa;
            padding: 5px;
        }

        /* Add patient modal spacing */
        .modal-body .form-group {
            margin-bottom: 20px;
        }

        /* Input validation */
        .is-valid {
            border-color: #28a745;
        }

        .is-invalid {
            border-color: #dc3545;
        }

        .text-danger {
            font-size: 12px;
        }

        /* Hover effect for buttons in table */
        .btn-group .btn {
            transition: 0.2s;
        }

            .btn-group .btn:hover {
                transform: scale(1.05);
            }
    </style>
</head>

<body>
    <div class="container">
        <main role="main" class="pb-5">

            <!-- Search & Add Patient -->
            <div class="row">
                <div class="col">
                    <div class="page-card mt-4">
                        <form id="searchForm">
                            <h2>Patient List</h2>
                            <div class="form-group row">
                                <div class="col-4">
                                    <label for="idNumber" class="form-label">ID number</label>
                                    <input type="text" class="form-control" id="idNumber" placeholder="ID number" pattern="^\d{13}$" required title="ID number must be exactly 13 digits." />
                                    <span id="idNumberError" class="text-danger"></span>
                                </div>
                            </div>
                            <div class="form-group row">
                                <div class="col-4 mt-2">
                                    <button type="button" class="btn btn-primary" style="width:160px;" data-toggle="modal" data-target="#addPatientModal">Add New Patient</button>
                                </div>
                            </div>
                        </form>
                    </div>
                </div>
            </div>

            <!-- Patient Table -->
            <div class="row">
                <div class="col">
                    <div class="page-card mt-4">
                        <table id="example" class="table display">
                            <thead>
                                <tr>
                                    <th>ID number</th>
                                    <th>Name</th>
                                    <th>Surname</th>
                                    <th>Gender</th>
                                    <th>Contact Number</th>
                                    <th>E-Mail</th>
                                    <th>Action</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var Patient in Model.AllPatients)
                                {
                                    <tr>
                                        <td>@Patient.IDNumber</td>
                                        <td>@Patient.Name</td>
                                        <td>@Patient.Surname</td>
                                        <td>@Patient.Gender</td>
                                        <td>@Patient.ContactNumber</td>
                                        <td>@Patient.Email</td>
                                        <td>
                                            <div class="w-100 btn-group" role="group">
                                                <a class="btn btn-primary"
                                                   data-toggle="modal"
                                                   data-target="#bookSurgeryModal"
                                                   data-name="@Patient.Name"
                                                   data-surname="@Patient.Surname"
                                                   data-patient-id="@Patient.PatientID">Book Surgery</a>
                                            </div>
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>
        </main>
    </div>

    <!-- Modals (Book Surgery + Add Patient) -->
    <!-- Book Surgery Modal -->
    <div class="modal fade" id="bookSurgeryModal" tabindex="-1" role="dialog" aria-hidden="true">
        <div class="modal-dialog modal-lg modal-dialog-centered" role="document">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title">Book Surgery</h5>
                    <button type="button" class="close" data-dismiss="modal"><span>&times;</span></button>
                </div>
                <div class="modal-body">
                    <form id="bookingForm" method="post" asp-action="BookSurgery" asp-controller="Home">
                        <div class="form-group row">
                            <div class="col-4">
                                <label>Name</label>
                                <input type="text" class="form-control" id="nameInput" name="Name" readonly>
                            </div>
                            <div class="col-4">
                                <label>Surname</label>
                                <input type="text" class="form-control" id="surnameInput" name="Surname" readonly>
                            </div>
                            <div class="col-4">
                                <label>Surgeon Name</label>
                                <input type="text" class="form-control" value="@ViewBag.UserName @ViewBag.UserSurname" disabled>
                            </div>
                        </div>
                        <div class="form-group row">
                            <div class="col-4">
                                <label>Theater</label> 
                                <div id="Theater" class="form-control" style="width:250px; display: inline-table; justify-content: space-around; align-items: center;">
                                    <div class="form-check"> 
                                        <input class="form-check-input" type="radio" name="Theater" id="Dove Theatre" value="Dove Theatre">
                                        <label class="form-check-label" for="Dove Theatre">Dove Theatre</label>
                                    </div> 
                                    <div class="form-check"> 
                                        <input class="form-check-input" type="radio" name="Theater" id="Eagle Theatre" value="Eagle Theatre"> 
                                        <label class="form-check-label" for="Eagle Theatre">Eagle Theatre</label> 
                                    </div>
                                    <div class="form-check">
                                        <input class="form-check-input" type="radio" name="Theater" id="Hadida Theatre" value="Hadida Theatre"> <label class="form-check-label" for="Hadida Theatre">Hadida Theatre</label>
                                    </div>
                                </div>
                            </div>
                            <div class="col-4">
                                <label>Surgery Date</label>
                                <input type="date" class="form-control" name="SurgeryDate">
                            </div>
                            <div class="col-4">
                                <label>Surgery Time</label>
                                <div id="SurgeryTime" class="form-control d-flex justify-content-around">
                                    <div class="form-check">
                                        <input class="form-check-input" type="radio" name="SurgeryTime" id="AM" value="AM">
                                        <label class="form-check-label" for="AM">AM</label>
                                    </div>
                                    <div class="form-check">
                                        <input class="form-check-input" type="radio" name="SurgeryTime" id="PM" value="PM">
                                        <label class="form-check-label" for="PM">PM</label>
                                    </div>
                                </div>
                            </div>
                        </div>
                        <input type="hidden" id="PatientID" name="PatientID">
                        <input type="hidden" id="AccountID" name="AccountID" value="@ViewBag.UserAccountID">
                        <div class="modal-footer">
                            <button type="button" id="confirmBookSurgeryButton" class="btn btn-primary">Save</button>
                            <button type="button" class="btn btn-secondary" data-dismiss="modal">Close</button>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>

    <!-- Add Patient Modal -->
    <div class="modal fade" id="addPatientModal" tabindex="-1" role="dialog" aria-hidden="true">
        <div class="modal-dialog modal-lg modal-dialog-centered">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title">Add Patient</h5>
                    <button type="button" class="close" data-dismiss="modal"><span>&times;</span></button>
                </div>
                <div class="modal-body">
                    <form id="addPatientForm" method="post" asp-action="RegisterPatient" asp-controller="Home">
                        @Html.AntiForgeryToken()
                        <div class="form-group row">
                            <div class="col-4">
                                <label>Name</label>
                                <input type="text" class="form-control" name="Name" required maxlength="100">
                                <span class="text-danger" id="nameError"></span>
                            </div>
                            <div class="col-4">
                                <label>Surname</label>
                                <input type="text" class="form-control" name="Surname" required maxlength="100">
                                <span class="text-danger" id="surnameError"></span>
                            </div>
                            <div class="col-4">
                                <label>ID Number</label>
                                <input type="number" class="form-control" name="IdNumber" required pattern="^\d{13}$" maxlength="13">
                                <span class="text-danger" id="idNumberError"></span>
                            </div>
                        </div>
                        <div class="form-group row">
                            <div class="col-4">
                                <label>Gender</label>
                                <div id="gender">
                                    <div class="form-check">
                                        <input class="form-check-input" type="radio" name="Gender" value="Male" checked>
                                        <label class="form-check-label">Male</label>
                                    </div>
                                    <div class="form-check">
                                        <input class="form-check-input" type="radio" name="Gender" value="Female">
                                        <label class="form-check-label">Female</label>
                                    </div>
                                </div>
                                <span class="text-danger" id="genderError"></span>
                            </div>
                            <div class="col-4">
                                <label>Email</label>
                                <input type="email" class="form-control" name="Email" required>
                                <span class="text-danger" id="emailError"></span>
                            </div>
                            <div class="col-4">
                                <label>Contact Number</label>
                                <input type="text" class="form-control" id="contactNumber" name="ContactNumber" required maxlength="10">
                                <span id="contactNumberError" class="text-danger"></span>
                            </div>
                        </div>
                        <div class="modal-footer">
                            <button type="button" id="mainSavePatientButton" class="btn btn-primary">Save</button>
                            <button type="button" class="btn btn-secondary" data-dismiss="modal">Close</button>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>

    <!-- Scripts -->
    <script>
        $(document).ready(function () {
            var table = $('#example').DataTable({"language":{"zeroRecords":"No matching records found"}});

            $('#mainSavePatientButton').on('click', function () {
                if($('#addPatientForm')[0].checkValidity()){
                    $('#addPatientForm').submit();
                }
            });

            $('#bookSurgeryModal').on('show.bs.modal', function (event) {
                var button = $(event.relatedTarget);
                var name = button.data('name');
                var surname = button.data('surname');
                var patientID = button.data('patient-id');

                $(this).find('#nameInput').val(name);
                $(this).find('#surnameInput').val(surname);
                $(this).find('#PatientID').val(patientID);
            });

            $('#confirmBookSurgeryButton').on('click', function () {
                $('#bookingForm').submit();
            });

            // --- ID Number Validation & Table Filter ---
            $('#idNumber').on('input', function () {
                // Only numbers
                this.value = this.value.replace(/\D/g, '');

                var val = $(this).val();

                if(val === ""){
                    // Hide all rows if empty
                    table.rows().nodes().to$().hide();
                    $(this).removeClass('is-valid is-invalid');
                    $('#idNumberError').text('');
                } else {
                    // Show table and filter
                    table.rows().nodes().to$().show();
                    table.search(val).draw();

                    if(/^\d{13}$/.test(val)){
                        $(this).removeClass('is-invalid').addClass('is-valid');
                        $('#idNumberError').text('');
                    } else {
                        $(this).removeClass('is-valid').addClass('is-invalid');
                        $('#idNumberError').text('ID number must be exactly 13 digits.');
                    }
                }
            });

            // Contact number validation
            $('#contactNumber').on('input', function () {
                $(this).val($(this).val().replace(/\D/g,''));
                if($(this).val().length !== 10){
                    $('#contactNumberError').text("Contact number must be exactly 10 digits.");
                } else {
                    $('#contactNumberError').text("");
                }
            });

            // Hide all rows on load
            table.rows().nodes().to$().hide();
        });
    </script>
</body>
</html>
