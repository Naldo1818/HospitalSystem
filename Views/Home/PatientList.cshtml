@{
    ViewData["Title"] = "Patient List";
    Layout = "_Layout2";
}
@model DEMO.ViewModels.PatientListViewModal

<div class="dashboard-container">
    <!-- Page Header -->
    <div class="d-flex justify-content-between align-items-center mb-4 flex-wrap gap-3">
        <div>
            <h1 class="fw-bold mb-1" style="color: #0f2b3d; font-size: 2rem;">
                <i class="bi bi-people-fill me-2" style="color: #4e73df;"></i>Patient Management
            </h1>
            <p class="text-secondary mb-0">Manage patient records and schedule surgical procedures</p>
        </div>
        <button type="button" class="btn btn-primary rounded-pill px-5 py-3 shadow-sm" data-bs-toggle="modal" data-bs-target="#addPatientModal">
            <i class="bi bi-plus-circle me-2"></i>Add New Patient
        </button>
    </div>

    <!-- Search Card -->
    <div class="card shadow-sm border-0 mb-4">
        <div class="card-body p-4">
            <div class="row align-items-end g-3">
                <div class="col-md-6 col-lg-5">
                    <label class="form-label fw-semibold text-secondary mb-2">
                        <i class="bi bi-search me-1"></i>Search by ID Number
                    </label>
                    <input type="text" class="form-control" id="idNumber"
                           placeholder="Enter 13-digit ID number" pattern="^\d{13}$" maxlength="13" />
                    <div id="idNumberError" class="text-danger small mt-1"></div>
                </div>
                <div class="col-md-4 col-lg-3">
                    <button type="button" class="btn btn-outline-secondary w-100" id="clearSearchBtn">
                        <i class="bi bi-x-circle me-1"></i>Clear Search
                    </button>
                </div>
            </div>
        </div>
    </div>

    <!-- Patients Table Card -->
    <div class="card shadow-sm border-0">
        <div class="card-body p-0">
            <div class="table-responsive">
                <table id="patientsTable" class="table mb-0">
                    <thead>
                        <tr>
                            <th>ID Number</th>
                            <th>Name</th>
                            <th>Surname</th>
                            <th>Gender</th>
                            <th>Email</th>
                            <th>Action</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var Patient in Model.AllPatients)
                        {
                            <tr>
                                <td class="fw-medium">@Patient.IDNumber</td>
                                <td>@Patient.Name</td>
                                <td>@Patient.Surname</td>
                                <td>
                                    <span class="badge @(Patient.Gender == "Male" ? "bg-info bg-opacity-10 text-info" : "bg-danger bg-opacity-10 text-danger") px-3 py-2 rounded-pill">
                                        <i class="bi @(Patient.Gender == "Male" ? "bi-gender-male" : "bi-gender-female") me-1"></i>@Patient.Gender
                                    </span>
                                </td>
                                <td>
                                    <a href="mailto:@Patient.Email" class="text-decoration-none email-link">@Patient.Email</a>
                                </td>
                                <td>
                                    <button type="button" class="btn btn-primary rounded-pill book-surgery-btn"
                                            data-bs-toggle="modal"
                                            data-bs-target="#bookSurgeryModal"
                                            data-name="@Patient.Name"
                                            data-surname="@Patient.Surname"
                                            data-patient-id="@Patient.PatientID">
                                        <i class="bi bi-scissors me-1"></i>Book Surgery
                                    </button>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>

<!-- Book Surgery Modal -->
<div class="modal fade" id="bookSurgeryModal" tabindex="-1" aria-labelledby="bookSurgeryModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-lg modal-dialog-centered">
        <div class="modal-content">
            <div class="modal-header border-0 pt-4 px-4">
                <h5 class="modal-title fw-bold" id="bookSurgeryModalLabel">
                    <i class="bi bi-calendar-plus me-2"></i>Schedule Surgery
                </h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body px-4 pb-2">
                <form id="bookingForm" method="post" asp-action="BookSurgery" asp-controller="Home">
                    @Html.AntiForgeryToken()

                    <!-- Patient Info Section -->
                    <div class="bg-light rounded-3 p-4 mb-4">
                        <div class="row g-3">
                            <div class="col-sm-4">
                                <label class="form-label fw-semibold text-secondary mb-2">Patient Name</label>
                                <input type="text" class="form-control bg-white" id="modalPatientName" readonly>
                            </div>
                            <div class="col-sm-4">
                                <label class="form-label fw-semibold text-secondary mb-2">Patient Surname</label>
                                <input type="text" class="form-control bg-white" id="modalPatientSurname" readonly>
                            </div>
                            <div class="col-sm-4">
                                <label class="form-label fw-semibold text-secondary mb-2">Surgeon</label>
                                <input type="text" class="form-control bg-white" value="@ViewBag.UserName @ViewBag.UserSurname" disabled>
                            </div>
                        </div>
                    </div>

                    <!-- Surgery Details -->
                    <div class="row g-4">
                        <div class="col-md-4">
                            <label class="form-label fw-semibold mb-2">Theatre <span class="text-danger">*</span></label>
                            <div class="theatre-container">
                                <div class="form-check mb-2">
                                    <input class="form-check-input" type="radio" name="Theater" id="DoveTheatre" value="Dove Theatre" required>
                                    <label class="form-check-label" for="DoveTheatre">🕊️ Dove Theatre</label>
                                </div>
                                <div class="form-check mb-2">
                                    <input class="form-check-input" type="radio" name="Theater" id="EagleTheatre" value="Eagle Theatre">
                                    <label class="form-check-label" for="EagleTheatre">🦅 Eagle Theatre</label>
                                </div>
                                <div class="form-check">
                                    <input class="form-check-input" type="radio" name="Theater" id="HadidaTheatre" value="Hadida Theatre">
                                    <label class="form-check-label" for="HadidaTheatre">🪶 Hadida Theatre</label>
                                </div>
                            </div>
                        </div>
                        <div class="col-md-4">
                            <label class="form-label fw-semibold mb-2">Surgery Date <span class="text-danger">*</span></label>
                            <input type="date" class="form-control" name="SurgeryDate" required>
                        </div>
                        <div class="col-md-4">
                            <label class="form-label fw-semibold mb-2">Time Slot <span class="text-danger">*</span></label>
                            <div class="time-slot-container">
                                <div class="form-check form-check-inline">
                                    <input class="form-check-input" type="radio" name="SurgeryTime" id="AM" value="AM" required>
                                    <label class="form-check-label" for="AM">🌅 AM</label>
                                </div>
                                <div class="form-check form-check-inline">
                                    <input class="form-check-input" type="radio" name="SurgeryTime" id="PM" value="PM">
                                    <label class="form-check-label" for="PM">🌙 PM</label>
                                </div>
                            </div>
                        </div>
                    </div>

                    <!-- Hidden fields -->
                    <input type="hidden" name="Status" value="Booked">
                    <input type="hidden" id="modalPatientID" name="PatientID">
                    <input type="hidden" id="AccountID" name="AccountID" value="@ViewBag.UserAccountID">
                </form>
            </div>
            <div class="modal-footer border-0 pb-4 px-4">
                <button type="button" class="btn btn-secondary rounded-pill px-4" data-bs-dismiss="modal">
                    <i class="bi bi-x-lg me-1"></i>Cancel
                </button>
                <button type="submit" form="bookingForm" class="btn btn-primary rounded-pill px-4">
                    <i class="bi bi-check-lg me-1"></i>Confirm Booking
                </button>
            </div>
        </div>
    </div>
</div>

<!-- Add Patient Modal - Updated Form -->
<div class="modal fade" id="addPatientModal" tabindex="-1" aria-labelledby="addPatientModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-lg modal-dialog-centered">
        <div class="modal-content">
            <div class="modal-header border-0 pt-4 px-4">
                <h5 class="modal-title fw-bold" id="addPatientModalLabel">
                    <i class="bi bi-person-plus me-2"></i>Register New Patient
                </h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body px-4 pb-2">
                <form id="addPatientForm" method="post" asp-action="RegisterPatient" asp-controller="Home">
                    @Html.AntiForgeryToken()
                    <div class="row g-3">
                        <div class="col-md-4">
                            <label class="form-label fw-semibold mb-2">First Name <span class="text-danger">*</span></label>
                            <input type="text" class="form-control" name="Name" required maxlength="100" placeholder="Enter first name">
                            <span class="text-danger small" id="nameError"></span>
                        </div>
                        <div class="col-md-4">
                            <label class="form-label fw-semibold mb-2">Last Name <span class="text-danger">*</span></label>
                            <input type="text" class="form-control" name="Surname" required maxlength="100" placeholder="Enter last name">
                            <span class="text-danger small" id="surnameError"></span>
                        </div>
                        <div class="col-md-4">
                            <label class="form-label fw-semibold mb-2">ID Number <span class="text-danger">*</span></label>
                            <input type="text" class="form-control" name="IdNumber" required pattern="^\d{13}$" maxlength="13" placeholder="13-digit ID">
                            <span class="text-danger small" id="idNumberError"></span>
                        </div>
                        <div class="col-md-4">
                            <label class="form-label fw-semibold mb-2">Gender <span class="text-danger">*</span></label>
                            <div class="gender-container">
                                <div class="form-check form-check-inline">
                                    <input class="form-check-input" type="radio" name="Gender" value="Male" checked id="genderMale">
                                    <label class="form-check-label" for="genderMale">Male</label>
                                </div>
                                <div class="form-check form-check-inline">
                                    <input class="form-check-input" type="radio" name="Gender" value="Female" id="genderFemale">
                                    <label class="form-check-label" for="genderFemale">Female</label>
                                </div>
                            </div>
                        </div>
                        <div class="col-md-8">
                            <label class="form-label fw-semibold mb-2">Email Address <span class="text-danger">*</span></label>
                            <input type="email" class="form-control" name="Email" required placeholder="patient@example.com">
                            <span class="text-danger small" id="emailError"></span>
                        </div>
                    </div>
                </form>
            </div>
            <div class="modal-footer border-0 pb-4 px-4">
                <button type="button" class="btn btn-secondary rounded-pill px-4" data-bs-dismiss="modal">
                    <i class="bi bi-x-lg me-1"></i>Cancel
                </button>
                <button type="submit" form="addPatientForm" class="btn btn-primary rounded-pill px-4">
                    <i class="bi bi-save me-1"></i>Save Patient
                </button>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script src="https://cdn.datatables.net/1.11.5/js/jquery.dataTables.js"></script>
    <script>
        $(document).ready(function () {
            // Initialize DataTable
            var table = $('#patientsTable').DataTable({
                "language": {
                    "zeroRecords": "No matching patients found",
                    "info": "Showing _START_ to _END_ of _TOTAL_ patients",
                    "infoEmpty": "No patients to show",
                    "infoFiltered": "(filtered from _MAX_ total)",
                    "search": "Search:",
                    "paginate": {
                        "previous": "<i class='bi bi-chevron-left'></i>",
                        "next": "<i class='bi bi-chevron-right'></i>"
                    }
                },
                "pageLength": 10,
                "lengthMenu": [[5, 10, 25, 50], [5, 10, 25, 50]],
                "dom": "<'row px-3 py-2'<'col-sm-12 col-md-6'l><'col-sm-12 col-md-6'f>>" +
                       "<'row'<'col-sm-12'tr>>" +
                       "<'row px-3 py-2'<'col-sm-12 col-md-5'i><'col-sm-12 col-md-7'p>>"
            });

            // Hide all rows on load
            table.rows().nodes().to$().hide();

            // ID Number Search with validation
            $('#idNumber').on('input', function () {
                this.value = this.value.replace(/\D/g, '').slice(0, 13);
                var val = $(this).val();

                if (val === "") {
                    table.rows().nodes().to$().hide();
                    $(this).removeClass('is-valid is-invalid');
                    $('#idNumberError').text('');
                } else {
                    if (/^\d{13}$/.test(val)) {
                        $(this).removeClass('is-invalid').addClass('is-valid');
                        $('#idNumberError').text('');
                        table.rows().nodes().to$().show();
                        table.search(val).draw();
                    } else {
                        $(this).removeClass('is-valid').addClass('is-invalid');
                        $('#idNumberError').text('ID number must be exactly 13 digits.');
                        table.rows().nodes().to$().hide();
                    }
                }
            });

            // Clear search button
            $('#clearSearchBtn').on('click', function () {
                $('#idNumber').val('').removeClass('is-valid is-invalid');
                $('#idNumberError').text('');
                table.rows().nodes().to$().hide();
                table.search('').draw();
            });

            // Book Surgery Modal - populate data
            var bookSurgeryModal = document.getElementById('bookSurgeryModal');
            if (bookSurgeryModal) {
                bookSurgeryModal.addEventListener('show.bs.modal', function (event) {
                    var button = event.relatedTarget;

                    // Get data from button attributes
                    var name = button.getAttribute('data-name');
                    var surname = button.getAttribute('data-surname');
                    var patientID = button.getAttribute('data-patient-id');

                    console.log('Populating modal with:', { name, surname, patientID });

                    // Populate the readonly display fields with the NEW IDs
                    var nameInput = document.getElementById('modalPatientName');
                    var surnameInput = document.getElementById('modalPatientSurname');
                    var patientIdInput = document.getElementById('modalPatientID');

                    if (nameInput) {
                        nameInput.value = name || '';
                        console.log('Name input set to:', nameInput.value);
                    } else {
                        console.error('modalPatientName element not found!');
                    }

                    if (surnameInput) {
                        surnameInput.value = surname || '';
                        console.log('Surname input set to:', surnameInput.value);
                    } else {
                        console.error('modalPatientSurname element not found!');
                    }

                    if (patientIdInput) {
                        patientIdInput.value = patientID || '';
                        console.log('PatientID set to:', patientIdInput.value);
                    } else {
                        console.error('modalPatientID element not found!');
                    }

                    // Reset radio buttons
                    var radioButtons = document.querySelectorAll('#bookSurgeryModal input[type="radio"]');
                    radioButtons.forEach(function(radio) {
                        radio.checked = false;
                    });

                    // Reset date input
                    var dateInput = document.querySelector('#bookSurgeryModal input[type="date"]');
                    if (dateInput) dateInput.value = '';
                });
            }

            // Add validation for booking form
            $('#bookingForm').on('submit', function(e) {
                var patientID = $('#modalPatientID').val();
                var theaterSelected = $('input[name="Theater"]:checked').val();
                var timeSelected = $('input[name="SurgeryTime"]:checked').val();
                var surgeryDate = $('input[name="SurgeryDate"]').val();

                console.log('Form submission - PatientID:', patientID);

                if (!patientID) {
                    alert('Patient information is missing. Please try again.');
                    e.preventDefault();
                    return false;
                }
                if (!theaterSelected) {
                    alert('Please select a theatre');
                    e.preventDefault();
                    return false;
                }
                if (!timeSelected) {
                    alert('Please select a time slot');
                    e.preventDefault();
                    return false;
                }
                if (!surgeryDate) {
                    alert('Please select a surgery date');
                    e.preventDefault();
                    return false;
                }
                return true;
            });
        });
    </script>
}
