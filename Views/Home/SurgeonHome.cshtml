@{
    ViewData["Title"] = "Surgeon";
    Layout = "_Layout2";
}
@model DEMO.ViewModels.HomeViewModel
<div class="container mt-5">

    <!-- Top Cards -->
    <div class="row g-4 justify-content-center">

        <!-- Patients -->
        <div class="col-md-4">
            <div class="card h-100 shadow-sm">
                <img src="~/css/DnP.jpeg" class="card-img-top" alt="Doctor Patient">
                <div class="card-body text-center">
                    <h5 class="card-title">Patients</h5>
                    <p class="card-text">
                        View a list of patients and book surgeries for those in need.
                    </p>
                    <a class="btn btn-primary w-100" asp-controller="Home" asp-action="PatientList">View Patients</a>
                </div>
            </div>
        </div>

        <!-- Prescriptions -->
        <div class="col-md-4">
            <div class="card h-100 shadow-sm">
                <img src="~/css/DP.jpeg" class="card-img-top" alt="Doctor Prescription">
                <div class="card-body text-center">
                    <h5 class="card-title">Prescriptions</h5>
                    <p class="card-text">
                        Check prescriptions linked to your name and track their approval status.
                    </p>
                    <a class="btn btn-primary w-100" asp-controller="Home" asp-action="PrescriptionList">View Prescriptions</a>
                </div>
            </div>
        </div>

        <!-- Admissions -->
        <div class="col-md-4">
            <div class="card h-100 shadow-sm">
                <img src="~/css/HB.jpeg" class="card-img-top" alt="Hospital Bed">
                <div class="card-body text-center">
                    <h5 class="card-title">Admissions</h5>
                    <p class="card-text">
                        View all current patient admissions, search patients, and check nurse-recorded vitals.
                    </p>
                    <a class="btn btn-primary w-100" asp-controller="Home" asp-action="patientAddmision">View Admissions</a>
                </div>
            </div>
        </div>

    </div>

    <!-- Table Section -->
    <div class="row mt-5">
        <div class="col-12">        
            <div class="p-3 border bg-white shadow-sm">
                <h3 class="mb-3 text-center">Admissions List</h3>
                <table id="example" class="table table-striped table-bordered" style="width:100%">
                    <thead class="table-dark">
                        <tr>
                            <th>Name</th>
                            <th>Surname</th>
                            <th>Surgeon Name</th>
                            <th>Surgery Date</th>
                            <th>Surgery Time</th>
                            <th>Theatre</th>
                            <th>Ward Name</th>
                            <th>Bed Number</th>
                            <th>Admitted Time</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var Data in Model.AllAdmissionsData)
                        {
                            <tr>
                                <td>@Data.Name</td>
                                <td>@Data.Surname</td>
                                <td>@ViewBag.UserName @ViewBag.UserSurname</td>
                                <td>@Data.SurgeryDate</td>
                                <td>@Data.SurgeryTime</td>
                                <td>@Data.Theater</td>
                                <td>@Data.WardName</td>
                                <td>@Data.BedNumber</td>
                                <td>@Data.Time</td>
                            </tr>
                        }
                    </tbody>
                </table>

            </div>
        </div>
    </div>


    <div class="row mt-5">
        <div class="col-12">
            <div class="p-3 border bg-white shadow-sm">
                <h3 class="mb-3 text-center">Surgery List</h3>
                <table id="example" class="table table-striped table-bordered" style="width:100%">
                    <thead class="table-dark">
                        <tr>

                            <th scope="col">Name</th>
                            <th scope="col">Surname</th>
                            <th scope="col">Surgeon Name</th>
                            <th scope="col">Surgery Date</th>
                            <th scope="col">Surgery Time</th>
                            <th scope="col">Theatre</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var Data in Model.AllSurgeryData)
                        {
                            <tr>
                                <td>@Data.Name</td>
                                <td>@Data.Surname</td>
                                <td>@ViewBag.UserName @ViewBag.UserSurname</td>
                                <td>@Data.SurgeryDate</td>
                                <td>@Data.SurgeryTime</td>
                                <td>@Data.Theater</td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>