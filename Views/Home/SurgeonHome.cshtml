@model DEMO.ViewModels.HomeViewModel
@{
    ViewData["Title"] = "Surgeon Dashboard";
    Layout = "_Layout2";
}

<div class="dashboard-container">
    <!-- Hero stats cards row -->
    <div class="row g-4 mb-5">
        <!-- Patients Card -->
        <div class="col-md-4">
            <div class="card top-card border-0 h-100" style="background: linear-gradient(145deg, #ffffff, #fefefe); border-radius: 32px;">
                <div class="card-body p-4">
                    <div class="d-flex justify-content-between align-items-start">
                        <div>
                            <span class="badge bg-primary bg-opacity-10 text-primary mb-2 px-3 py-2 rounded-pill">Overview</span>
                            <h4 class="card-title fw-bold mt-2">Patient Registry</h4>
                            <p class="text-secondary small">Manage patient data & surgical bookings</p>
                            <a class="btn btn-outline-primary rounded-pill mt-3 px-4" asp-controller="Home" asp-action="PatientList">
                                <i class="bi bi-arrow-right-circle"></i> Access List
                            </a>
                        </div>
                        <div class="bg-light rounded-4 p-3">
                            <i class="bi bi-people fs-1 text-primary"></i>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <!-- Prescriptions Card -->
        <div class="col-md-4">
            <div class="card top-card border-0 h-100" style="background: linear-gradient(145deg, #ffffff, #fefefe);">
                <div class="card-body p-4">
                    <div class="d-flex justify-content-between align-items-start">
                        <div>
                            <span class="badge bg-success bg-opacity-10 text-success mb-2 px-3 py-2 rounded-pill">Pharma</span>
                            <h4 class="card-title fw-bold">Prescriptions</h4>
                            <p class="text-secondary small">Track, review & monitor medication</p>
                            <a class="btn btn-outline-success rounded-pill mt-3 px-4" asp-controller="Home" asp-action="PrescriptionList">
                                <i class="bi bi-eye"></i> View details
                            </a>
                        </div>
                        <div class="bg-light rounded-4 p-3">
                            <i class="bi bi-capsule fs-1 text-success"></i>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <!-- Admissions Card -->
        <div class="col-md-4">
            <div class="card top-card border-0 h-100" style="background: linear-gradient(145deg, #ffffff, #fefefe);">
                <div class="card-body p-4">
                    <div class="d-flex justify-content-between align-items-start">
                        <div>
                            <span class="badge bg-warning bg-opacity-10 text-warning mb-2 px-3 py-2 rounded-pill">Inpatient</span>
                            <h4 class="card-title fw-bold">Admissions</h4>
                            <p class="text-secondary small">Active beds & vital signs</p>
                            <a class="btn btn-outline-warning rounded-pill mt-3 px-4" asp-controller="Home" asp-action="patientAddmision">
                                <i class="bi bi-hospital"></i> Wards
                            </a>
                        </div>
                        <div class="bg-light rounded-4 p-3">
                            <i class="bi bi-heart-half fs-1 text-warning"></i>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- Analytics row: Charts -->
    <div class="row g-4 mb-5">
        <div class="col-lg-6">
            <div class="card chart-card shadow-sm border-0 h-100">
                <div class="card-body p-4">
                    <div class="d-flex justify-content-between align-items-center mb-3">
                        <h5 class="fw-bold mb-0"><i class="bi bi-pie-chart-fill me-2 text-primary"></i> Prescription Status</h5>
                        <span class="badge bg-light text-dark">@(ViewBag.prescribedCount + ViewBag.dispensedCount + ViewBag.rejectedCount) total</span>
                    </div>
                    <div style="height: 280px; position: relative;">
                        <canvas id="prescriptionChart" style="max-height: 260px;"></canvas>
                    </div>
                </div>
            </div>
        </div>
        <div class="col-lg-6">
            <div class="card chart-card shadow-sm border-0 h-100">
                <div class="card-body p-4">
                    <div class="d-flex justify-content-between align-items-center mb-3">
                        <h5 class="fw-bold mb-0"><i class="bi bi-bar-chart-steps me-2 text-info"></i> Today's Surgeries (AM / PM)</h5>
                        <span class="badge bg-light text-dark">Total: @ViewBag.surgeryCount</span>
                    </div>
                    <div style="height: 280px;">
                        <canvas id="surgeryChart"></canvas>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- Admissions Table (Modern layout) -->
    <div class="row mb-5">
        <div class="col-12">
            <div class="data-table-wrapper">
                <div class="d-flex flex-wrap justify-content-between align-items-center mb-3 px-2 pt-2">
                    <h3 class="section-title mb-0"><i class="bi bi-journal-medical"></i> Active Admissions</h3>
                    <div class="search-wrapper">
                        <i class="bi bi-search position-absolute ms-3 mt-3 text-secondary"></i>
                        <input class="form-control search-input ps-5" id="searchAdmissions" placeholder="Search by name, ward, bed..." />
                    </div>
                </div>
                <div class="table-responsive">
                    <table class="table table-custom" id="admissionsTable">
                        <thead>
                            <tr>
                                <th>Patient</th>
                                <th>Surgeon</th>
                                <th>Surgery Date</th>
                                <th>Time</th>
                                <th>Theatre</th>
                                <th>Ward</th>
                                <th>Bed</th>
                                <th>Admitted</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var Data in Model.AllAdmissionsData)
                            {
                                <tr>
                                    <td><span class="fw-semibold">@Data.Name @Data.Surname</span></td>
                                    <td>Dr. @ViewBag.UserName @ViewBag.UserSurname</td>
                                    <td>@Data.SurgeryDate.ToShortDateString()</td>
                                    <td>@Data.SurgeryTime</td>
                                    <td><span class="badge bg-secondary bg-opacity-10 text-dark">@Data.Theater</span></td>
                                    <td>@Data.WardName</td>
                                    <td>@Data.BedNumber</td>
                                    <td>@Data.AdmitDate @Data.Time</td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>

    <!-- Surgery Schedule Table -->
    <div class="row">
        <div class="col-12">
            <div class="data-table-wrapper">
                <div class="d-flex flex-wrap justify-content-between align-items-center mb-3 px-2 pt-2">
                    <h3 class="section-title mb-0"><i class="bi bi-calendar2-week"></i> Upcoming Surgeries</h3>
                    <div class="search-wrapper">
                        <i class="bi bi-search position-absolute ms-3 mt-3 text-secondary"></i>
                        <input class="form-control search-input ps-5" id="searchSurgery" placeholder="Filter surgeries..." />
                    </div>
                </div>
                <div class="table-responsive">
                    <table class="table table-custom" id="surgeryTable">
                        <thead>
                            <tr><th>Patient</th><th>Surgeon</th><th>Date</th><th>Time</th><th>Theatre</th></tr>
                        </thead>
                        <tbody>
                            @foreach (var Data in Model.AllSurgeryData)
                            {
                                <tr>
                                    <td><strong>@Data.Name @Data.Surname</strong></td>
                                    <td>Dr. @ViewBag.UserName @ViewBag.UserSurname</td>
                                    <td>@Data.SurgeryDate.ToShortDateString()</td>
                                    <td><span class="badge bg-info bg-opacity-15 text-info-emphasis px-3">@Data.SurgeryTime</span></td>
                                    <td>@Data.Theater</td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
    <script>
        // Prescription pie chart
        const pieCtx = document.getElementById('prescriptionChart').getContext('2d');
        new Chart(pieCtx, {
            type: 'doughnut',
            data: {
                labels: ['Prescribed', 'Dispensed', 'Rejected'],
                datasets: [{
                    data: [@ViewBag.prescribedCount, @ViewBag.dispensedCount, @ViewBag.rejectedCount],
                    backgroundColor: ['#3b82f6', '#10b981', '#ef4444'],
                    borderWidth: 0,
                    hoverOffset: 7,
                }]
            },
            options: {
                responsive: true,
                maintainAspectRatio: true,
                plugins: { legend: { position: 'bottom', labels: { font: { size: 12 } } } }
            }
        });

        // Bar chart for Surgeries (AM/PM)
        const barCtx = document.getElementById('surgeryChart').getContext('2d');
        new Chart(barCtx, {
            type: 'bar',
            data: {
                labels: ['Morning (AM)', 'Afternoon (PM)'],
                datasets: [{
                    label: 'Surgeries',
                    data: [@ViewBag.amCount, @ViewBag.pmCount],
                    backgroundColor: ['#4f46e5', '#f59e0b'],
                    borderRadius: 12,
                    barPercentage: 0.6,
                }]
            },
            options: {
                responsive: true,
                maintainAspectRatio: true,
                scales: {
                    y: { beginAtZero: true, grid: { color: '#eef2ff' }, title: { display: true, text: 'Number of procedures' } }
                },
                plugins: { tooltip: { backgroundColor: '#0f172a' } }
            }
        });

        // Live filters
        function filterTable(inputId, tableId) {
            const input = document.getElementById(inputId);
            const filter = input.value.toLowerCase();
            const table = document.getElementById(tableId);
            const rows = table.getElementsByTagName('tbody')[0]?.getElementsByTagName('tr');
            if (!rows) return;
            for (let i = 0; i < rows.length; i++) {
                const cells = rows[i].getElementsByTagName('td');
                let visible = false;
                for (let j = 0; j < cells.length; j++) {
                    if (cells[j].innerText.toLowerCase().includes(filter)) {
                        visible = true;
                        break;
                    }
                }
                rows[i].style.display = visible ? '' : 'none';
            }
        }
        document.getElementById('searchAdmissions')?.addEventListener('keyup', () => filterTable('searchAdmissions', 'admissionsTable'));
        document.getElementById('searchSurgery')?.addEventListener('keyup', () => filterTable('searchSurgery', 'surgeryTable'));
    </script>
}