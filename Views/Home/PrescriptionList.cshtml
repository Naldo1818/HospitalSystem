@{
    ViewData["Title"] = "Prescription List";
    Layout = "_Layout2";
}
@model DEMO.ViewModels.PrescriptionListViewModal
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Prescription Management | Pharmacy Portal</title>

    <!-- Bootstrap 5 CSS (Modern) -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0-alpha1/dist/css/bootstrap.min.css" rel="stylesheet">

    <!-- Font Awesome 6 -->
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0-beta3/css/all.min.css">

    <!-- Google Fonts: Inter -->
    <link href="https://fonts.googleapis.com/css2?family=Inter:opsz,wght@14..32,300;14..32,400;14..32,500;14..32,600;14..32,700&display=swap" rel="stylesheet">

    <!-- DataTables CSS -->
    <link rel="stylesheet" type="text/css" href="https://cdn.datatables.net/1.13.4/css/jquery.dataTables.min.css">
    <link rel="stylesheet" type="text/css" href="https://cdn.datatables.net/responsive/2.4.1/css/responsive.dataTables.min.css">

    <!-- jQuery -->
    <script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>

    <!-- DataTables JS -->
    <script src="https://cdn.datatables.net/1.13.4/js/jquery.dataTables.min.js"></script>
    <script src="https://cdn.datatables.net/responsive/2.4.1/js/dataTables.responsive.min.js"></script>

    <!-- Bootstrap JS Bundle -->
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0-alpha1/dist/js/bootstrap.bundle.min.js"></script>

    <style>
        * {
            font-family: 'Inter', sans-serif;
        }

        body {
            background: linear-gradient(135deg, #f0f4f8 0%, #e8eef5 100%);
            min-height: 100vh;
        }

        /* Main container */
        .prescription-container {
            max-width: 1600px;
            margin: 0 auto;
            padding: 1.5rem;
        }

        /* Header Card */
        .header-card {
            background: white;
            border-radius: 24px;
            box-shadow: 0 8px 24px rgba(0, 0, 0, 0.06);
            padding: 1.5rem 2rem;
            margin-bottom: 2rem;
            border: 1px solid rgba(0, 0, 0, 0.04);
        }

        .page-badge {
            display: inline-flex;
            align-items: center;
            gap: 8px;
            background: #eef2ff;
            color: #1e40af;
            padding: 0.25rem 1rem;
            border-radius: 60px;
            font-size: 0.7rem;
            font-weight: 600;
            margin-bottom: 1rem;
        }

        .page-title {
            font-size: 1.8rem;
            font-weight: 700;
            color: #1e2a3e;
            margin-bottom: 0.25rem;
            display: flex;
            align-items: center;
            gap: 12px;
        }

            .page-title i {
                color: #2c7da0;
                font-size: 1.8rem;
            }

        .title-desc {
            color: #5a6e7c;
            font-size: 0.85rem;
            border-left: 3px solid #2c7da0;
            padding-left: 12px;
            margin-top: 6px;
        }

        /* Search wrapper */
        .search-wrapper {
            background: #f8fafc;
            border-radius: 60px;
            padding: 0.2rem 0.2rem 0.2rem 1.2rem;
            border: 1px solid #e2e8f0;
            transition: all 0.2s;
        }

            .search-wrapper:focus-within {
                border-color: #2c7da0;
                box-shadow: 0 0 0 3px rgba(44, 125, 160, 0.1);
            }

            .search-wrapper i {
                color: #94a3b8;
            }

        .search-input-custom {
            border: none;
            background: transparent;
            padding: 0.6rem 0;
            font-size: 0.9rem;
            width: 260px;
            outline: none;
        }

        /* Filter buttons */
        .filter-group {
            display: flex;
            flex-wrap: wrap;
            gap: 10px;
            margin-top: 1rem;
        }

        .filter-btn {
            border-radius: 40px;
            padding: 0.45rem 1.3rem;
            font-weight: 500;
            font-size: 0.8rem;
            transition: all 0.2s;
            border: 1px solid #e2e8f0;
            background: white;
            color: #334155;
        }

            .filter-btn i {
                margin-right: 6px;
            }

            .filter-btn:hover {
                background: #f1f5f9;
                border-color: #cbd5e1;
                transform: translateY(-1px);
            }

            .filter-btn.active {
                background: #2c7da0;
                border-color: #2c7da0;
                color: white;
                box-shadow: 0 4px 12px rgba(44, 125, 160, 0.25);
            }

        /* Section Cards */
        .section-card {
            background: white;
            border-radius: 24px;
            box-shadow: 0 8px 20px rgba(0, 0, 0, 0.05);
            margin-bottom: 2rem;
            overflow: hidden;
            border: 1px solid rgba(0, 0, 0, 0.05);
        }

        .section-header {
            padding: 1rem 1.5rem;
            background: #ffffff;
            border-bottom: 2px solid #f0f4f8;
            display: flex;
            align-items: center;
            justify-content: space-between;
            flex-wrap: wrap;
        }

        .section-title {
            font-size: 1.2rem;
            font-weight: 600;
            color: #0f172a;
            display: flex;
            align-items: center;
            gap: 10px;
        }

            .section-title i {
                font-size: 1.3rem;
            }

        .badge-count {
            background: #eef2ff;
            color: #1e40af;
            border-radius: 40px;
            padding: 0.2rem 0.8rem;
            font-size: 0.7rem;
            font-weight: 600;
            margin-left: 10px;
        }

        .section-content {
            padding: 0.5rem 1rem 1rem 1rem;
        }

        /* DataTables styling */
        .dataTables_wrapper .dataTables_length,
        .dataTables_wrapper .dataTables_filter {
            padding: 0.5rem 0.8rem;
        }

        table.dataTable {
            border-collapse: separate;
            border-spacing: 0;
            width: 100%;
        }

            table.dataTable thead th {
                background: #f8fafd;
                color: #1e2a3e;
                font-weight: 600;
                font-size: 0.75rem;
                text-transform: uppercase;
                letter-spacing: 0.5px;
                padding: 1rem 0.8rem;
                border-bottom: 1px solid #e2e8f0;
            }

            table.dataTable tbody td {
                padding: 0.8rem 0.8rem;
                font-size: 0.85rem;
                color: #334155;
                vertical-align: middle;
                border-bottom: 1px solid #f0f4fa;
            }

            table.dataTable tbody tr:hover td {
                background-color: #fafcff;
            }

        /* Status badges */
        .status-badge {
            display: inline-block;
            padding: 0.25rem 0.9rem;
            border-radius: 40px;
            font-size: 0.7rem;
            font-weight: 600;
        }

        .status-rejected {
            background: #fee2e2;
            color: #b91c1c;
        }

        .status-dispensed {
            background: #dcfce7;
            color: #15803d;
        }

        .status-prescribed {
            background: #fff7e5;
            color: #b45309;
        }

        /* Urgency indicators */
        .urgency-high {
            background: #fee2e2;
            color: #b91c1c;
            padding: 0.2rem 0.7rem;
            border-radius: 40px;
            font-size: 0.7rem;
            font-weight: 600;
            display: inline-block;
        }

        .urgency-normal {
            background: #e6f7ec;
            color: #15803d;
            padding: 0.2rem 0.7rem;
            border-radius: 40px;
            font-size: 0.7rem;
            font-weight: 600;
            display: inline-block;
        }

        /* Buttons */
        .btn-check-prescription {
            background: #2c7da0;
            color: white;
            border: none;
            border-radius: 40px;
            padding: 0.35rem 1rem;
            font-size: 0.75rem;
            font-weight: 500;
            transition: all 0.2s;
        }

            .btn-check-prescription:hover {
                background: #1f5e7a;
                transform: translateY(-1px);
            }

        /* Modal styling */
        .modal-content-custom {
            border-radius: 24px;
            border: none;
            box-shadow: 0 20px 40px rgba(0, 0, 0, 0.15);
        }

        .modal-header-custom {
            background: linear-gradient(135deg, #1e2a3e 0%, #0f2b3d 100%);
            color: white;
            border-radius: 24px 24px 0 0;
            padding: 1.2rem 1.8rem;
        }

            .modal-header-custom .btn-close {
                filter: invert(1);
            }

        .modal-body-custom {
            padding: 1.5rem;
        }

        .medication-table {
            font-size: 0.85rem;
        }

            .medication-table th {
                background: #f8fafc;
                font-weight: 600;
            }

        /* Rejection reason text */
        .rejection-text {
            max-width: 200px;
            white-space: normal;
            word-break: break-word;
            font-size: 0.8rem;
            color: #dc2626;
        }

        .header-card {
            padding: 1rem;
        }

        .search-input-custom {
            width: 160px;
        }

        }
    </style>
</head>
<body>
    <div class="prescription-container">
        <!-- Header Card -->
        <div class="header-card">
            <div class="page-badge">
                <i class="fas fa-prescription-bottle"></i> PHARMACY MANAGEMENT
            </div>
            <div class="page-title">
                <i class="fas fa-clipboard-list"></i> Prescription Dashboard
                <span style="font-size: 0.7rem; background: #eef2ff; padding: 3px 12px; border-radius: 60px;">Real-time Status</span>
            </div>
            <div class="title-desc">
                View and manage prescriptions by status • Track rejected, dispensed, and prescribed orders
            </div>

            <div class="row align-items-end mt-4">
                <div class="col-md-5 mb-3 mb-md-0">
                    <div class="search-wrapper d-flex align-items-center justify-content-between">
                        <i class="fas fa-search me-2"></i>
                        <input type="text" id="globalSearchInput" class="search-input-custom" placeholder="Search prescriptions...">
                        <span class="text-muted small px-2"><i class="fas fa-filter"></i></span>
                    </div>
                </div>
                <div class="col-md-7">
                    <div class="filter-group">
                        <button type="button" id="showAllBtn" class="filter-btn active">
                            <i class="fas fa-th-large"></i> All
                        </button>
                        <button type="button" id="showRejectedBtn" class="filter-btn">
                            <i class="fas fa-times-circle"></i> Rejected
                        </button>
                        <button type="button" id="showAcceptedBtn" class="filter-btn">
                            <i class="fas fa-check-circle"></i> Dispensed
                        </button>
                        <button type="button" id="showPrescribedBtn" class="filter-btn">
                            <i class="fas fa-pen-fancy"></i> Prescribed
                        </button>
                    </div>
                </div>
            </div>
        </div>

        <!-- Rejected Prescriptions Section -->
        <div class="section-card" id="rejectedSection">
            <div class="section-header">
                <div class="section-title">
                    <i class="fas fa-ban" style="color: #dc2626;"></i>
                    Rejected Prescriptions
                    <span class="badge-count" id="rejectedCount">0</span>
                </div>
                <div><i class="fas fa-info-circle text-muted small"></i> <span class="text-muted small">Requires pharmacist review</span></div>
            </div>
            <div class="section-content">
                <table id="rejectedTable" class="display" style="width:100%">
                    <thead>
                        <tr>
                            <th>Patient</th>
                            <th>Prescription Date</th>
                            <th>Pharmacist</th>
                            <th>Urgency</th>
                            <th>Status</th>
                            <th>Rejection Reason</th>
                            <th>Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var Data in Model.AllPrescribedRejected)
                        {
                            <tr>
                                <td><strong>@Data.PatientName @Data.PatientSurname</strong></td>
                                <td>@Data.DateGiven</td>
                                <td>@Data.AccountName @Data.AccountSurname</td>
                                <td>
                                    @if (Data.Urgency == "Yes")
                                    {
                                        <span class="urgency-high"><i class="fas fa-exclamation-triangle"></i> High</span>
                                    }
                                    else
                                    {
                                        <span class="urgency-normal"><i class="fas fa-clock"></i> Standard</span>
                                    }
                                </td>
                                <td><span class="status-badge status-rejected"><i class="fas fa-ban"></i> Rejected</span></td>
                                <td class="rejection-text">@Data.RejectionReason</td>
                                <td>
                                    <button class="btn-check-prescription check-prescription-btn" data-id="@Data.PrescriptionID" data-bs-toggle="modal" data-bs-target="#medicationModal">
                                        <i class="fas fa-eye"></i> View Details
                                    </button>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>

        <!-- Dispensed Prescriptions Section -->
        <div class="section-card" id="acceptedSection">
            <div class="section-header">
                <div class="section-title">
                    <i class="fas fa-capsules" style="color: #15803d;"></i>
                    Dispensed Prescriptions
                    <span class="badge-count" id="acceptedCount">0</span>
                </div>
                <div><i class="fas fa-check-circle text-muted small"></i> <span class="text-muted small">Ready for pickup</span></div>
            </div>
            <div class="section-content">
                <table id="acceptedTable" class="display" style="width:100%">
                    <thead>
                        <tr>
                            <th>Patient</th>
                            <th>Prescription Date</th>
                            <th>Pharmacist</th>
                            <th>Urgency</th>
                            <th>Status</th>
                            <th>Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var Data in Model.AllPrescribedDispensed)
                        {
                            <tr>
                                <td><strong>@Data.PatientName @Data.PatientSurname</strong></td>
                                <td>@Data.DateGiven</td>
                                <td>@Data.AccountName @Data.AccountSurname</td>
                                <td>
                                    @if (Data.Urgency == "Yes")
                                    {
                                        <span class="urgency-high"><i class="fas fa-exclamation-triangle"></i> High</span>
                                    }
                                    else
                                    {
                                        <span class="urgency-normal"><i class="fas fa-clock"></i> Standard</span>
                                    }
                                </td>
                                <td><span class="status-badge status-dispensed"><i class="fas fa-pills"></i> Dispensed</span></td>
                                <td>
                                    <button class="btn-check-prescription check-prescription-btn" data-id="@Data.PrescriptionID" data-bs-toggle="modal" data-bs-target="#medicationModal">
                                        <i class="fas fa-eye"></i> View Details
                                    </button>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>

        <!-- Prescribed Prescriptions Section -->
        <div class="section-card" id="prescribedSection">
            <div class="section-header">
                <div class="section-title">
                    <i class="fas fa-file-prescription" style="color: #f59e0b;"></i>
                    Active Prescriptions
                    <span class="badge-count" id="prescribedCount">0</span>
                </div>
                <div><i class="fas fa-hourglass-half text-muted small"></i> <span class="text-muted small">Awaiting pharmacy processing</span></div>
            </div>
            <div class="section-content">
                <table id="prescribedTable" class="display" style="width:100%">
                    <thead>
                        <tr>
                            <th>Patient</th>
                            <th>Prescription Date</th>
                            <th>Urgency</th>
                            <th>Status</th>
                            <th>Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var Data in Model.AllPrescribed)
                        {
                            <tr>
                                <td><strong>@Data.Name @Data.Surname</strong></td>
                                <td>@Data.DateGiven</td>
                                <td>
                                    @if (Data.Urgency == "Yes")
                                    {
                                        <span class="urgency-high"><i class="fas fa-exclamation-triangle"></i> High</span>
                                    }
                                    else
                                    {
                                        <span class="urgency-normal"><i class="fas fa-clock"></i> Standard</span>
                                    }
                                </td>
                                <td><span class="status-badge status-prescribed"><i class="fas fa-pen-fancy"></i> Prescribed</span></td>
                                <td>
                                    <button class="btn-check-prescription check-prescription-btn" data-id="@Data.PrescriptionID" data-bs-toggle="modal" data-bs-target="#medicationModal">
                                        <i class="fas fa-eye"></i> View Details
                                    </button>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>

    <!-- Medication Details Modal -->
    <div class="modal fade" id="medicationModal" tabindex="-1" aria-labelledby="medicationModalLabel" aria-hidden="true">
        <div class="modal-dialog modal-lg modal-dialog-centered">
            <div class="modal-content modal-content-custom">
                <div class="modal-header modal-header-custom">
                    <h5 class="modal-title" id="medicationModalLabel">
                        <i class="fas fa-capsules me-2"></i> Prescription Details
                    </h5>
                    <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal" aria-label="Close"></button>
                </div>
                <div class="modal-body modal-body-custom">
                    <div class="table-responsive">
                        <table class="table medication-table" id="medicationDetailsTable" style="width:100%">
                            <thead>
                                <tr>
                                    <th>Patient</th>
                                    <th>Surname</th>
                                    <th>Date</th>
                                    <th>Medication</th>
                                    <th>Qty</th>
                                    <th>Schedule</th>
                                    <th>Form</th>
                                    <th>Instructions</th>
                                </tr>
                            </thead>
                            <tbody id="medicationDetailsBody">
                                <!-- Dynamic content -->
                            </tbody>
                        </table>
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" id="changeMedicationBtn" class="btn btn-primary" style="display:none; border-radius: 40px; background: #2c7da0;">
                        <i class="fas fa-edit"></i> Change Medication
                    </button>
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal" style="border-radius: 40px;">Close</button>
                </div>
            </div>
        </div>
    </div>

    <script>
        $(document).ready(function () {
            // Initialize DataTables
            var rejectedTable = $('#rejectedTable').DataTable({
                responsive: true,
                pageLength: 8,
                language: { zeroRecords: "No rejected prescriptions", search: "", infoEmpty: "No entries" },
                dom: '<"top"f>rt<"bottom"lip>',
                columnDefs: [{ orderable: false, targets: 6 }]
            });

            var acceptedTable = $('#acceptedTable').DataTable({
                responsive: true,
                pageLength: 8,
                language: { zeroRecords: "No dispensed prescriptions", search: "", infoEmpty: "No entries" },
                dom: '<"top"f>rt<"bottom"lip>',
                columnDefs: [{ orderable: false, targets: 5 }]
            });

            var prescribedTable = $('#prescribedTable').DataTable({
                responsive: true,
                pageLength: 8,
                language: { zeroRecords: "No active prescriptions", search: "", infoEmpty: "No entries" },
                dom: '<"top"f>rt<"bottom"lip>',
                columnDefs: [{ orderable: false, targets: 4 }]
            });

            // Hide default DataTables search inputs
            $('.dataTables_filter').hide();

            // Update badge counts
            function updateCounts() {
                $('#rejectedCount').text(rejectedTable.page.info().recordsDisplay);
                $('#acceptedCount').text(acceptedTable.page.info().recordsDisplay);
                $('#prescribedCount').text(prescribedTable.page.info().recordsDisplay);
            }

            // Filter visibility functions
            function showAll() {
                $('#rejectedSection').fadeIn(200);
                $('#acceptedSection').fadeIn(200);
                $('#prescribedSection').fadeIn(200);
                $('.filter-btn').removeClass('active');
                $('#showAllBtn').addClass('active');
                updateCounts();
            }

            function showRejected() {
                $('#rejectedSection').fadeIn(200);
                $('#acceptedSection').fadeOut(150);
                $('#prescribedSection').fadeOut(150);
                $('.filter-btn').removeClass('active');
                $('#showRejectedBtn').addClass('active');
                updateCounts();
            }

            function showAccepted() {
                $('#acceptedSection').fadeIn(200);
                $('#rejectedSection').fadeOut(150);
                $('#prescribedSection').fadeOut(150);
                $('.filter-btn').removeClass('active');
                $('#showAcceptedBtn').addClass('active');
                updateCounts();
            }

            function showPrescribed() {
                $('#prescribedSection').fadeIn(200);
                $('#rejectedSection').fadeOut(150);
                $('#acceptedSection').fadeOut(150);
                $('.filter-btn').removeClass('active');
                $('#showPrescribedBtn').addClass('active');
                updateCounts();
            }

            // Global search across all tables
            $('#globalSearchInput').on('keyup', function () {
                var searchVal = this.value.trim();
                rejectedTable.search(searchVal).draw();
                acceptedTable.search(searchVal).draw();
                prescribedTable.search(searchVal).draw();
                updateCounts();

                // Check which filter is active
                if ($('#showRejectedBtn').hasClass('active')) {
                    if (rejectedTable.page.info().recordsDisplay === 0) $('#rejectedSection').hide();
                    else $('#rejectedSection').show();
                } else if ($('#showAcceptedBtn').hasClass('active')) {
                    if (acceptedTable.page.info().recordsDisplay === 0) $('#acceptedSection').hide();
                    else $('#acceptedSection').show();
                } else if ($('#showPrescribedBtn').hasClass('active')) {
                    if (prescribedTable.page.info().recordsDisplay === 0) $('#prescribedSection').hide();
                    else $('#prescribedSection').show();
                } else {
                    // Show/hide sections based on search results
                    $('#rejectedSection').toggle(rejectedTable.page.info().recordsDisplay > 0);
                    $('#acceptedSection').toggle(acceptedTable.page.info().recordsDisplay > 0);
                    $('#prescribedSection').toggle(prescribedTable.page.info().recordsDisplay > 0);
                }
            });

            // Button click handlers
            $('#showAllBtn').on('click', showAll);
            $('#showRejectedBtn').on('click', showRejected);
            $('#showAcceptedBtn').on('click', showAccepted);
            $('#showPrescribedBtn').on('click', showPrescribed);

            // Initially show all
            showAll();

            // Handle "Check Prescription" button clicks
            let currentPrescriptionId = null;

            $(document).on('click', '.check-prescription-btn', function () {
                currentPrescriptionId = $(this).data('id');
                $('#medicationDetailsBody').empty();

                let lastName = '', lastSurname = '', lastDate = '';

                $.ajax({
                    url: '@Url.Action("PrescriptionDetails", "Home")',
                    type: 'POST',
                    data: { id: currentPrescriptionId },
                    success: function (data) {
                        if (data && data.length > 0) {
                            $.each(data, function (index, item) {
                                let row = '<tr>';

                                if (item.name !== lastName || item.surname !== lastSurname || item.dateGiven !== lastDate) {
                                    row += '<td><strong>' + (item.name || '') + '</strong></td>';
                                    row += '<td><strong>' + (item.surname || '') + '</strong></td>';
                                    row += '<td>' + (item.dateGiven || '') + '</td>';
                                    lastName = item.name;
                                    lastSurname = item.surname;
                                    lastDate = item.dateGiven;
                                } else {
                                    row += '<td></td><td></td><td></td>';
                                }

                                row += '<td>' + (item.medicationName || '') + '</td>';
                                row += '<td>' + (item.quantity || '') + '</td>';
                                row += '<td>' + (item.schedule || '') + '</td>';
                                row += '<td>' + (item.medicationForm || '') + '</td>';
                                row += '<td>' + (item.instructions || '') + '</td>';
                                row += '</tr>';

                                $('#medicationDetailsBody').append(row);
                            });

                            // Show Change Medication button only for non-dispensed prescriptions
                            var isDispensed = $(this).closest('#acceptedSection').length > 0;
                            if (!isDispensed) {
                                $('#changeMedicationBtn').data('prescription-id', currentPrescriptionId).show();
                            } else {
                                $('#changeMedicationBtn').hide();
                            }
                        } else {
                            $('#medicationDetailsBody').html('<tr><td colspan="8" class="text-center text-muted">No medication details found</td></tr>');
                            $('#changeMedicationBtn').hide();
                        }
                    },
                    error: function () {
                        $('#medicationDetailsBody').html('<tr><td colspan="8" class="text-center text-danger">Error loading prescription details</td></tr>');
                        $('#changeMedicationBtn').hide();
                    }
                });
            });

            // Handle Change Medication button
            $('#changeMedicationBtn').click(function () {
                let prescriptionId = $(this).data('prescription-id');
                if (prescriptionId) {
                    window.location.href = '@Url.Action("PrescriptionMedication", "Home")/' + prescriptionId;
                }
            });

            // Refresh counts after table draws
            rejectedTable.on('draw', updateCounts);
            acceptedTable.on('draw', updateCounts);
            prescribedTable.on('draw', updateCounts);
        });
    </script>
</body>
</html>

