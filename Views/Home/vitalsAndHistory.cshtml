@{
    ViewData["Title"] = "Vitals And History";
    Layout = "_Layout2";
}
@model DEMO.ViewModels.PatientAllergyViewModel
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, user-scalable=yes">
    <title>Vitals & Medical History | Patient Clinical Summary</title>

    <!-- Google Fonts + Font Awesome -->
    <link href="https://fonts.googleapis.com/css2?family=Inter:opsz,wght@14..32,300;14..32,400;14..32,500;14..32,600;14..32,700&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0-beta3/css/all.min.css">

    <!-- jQuery -->
    <script src="https://code.jquery.com/jquery-3.7.1.min.js" integrity="sha256-/JqT3SQfawRcv/BIHPThkBvs0OEvtFFmqPF/lYI/Cxo=" crossorigin="anonymous"></script>

    <!-- Bootstrap 5.3 -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0-alpha1/dist/css/bootstrap.min.css" rel="stylesheet">
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0-alpha1/dist/js/bootstrap.bundle.min.js"></script>

    <!-- DataTables -->
    <link rel="stylesheet" href="https://cdn.datatables.net/1.13.4/css/dataTables.bootstrap5.min.css">
    <script src="https://cdn.datatables.net/1.13.4/js/jquery.dataTables.min.js"></script>
    <script src="https://cdn.datatables.net/1.13.4/js/dataTables.bootstrap5.min.js"></script>

    <style>
        * {
            font-family: 'Inter', sans-serif;
        }

        body {
            background: #f4f7fc;
            margin: 0;
            padding: 0;
        }

        .main-container {
            max-width: 1600px;
            margin: 0 auto;
            padding: 1.8rem 1.5rem;
        }

        /* modern card style */
        .modern-card {
            background: #ffffff;
            border-radius: 28px;
            box-shadow: 0 12px 28px rgba(0, 0, 0, 0.04), 0 0 1px rgba(0, 0, 0, 0.03);
            transition: all 0.2s ease;
            border: none;
            overflow: hidden;
        }

        .card-header-custom {
            background: white;
            padding: 1.2rem 1.8rem 0.6rem 1.8rem;
            border-bottom: 2px solid #eef2fa;
        }

        .card-body-custom {
            padding: 1.6rem 1.8rem 1.8rem 1.8rem;
        }

        .page-title {
            font-weight: 700;
            font-size: 1.8rem;
            letter-spacing: -0.3px;
            background: linear-gradient(135deg, #1f4870, #1b3b5c);
            background-clip: text;
            -webkit-background-clip: text;
            color: transparent;
            margin-bottom: 0;
        }

        .patient-badge {
            background-color: #eef2ff;
            padding: 6px 16px;
            border-radius: 40px;
            font-size: 0.85rem;
            font-weight: 500;
            color: #1e3a8a;
            display: inline-flex;
            align-items: center;
            gap: 8px;
        }

        /* section headers */
        .section-header {
            display: flex;
            align-items: center;
            gap: 12px;
            margin-bottom: 1.2rem;
            padding-bottom: 0.5rem;
            border-bottom: 2px solid #eef2fa;
        }

            .section-header i {
                font-size: 1.4rem;
                color: #2c7da0;
            }

            .section-header h3 {
                font-size: 1.2rem;
                font-weight: 700;
                margin: 0;
                color: #1f3b4c;
            }

        .info-grid {
            background: #f8fafd;
            border-radius: 20px;
            padding: 1rem;
            margin-bottom: 1.5rem;
        }

        /* table styling */
        .data-table-wrapper {
            overflow-x: auto;
            border-radius: 20px;
            margin-bottom: 2rem;
        }

        .table-vitals {
            width: 100%;
            margin-bottom: 0;
            font-size: 0.8rem;
        }

            .table-vitals th {
                background: #f8fafd;
                color: #1f3b4c;
                font-weight: 600;
                font-size: 0.7rem;
                padding: 0.9rem 0.6rem;
                border-bottom: 1px solid #e9edf2;
                white-space: nowrap;
            }

            .table-vitals td {
                padding: 0.7rem 0.6rem;
                vertical-align: middle;
                border-bottom: 1px solid #f0f2f7;
                color: #1f2f3e;
            }

        .badge-bmi {
            background: #eef2ff;
            color: #1f4870;
            border-radius: 40px;
            padding: 4px 10px;
            font-size: 0.7rem;
            font-weight: 600;
            display: inline-block;
        }

        /* simple info tables */
        .info-table {
            width: 100%;
            background: #fefefe;
            border-radius: 20px;
            overflow: hidden;
        }

            .info-table td {
                padding: 12px 16px;
                border-bottom: 1px solid #f0f2f7;
                font-size: 0.9rem;
            }

            .info-table tr:last-child td {
                border-bottom: none;
            }

            .info-table td:first-child {
                font-weight: 600;
                color: #4a627a;
                width: 180px;
            }

        .empty-state-small {
            text-align: center;
            padding: 1.5rem;
            background: #fafcff;
            border-radius: 20px;
            color: #8ba0bc;
            font-size: 0.85rem;
        }

        hr.divider-light {
            margin: 1.5rem 0;
            background: #eef2fa;
            height: 1px;
            opacity: 0.5;
        }

        .btn-back {
            background: white;
            border: 1px solid #cbd5e1;
            border-radius: 40px;
            padding: 0.55rem 1.5rem;
            font-weight: 500;
            transition: 0.2s;
        }

            .btn-back:hover {
                background: #f8fafc;
                border-color: #94a3b8;
            }

        .info-table td:first-child {
            width: 120px;
        }

        }
    </style>
</head>
<body>

    <div class="main-container">
        <main role="main">
            <!-- Header -->
            <div class="d-flex flex-wrap justify-content-between align-items-center mb-4">
                <div>
                    <h1 class="page-title"><i class="fas fa-chart-line me-2" style="color:#e67e22;"></i> Vitals & Medical History</h1>
                    <div class="mt-2">
                        <span class="patient-badge">
                            <i class="fas fa-user-injured me-1"></i> @ViewBag.PatientName @ViewBag.PatientSurname
                        </span>
                        <span class="badge bg-light text-dark ms-2 rounded-pill">
                            <i class="far fa-id-card"></i> Patient ID: @ViewBag.PatientID
                        </span>
                    </div>
                    <p class="text-muted small mt-2 mb-0">Complete clinical summary including vitals history, medications, allergies, and medical conditions</p>
                </div>
                <div class="mt-2 mt-sm-0">
                    <a href="@Url.Action("AdmissionsList", "Home")" class="btn btn-back">
                        <i class="fas fa-arrow-left me-2"></i>Back to Admissions
                    </a>
                </div>
            </div>

            <!-- Vitals History Card -->
            <div class="modern-card mb-4">
                <div class="card-header-custom">
                    <div class="section-header" style="margin-bottom: 0; border-bottom: none; padding-bottom: 0;">
                        <i class="fas fa-heartbeat"></i>
                        <h3>Vitals History</h3>
                        <span class="badge bg-light text-dark rounded-pill ms-2">@Model.Allvitals.Count records</span>
                    </div>
                </div>
                <div class="card-body-custom">
                    @if (Model.Allvitals != null && Model.Allvitals.Any())
                    {
                        <div class="data-table-wrapper">
                            <table id="vitalsTable" class="table table-vitals">
                                <thead>
                                    <tr>
                                        <th>Date</th>
                                        <th>Time</th>
                                        <th>Height (cm)</th>
                                        <th>Weight (kg)</th>
                                        <th>BMI</th>
                                        <th>Systolic BP</th>
                                        <th>Diastolic BP</th>
                                        <th>Heart Rate</th>
                                        <th>SpO₂ (%)</th>
                                        <th>Respiration</th>
                                        <th>Glucose (mg/dL)</th>
                                        <th>Temp (°C)</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach (var item in Model.Allvitals)
                                    {
                                        <tr>
                                            <td>@item.Date</td>
                                            <td>@item.Time</td>
                                            <td>@item.Height</td>
                                            <td>@item.Weight</td>
                                            @{
                                                double heightInMeters = item.Height / 100.0;
                                                double bmi = heightInMeters > 0 ? item.Weight / (heightInMeters * heightInMeters) : 0;
                                            }
                                            <td><span class="badge-bmi">@Math.Round(bmi, 1)</span></td>
                                            <td>@item.SystolicBloodPressure</td>
                                            <td>@item.DiastolicBloodPressure</td>
                                            <td>@item.HeartRate</td>
                                            <td>@item.BloodOxygen</td>
                                            <td>@item.Respiration</td>
                                            <td>@item.BloodGlucoseLevel</td>
                                            <td>@item.Temperature</td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>
                    }
                    else
                    {
                        <div class="empty-state-small">
                            <i class="fas fa-chart-line fa-2x mb-2 d-block text-muted"></i>
                            No vital records available for this patient.
                        </div>
                    }
                </div>
            </div>

            <!-- Clinical Summary Grid: Medications, Allergies, Conditions -->
            <div class="row g-4">
                <!-- Current Medications -->
                <div class="col-md-4">
                    <div class="modern-card h-100">
                        <div class="card-header-custom">
                            <div class="section-header" style="margin-bottom: 0; border-bottom: none;">
                                <i class="fas fa-pills" style="color:#1f7b4d;"></i>
                                <h3>Current Medications</h3>
                            </div>
                        </div>
                        <div class="card-body-custom">
                            @if (Model.AllCurrentMed != null && Model.AllCurrentMed.Any())
                            {
                                <div class="info-grid" style="background: transparent; padding: 0;">
                                    <table class="info-table">
                                        <tbody>
                                            @foreach (var item in Model.AllCurrentMed)
                                            {
                                                <tr>
                                                    <td><i class="fas fa-capsules me-2 text-muted"></i> @item.MedicationName</td>
                                                </tr>
                                            }
                                        </tbody>
                                    </table>
                                </div>
                            }
                            else
                            {
                                <div class="empty-state-small">
                                    <i class="fas fa-prescription-bottle fa-2x mb-2 d-block text-muted"></i>
                                    No current medications recorded.
                                </div>
                            }
                        </div>
                    </div>
                </div>

                <!-- Allergies -->
                <div class="col-md-4">
                    <div class="modern-card h-100">
                        <div class="card-header-custom">
                            <div class="section-header" style="margin-bottom: 0; border-bottom: none;">
                                <i class="fas fa-allergies" style="color:#e67e22;"></i>
                                <h3>Allergies</h3>
                            </div>
                        </div>
                        <div class="card-body-custom">
                            @if (Model.Allallergy != null && Model.Allallergy.Any())
                            {
                                <div class="info-grid" style="background: transparent; padding: 0;">
                                    <table class="info-table">
                                        <tbody>
                                            @foreach (var item in Model.Allallergy)
                                            {
                                                <tr>
                                                    <td><i class="fas fa-exclamation-triangle me-2 text-warning"></i> @item.ActiveIngredientName</td>
                                                </tr>
                                            }
                                        </tbody>
                                    </table>
                                </div>
                            }
                            else
                            {
                                <div class="empty-state-small">
                                    <i class="fas fa-smile fa-2x mb-2 d-block text-muted"></i>
                                    No known allergies.
                                </div>
                            }
                        </div>
                    </div>
                </div>

                <!-- Medical Conditions -->
                <div class="col-md-4">
                    <div class="modern-card h-100">
                        <div class="card-header-custom">
                            <div class="section-header" style="margin-bottom: 0; border-bottom: none;">
                                <i class="fas fa-notes-medical" style="color:#2c7da0;"></i>
                                <h3>Medical Conditions</h3>
                            </div>
                        </div>
                        <div class="card-body-custom">
                            @if (Model.AllConditions != null && Model.AllConditions.Any())
                            {
                                <div class="info-grid" style="background: transparent; padding: 0;">
                                    <table class="info-table">
                                        <tbody>
                                            @foreach (var item in Model.AllConditions)
                                            {
                                                <tr>
                                                    <td><i class="fas fa-diagnoses me-2 text-info"></i> @item.ConditionName</td>
                                                </tr>
                                            }
                                        </tbody>
                                    </table>
                                </div>
                            }
                            else
                            {
                                <div class="empty-state-small">
                                    <i class="fas fa-file-medical fa-2x mb-2 d-block text-muted"></i>
                                    No medical conditions recorded.
                                </div>
                            }
                        </div>
                    </div>
                </div>
            </div>

            <!-- Footer with back action -->
            <div class="mt-4 d-flex justify-content-end">
                <a href="@Url.Action("AdmissionsList", "Home")" class="btn btn-back">
                    <i class="fas fa-arrow-left me-2"></i>Return to Admissions List
                </a>
            </div>
        </main>
    </div>

    <script>
        $(document).ready(function () {
            // Initialize DataTable for vitals with responsive settings
            $('#vitalsTable').DataTable({
                "pageLength": 8,
                "lengthMenu": [[5, 8, 10, 15], [5, 8, 10, 15]],
                "language": {
                    "zeroRecords": "No vitals records found",
                    "info": "Showing _START_ to _END_ of _TOTAL_ entries",
                    "search": "Filter:",
                    "paginate": {
                        "previous": "<i class='fas fa-chevron-left'></i>",
                        "next": "<i class='fas fa-chevron-right'></i>"
                    }
                },
                "order": [[0, 'desc'], [1, 'desc']], // sort by date desc, then time desc
                "scrollX": true,
                "autoWidth": false
            });
        });
    </script>

</body>
</html>
