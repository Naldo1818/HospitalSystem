@using Microsoft.AspNetCore.Http
@{
    var userName = Context.Session.GetString("UserName");
    var userSurname = Context.Session.GetString("UserSurname");
    var userEmail = Context.Session.GetString("UserEmail");
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, user-scalable=yes">
    <title>Apollo+ | Nurse Hub</title>
    <!-- Bootstrap 5 + Icons + Fonts -->
    <link href="https://cdnjs.cloudflare.com/ajax/libs/bootstrap/5.3.0/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.1/font/bootstrap-icons.css">
    <link href="https://fonts.googleapis.com/css2?family=Inter:opsz,wght@14..32,300;14..32,400;14..32,500;14..32,600;14..32,700&display=swap" rel="stylesheet">
    <link href="~/css/site2.css" rel="stylesheet">
    <style>
        /* ---------- GLOBAL RESET & ENHANCED DASHBOARD ---------- */
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }

        body {
            font-family: 'Inter', system-ui, -apple-system, 'Segoe UI', Roboto, sans-serif;
            background: #f0f4f9;
            overflow-x: hidden;
        }

        /* modern navbar */
        .app-navbar {
            background: #ffffff;
            backdrop-filter: blur(0px);
            box-shadow: 0 4px 20px rgba(0, 0, 0, 0.02), 0 1px 2px rgba(0, 0, 0, 0.03);
            height: 68px;
            display: flex;
            align-items: center;
            padding: 0 32px;
            justify-content: space-between;
            position: fixed;
            top: 0;
            left: 0;
            right: 0;
            z-index: 200;
            border-bottom: 1px solid #e9edf2;
        }

            .app-navbar .brand {
                background: linear-gradient(135deg, #0b5c4a, #1e7658);
                background-clip: text;
                -webkit-background-clip: text;
                color: transparent;
                font-size: 24px;
                font-weight: 700;
                letter-spacing: -0.3px;
                text-decoration: none;
            }

            .app-navbar .welcome {
                color: #2c3e50;
                font-size: 14px;
                font-weight: 500;
                background: #f1f5f9;
                padding: 6px 14px;
                border-radius: 40px;
            }

        /* sidebar premium - NARROWER */
        .app-sidebar {
            width: 220px;
            background: #ffffff;
            position: fixed;
            top: 68px;
            bottom: 0;
            left: 0;
            padding: 20px 8px;
            z-index: 100;
            overflow-y: auto;
            border-right: 1px solid #eef2f6;
            box-shadow: 2px 0 12px rgba(0, 0, 0, 0.02);
        }

            .app-sidebar .nav-section-label {
                padding: 0 14px;
                font-size: 10px;
                font-weight: 600;
                color: #5b6e8c;
                letter-spacing: 0.5px;
                text-transform: uppercase;
                margin: 14px 0 6px 0;
            }

            .app-sidebar .nav-link {
                display: flex;
                align-items: center;
                gap: 10px;
                padding: 9px 14px;
                color: #334155;
                font-size: 13px;
                font-weight: 500;
                border-radius: 10px;
                margin: 3px 6px;
                transition: all 0.2s ease;
                text-decoration: none;
            }

                .app-sidebar .nav-link i {
                    font-size: 1.1rem;
                    width: 22px;
                    color: #5b6e8c;
                }

                .app-sidebar .nav-link:hover {
                    background: #f1f5fe;
                    color: #1e7658;
                    transform: translateX(2px);
                }

                .app-sidebar .nav-link.active {
                    background: #e6f7f0;
                    color: #0d9488;
                    border-left: 3px solid #0d9488;
                }

            .app-sidebar .nav-divider {
                height: 1px;
                background: #e9edf2;
                margin: 14px 10px;
            }

        /* main area - MORE SPACE */
        .app-main {
            margin-left: 220px;
            margin-top: 68px;
            padding: 20px 24px;
            min-height: calc(100vh - 68px);
            background: #f8fafc;
        }

        /* Profile card - right sidebar */
        .profile-sidebar-card {
            background: white;
            border-radius: 28px;
            border: 1px solid #eef2f8;
            overflow: hidden;
            width: 260px;
            flex-shrink: 0;
            box-shadow: 0 8px 20px rgba(0, 0, 0, 0.02);
            transition: all 0.2s;
        }

            .profile-sidebar-card .p-header {
                background: linear-gradient(145deg, #1e473a, #0f3d2b);
                padding: 24px 16px;
                text-align: center;
            }

            .profile-sidebar-card .p-avatar {
                width: 70px;
                height: 70px;
                border-radius: 50%;
                background: rgba(255,255,255,0.2);
                backdrop-filter: blur(4px);
                display: flex;
                align-items: center;
                justify-content: center;
                font-size: 28px;
                font-weight: 600;
                color: white;
                margin: 0 auto 12px;
                border: 2px solid rgba(255,255,240,0.5);
            }

            .profile-sidebar-card .p-name {
                color: white;
                font-size: 16px;
                font-weight: 700;
            }

            .profile-sidebar-card .p-email {
                color: #cbd5e6;
                font-size: 12px;
                margin-top: 6px;
                word-break: break-all;
            }

            .profile-sidebar-card .p-body {
                padding: 20px 18px;
            }

        .p-stat {
            display: flex;
            justify-content: space-between;
            align-items: center;
            margin-bottom: 12px;
            font-size: 13px;
            font-weight: 500;
            color: #1e293b;
        }

            .p-stat .badge-stat {
                background: #f1f5f9;
                padding: 4px 12px;
                border-radius: 40px;
                font-weight: 600;
                font-size: 12px;
            }

        .btn-logout {
            display: block;
            margin: 8px 16px 20px;
            padding: 8px;
            text-align: center;
            border: 1px solid #ffcdd2;
            color: #c62828;
            border-radius: 60px;
            font-size: 13px;
            font-weight: 500;
            background: #fff5f5;
            text-decoration: none;
            transition: all 0.2s;
        }

            .btn-logout:hover {
                background: #ffebee;
                color: #b71c1c;
                border-color: #ef9a9a;
            }

        /* Mobile sidebar toggle button */
        .sidebar-toggle-mobile {
            display: none;
            background: none;
            border: none;
            font-size: 1.5rem;
            color: #334155;
            cursor: pointer;
            padding: 4px 8px;
        }

        @@media (max-width: 1200px) {
            .profile-sidebar-card {
                width: 230px;
            }
        }

        @@media (max-width: 1024px) {
            .app-main {
                padding: 16px 16px;
            }

            .profile-sidebar-card {
                width: 210px;
            }

            .app-sidebar {
                width: 200px;
            }

            .app-main {
                margin-left: 200px;
            }
        }

        @@media (max-width: 768px) {
            .sidebar-toggle-mobile {
                display: block;
            }

            .app-sidebar {
                transform: translateX(-100%);
                transition: transform 0.3s ease;
                z-index: 300;
                box-shadow: 4px 0 20px rgba(0,0,0,0.15);
                width: 260px;
            }

                .app-sidebar.mobile-open {
                    transform: translateX(0);
                }

            .app-main {
                margin-left: 0;
                padding: 12px 12px;
            }

            .profile-sidebar-card {
                display: none;
            }

            .app-navbar .brand {
                font-size: 20px;
            }
        }

        /* Overlay for mobile sidebar */
        .sidebar-overlay {
            display: none;
            position: fixed;
            top: 0;
            left: 0;
            right: 0;
            bottom: 0;
            background: rgba(0,0,0,0.5);
            z-index: 250;
        }

            .sidebar-overlay.active {
                display: block;
            }

        /* ---------- UTILITY: Hide profile card on specific pages ---------- */
        .hide-profile-card .profile-sidebar-card {
            display: none !important;
        }

        .hide-profile-card .app-main .d-flex.gap-4 > div:first-child {
            flex: 1 1 100% !important;
            max-width: 100% !important;
        }
    </style>
</head>
<body>

    <!-- Mobile Sidebar Overlay -->
    <div class="sidebar-overlay" id="sidebarOverlay"></div>

    <nav class="app-navbar">
        <div class="d-flex align-items-center gap-3">
            <button class="sidebar-toggle-mobile" id="sidebarToggleMobile" aria-label="Toggle sidebar">
                <i class="bi bi-list"></i>
            </button>
            <span class="welcome">
                <i class="bi bi-calendar-check"></i> Welcome back,
                <strong style="color:#0f3d2b;">Nurse @ViewBag.UserName @ViewBag.UserSurname</strong>
            </span>
        </div>
        <a class="brand" href="#"><i class="bi bi-heart-pulse-fill" style="color:#0d9488;"></i> Apollo+</a>
    </nav>

    <aside class="app-sidebar" id="appSidebar">
        <span class="nav-section-label">Main</span>
        <a class="nav-link active" asp-controller="Nurse" asp-action="MainPage">
            <i class="bi bi-grid-1x2-fill"></i> Dashboard
        </a>
        <a class="nav-link" asp-controller="Nurse" asp-action="ViewSurgeryBooking">
            <i class="bi bi-scissors"></i> Surgery Bookings
        </a>
        <a class="nav-link" asp-controller="Nurse" asp-action="AdmittedPatients">
            <i class="bi bi-hospital-fill"></i> Admitted Patients
        </a>
        <a class="nav-link" asp-controller="Nurse" asp-action="PrescriptionList">
            <i class="bi bi-capsule"></i> Prescriptions
        </a>
        <div class="nav-divider"></div>
        <span class="nav-section-label">Management</span>
        <a class="nav-link" asp-controller="Nurse" asp-action="NurseReport">
            <i class="bi bi-bar-chart-steps"></i> Reports
        </a>
        <a class="nav-link" asp-controller="Nurse" asp-action="InfoNurse">
            <i class="bi bi-info-circle"></i> Hospital Information
        </a>
    </aside>

    <main class="app-main">
        <div class="d-flex gap-4 align-items-start flex-wrap">
            <div style="flex: 1; min-width: 0;">
                @RenderBody()
            </div>
            <div class="profile-sidebar-card">
                <div class="p-header">
                    <div class="p-avatar">@ViewBag.UserName?.Substring(0, 1)@ViewBag.UserSurname?.Substring(0, 1)</div>
                    <div class="p-name">@ViewBag.UserName @ViewBag.UserSurname</div>
                    <div class="p-email">@ViewBag.UserEmail</div>
                </div>
                <div class="p-body">
                    <div class="p-section fw-semibold text-uppercase small text-secondary mb-3">Patient Admissions</div>
                    <div class="p-stat">
                        <span><i class="bi bi-person-plus me-1"></i> Admitted</span>
                        <span class="badge-stat">@ViewBag.AdmittedCount</span>
                    </div>
                    <div class="p-stat">
                        <span><i class="bi bi-clipboard-check me-1"></i> Discharged</span>
                        <span class="badge-stat">@ViewBag.DischargedCount</span>
                    </div>
                    <div class="nav-divider" style="margin: 12px 0;"></div>
                    <div class="p-section fw-semibold text-uppercase small text-secondary mb-3">Today's Ward Activity</div>
                    <div class="p-stat">
                        <span><i class="bi bi-hospital me-1"></i> Awaiting</span>
                        <span class="badge-stat bg-warning-subtle">@ViewBag.AwaitingAdmissionCount</span>
                    </div>
                </div>
                <a class="btn-logout" asp-controller="Home" asp-action="Index">
                    <i class="bi bi-box-arrow-right"></i> Log Out
                </a>
            </div>
        </div>
    </main>

    <!-- Scripts -->
    <script src="https://cdnjs.cloudflare.com/ajax/libs/bootstrap/5.3.0/js/bootstrap.bundle.min.js"></script>
    <script>
        // Mobile sidebar toggle
        document.getElementById('sidebarToggleMobile').addEventListener('click', function() {
            document.getElementById('appSidebar').classList.toggle('mobile-open');
            document.getElementById('sidebarOverlay').classList.toggle('active');
        });

        document.getElementById('sidebarOverlay').addEventListener('click', function() {
            document.getElementById('appSidebar').classList.remove('mobile-open');
            document.getElementById('sidebarOverlay').classList.remove('active');
        });

        // Close sidebar when a nav link is clicked (mobile)
        document.querySelectorAll('.app-sidebar .nav-link').forEach(link => {
            link.addEventListener('click', function() {
                if (window.innerWidth <= 768) {
                    document.getElementById('appSidebar').classList.remove('mobile-open');
                    document.getElementById('sidebarOverlay').classList.remove('active');
                }
            });
        });

        // Set active nav link based on current page
        document.addEventListener('DOMContentLoaded', function() {
            const currentPath = window.location.pathname.toLowerCase();
            document.querySelectorAll('.app-sidebar .nav-link').forEach(link => {
                link.classList.remove('active');
                const href = link.getAttribute('href')?.toLowerCase() || '';
                if (currentPath.includes(href.split('/').pop()) && href !== '#') {
                    link.classList.add('active');
                }
                // Special case for main page
                if (currentPath === '/' || currentPath.endsWith('/mainpage')) {
                    document.querySelector('.app-sidebar .nav-link[href*="MainPage"]')?.classList.add('active');
                }
            });
        });
    </script>
    @RenderSection("Scripts", required: false)
</body>
</html>