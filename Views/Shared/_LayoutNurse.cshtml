@using Microsoft.AspNetCore.Http
@{
    var userName = Context.Session.GetString("UserName");
    var userSurname = Context.Session.GetString("UserSurname");
    var userEmail = Context.Session.GetString("UserEmail");
}
<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Apollo+</title>
    <link href="https://cdnjs.cloudflare.com/ajax/libs/bootstrap/5.3.0/css/bootstrap.min.css" rel="stylesheet">
    <link href="~/css/site2.css" rel="stylesheet">
    <style>
        .custom-card {
            display: flex;
            flex-direction: column;
            align-items: center;
            justify-content: center;
            text-align: center;
            padding: 20px;
            box-shadow: 0 4px 8px rgba(0, 0, 0, 0.1);
            border-radius: 8px;
            margin-top: 15px; /* Reduced margin-top to move the card higher */
        }

            .custom-card img {
                width: 100px;
                height: 100px;
            }

        .card-body {
            display: flex;
            flex-direction: column;
            align-items: center;
        }

        .card-text {
            margin: 5px 0;
        }

        .btn-primary {
            margin-top: 0px;
        }

        .sideBar {
            margin-top: -1rem;
        }
    </style>
</head>

<body>
    <nav class="navbar navbar-dark bg-dark fixed-top">
        <div class="container-fluid d-flex align-items-center">
            <!-- Toggle button and welcome text aligned -->
            <div class="d-flex align-items-center me-3">
                <button class="navbar-toggler me-2" type="button" data-bs-toggle="offcanvas"
                        data-bs-target="#offcanvasDarkNavbar" aria-controls="offcanvasDarkNavbar"
                        aria-label="Toggle navigation">
                    <span class="navbar-toggler-icon"></span>
                </button>
                <span class="navbar-text text-white fw-bold">Welcome, Nurse</span>
            </div>

            <!-- Brand aligned to right -->
            <a class="navbar-brand ms-auto" href="#">Apollo+</a>
        </div>
    </nav>

    <div class="offcanvas offcanvas-start text-bg-dark" tabindex="-1" id="offcanvasDarkNavbar" aria-labelledby="offcanvasDarkNavbarLabel">
        <div class="offcanvas-header">
            <h3 class="offcanvas-title" id="offcanvasDarkNavbarLabel">Main Menu</h3>
            <button type="button" class="btn-close btn-close-white" data-bs-dismiss="offcanvas" aria-label="Close"></button>
        </div>
        <div class="offcanvas-body">
            <ul class="navbar-nav justify-content-end flex-grow-1 pe-3">
                <li class="nav-item">             
                    <a class="nav-link active" asp-controller="Nurse" asp-action="MainPage" style="font-size: 1.3rem;"> Home </a>
                    <a class="nav-link active" asp-controller="Nurse" asp-action="ViewSurgeryBooking" style="font-size: 1.3rem;">Surgery Bookings</a>
                    <a class="nav-link active" asp-controller="Nurse" asp-action="AdmittedPatients" style="font-size: 1.3rem;">Admitted Patient List</a>
                    <a class="nav-link active" asp-controller="Nurse" asp-action="DischargeList" style="font-size: 1.3rem;">Discharge Patient</a>
                    <a class="nav-link active" asp-controller="Nurse" asp-action="NurseReport" style="font-size: 1.3rem;">Report</a>
                    <a class="nav-link active" asp-controller="Nurse" asp-action="InfoNurse" style="font-size: 1.3rem;">Hospital Information</a>
               
                </li>
            </ul>
        </div>
    </div>

    <div class="container-fluid">
        <main role="main">
            <div class="row">
                <!-- Main content -->
                <div class="col-md-9">
                    @RenderBody()
                </div>

                <!-- Sidebar -->
                <div id="sideBar" class="d-flex justify-content-end align-self-start"
                     style="width:270px; min-width:270px; max-width:270px; flex-shrink:0;margin-top:30px;">

                    <div class="card shadow-sm text-center"
                         style="width:260px; border-radius:15px; overflow:hidden; height:auto;">

                        <!-- User Header -->
                        <div style="background: linear-gradient(135deg, #4e73df, #1cc88a); color:white; padding:20px;">
                            <img src="~/css/user.png" class="rounded-circle mb-2"
                                 style="width:80px; height:80px; border:3px solid white;">
                            <h5 class="mb-0">@ViewBag.UserName @ViewBag.UserSurname</h5>
                            <small>@ViewBag.UserEmail</small>
                        </div>

                        <div class="card-body">
                            <!-- Nurse Admission Stats -->

                            <h6 class="text-uppercase text-muted mb-3">Patient Admissions</h6>

                            <div class="d-flex flex-column align-items-center mb-2">
                                <div><i class="bi bi-person-plus"></i> Patients Admitted</div>
                            </div>

                            <div class="d-flex flex-column align-items-center mb-2">
                                <div><i class="bi bi-clipboard-check"></i>  Patients Discharged</div>
                            </div>

                            <hr>

                            <h6 class="text-uppercase text-muted mb-2">Today's Ward Activity</h6>

                            <div class="d-flex flex-column align-items-center mb-2">
                                <div><i class="bi bi-hospital"></i> Patients Awaiting Admission</div>
                            </div>

                            <a class="btn btn-outline-danger w-100"
                               asp-controller="Home"
                               asp-action="Index">Log Out</a>
                        </div>
                    </div>
                </div>



                <!-- Include Bootstrap Icons CDN in <head> if not already -->
                <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.1/font/bootstrap-icons.css">
            </div>
        </main>
    </div>

    <!-- Scripts -->
    <script src="https://cdnjs.cloudflare.com/ajax/libs/bootstrap/5.3.0/js/bootstrap.bundle.min.js"></script>
    @RenderSection("Scripts", required: false)
</body>
</html>