@using Microsoft.AspNetCore.Http
@{
    var userName = Context.Session.GetString("UserName");
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Apollo+</title>
    <link href="https://cdnjs.cloudflare.com/ajax/libs/bootstrap/5.3.0/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.1/font/bootstrap-icons.css">
    <link href="~/css/site2.css" rel="stylesheet">
    <style>
        body {
            background: #f4f6fb;
        }

        .app-navbar {
            background: #0f172a;
            height: 56px;
            display: flex;
            align-items: center;
            padding: 0 24px;
            justify-content: space-between;
            position: fixed;
            top: 0;
            left: 0;
            right: 0;
            z-index: 200;
        }

            .app-navbar .brand {
                color: #7c3aed;
                font-size: 20px;
                font-weight: 600;
                text-decoration: none;
            }

            .app-navbar .welcome {
                color: #94a3b8;
                font-size: 13px;
            }

        .app-sidebar {
            width: 220px;
            background: #0f172a;
            position: fixed;
            top: 56px;
            bottom: 0;
            left: 0;
            padding: 20px 0;
            z-index: 100;
            overflow-y: auto;
        }

            .app-sidebar .nav-section-label {
                padding: 0 16px;
                font-size: 10px;
                font-weight: 500;
                color: #475569;
                letter-spacing: 1px;
                text-transform: uppercase;
                margin-bottom: 6px;
                display: block;
            }

            .app-sidebar .nav-link {
                display: flex;
                align-items: center;
                gap: 10px;
                padding: 9px 16px;
                color: #94a3b8;
                font-size: 13px;
                border-left: 2px solid transparent;
                transition: all 0.15s;
            }

                .app-sidebar .nav-link:hover {
                    color: #e2e8f0;
                    background: rgba(255,255,255,0.05);
                }

                .app-sidebar .nav-link.active {
                    color: #a78bfa;
                    border-left-color: #7c3aed;
                    background: rgba(124,58,237,0.1);
                }

            .app-sidebar .nav-divider {
                height: 0.5px;
                background: #1e293b;
                margin: 12px 16px;
            }

        .app-main {
            margin-left: 220px;
            margin-top: 56px;
            padding: 28px 24px;
            min-height: calc(100vh - 56px);
        }

        .profile-sidebar-card {
            background: white;
            border-radius: 14px;
            border: 0.5px solid #e2e8f0;
            overflow: hidden;
            width: 200px;
            flex-shrink: 0;
        }

            .profile-sidebar-card .p-header {
                background: linear-gradient(135deg, #7c3aed, #06b6d4);
                padding: 18px 16px;
                text-align: center;
            }

            .profile-sidebar-card .p-avatar {
                width: 52px;
                height: 52px;
                border-radius: 50%;
                background: rgba(255,255,255,0.25);
                display: flex;
                align-items: center;
                justify-content: center;
                font-size: 16px;
                font-weight: 600;
                color: white;
                margin: 0 auto 8px;
                border: 2px solid rgba(255,255,255,0.4);
            }

            .profile-sidebar-card .p-name {
                color: white;
                font-size: 13px;
                font-weight: 600;
            }

            .profile-sidebar-card .p-email {
                color: rgba(255,255,255,0.7);
                font-size: 11px;
                margin-top: 2px;
            }

            .profile-sidebar-card .p-body {
                padding: 14px 16px;
            }

            .profile-sidebar-card .p-section {
                font-size: 10px;
                font-weight: 500;
                color: #64748b;
                text-transform: uppercase;
                letter-spacing: 0.8px;
                margin-bottom: 8px;
            }

        .p-stat {
            display: flex;
            justify-content: space-between;
            align-items: center;
            margin-bottom: 7px;
            font-size: 12px;
            color: #475569;
        }

        .p-divider {
            height: 0.5px;
            background: #f1f5f9;
            margin: 10px 0;
        }

        .btn-logout {
            display: block;
            margin: 0 16px 14px;
            padding: 7px;
            text-align: center;
            border: 0.5px solid #fca5a5;
            color: #dc2626;
            border-radius: 8px;
            font-size: 12px;
            background: none;
            text-decoration: none;
        }

            .btn-logout:hover {
                background: #fee2e2;
                color: #dc2626;
            }
    </style>
</head>
<body>

    <nav class="app-navbar">
        <div class="d-flex align-items-center gap-3">
            <span class="welcome">Welcome, <strong style="color:#e2e8f0;">Dr. @ViewBag.UserName @ViewBag.UserSurname</strong></span>
        </div>
        <a class="brand" href="#">Apollo+</a>
    </nav>

    <aside class="app-sidebar">
        <span class="nav-section-label">Navigation</span>
        <a class="nav-link" asp-controller="Home" asp-action="SurgeonHome"><i class="bi bi-house-door"></i> Home</a>
        <a class="nav-link" asp-controller="Home" asp-action="PatientList"><i class="bi bi-people"></i> Patients</a>
        <a class="nav-link" asp-controller="Home" asp-action="ListSurgery"><i class="bi bi-scissors"></i> Surgery</a>
        <a class="nav-link" asp-controller="Home" asp-action="patientAddmision"><i class="bi bi-hospital"></i> Admissions</a>
        <a class="nav-link" asp-controller="Home" asp-action="PrescriptionList"><i class="bi bi-capsule"></i> Prescriptions</a>
        <div class="nav-divider"></div>
        <a class="nav-link" asp-controller="Home" asp-action="InfoSurgeon"><i class="bi bi-info-circle"></i> Info</a>
        <a class="nav-link" asp-controller="Home" asp-action="Reports"><i class="bi bi-bar-chart"></i> Reports</a>
    </aside>

    <main class="app-main">
        <div class="d-flex gap-4 align-items-start">
            <div style="flex: 1; min-width: 0;">
                @RenderBody()
            </div>
            <div class="profile-sidebar-card">
                <div class="p-header">
                    <div class="p-avatar">@ViewBag.UserName?.Substring(0, 1)@ViewBag.UserSurname?.Substring(0, 1)</div>
                    <div class="p-name">@ViewBag.UserName @ViewBag.UserSurname</div>
                    <div class="p-email">@ViewBag.UserEmail</div>
                </div>
                <div class="p-body">
                    <div class="p-section">Prescriptions</div>
                    <div class="p-stat"><span>Prescribed</span><span class="badge" style="background:#dbeafe;color:#1d4ed8;">@ViewBag.prescribedCount</span></div>
                    <div class="p-stat"><span>Dispensed</span><span class="badge" style="background:#d1fae5;color:#065f46;">@ViewBag.dispensedCount</span></div>
                    <div class="p-stat"><span>Rejected</span><span class="badge" style="background:#fee2e2;color:#991b1b;">@ViewBag.rejectedCount</span></div>
                    <div class="p-divider"></div>
                    <div class="p-section">Today</div>
                    <div class="p-stat"><span>Surgeries</span><span class="badge" style="background:#fef3c7;color:#92400e;">@ViewBag.surgeryCount</span></div>
                </div>
                <a class="btn-logout" asp-controller="Home" asp-action="Index">Log Out</a>
            </div>
        </div>
    </main>

    <script src="https://cdnjs.cloudflare.com/ajax/libs/bootstrap/5.3.0/js/bootstrap.bundle.min.js"></script>
    @RenderSection("Scripts", required: false)
</body>
</html>