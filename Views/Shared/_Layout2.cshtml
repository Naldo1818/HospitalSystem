@using Microsoft.AspNetCore.Http
@{
    var userName = Context.Session.GetString("UserName");
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, user-scalable=yes">
    <title>Apollo+ | Surgeon Hub</title>
    <!-- Bootstrap 5 + Icons + Fonts -->
    <link href="https://cdnjs.cloudflare.com/ajax/libs/bootstrap/5.3.0/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.1/font/bootstrap-icons.css">
    <link href="https://fonts.googleapis.com/css2?family=Inter:opsz,wght@14..32,300;14..32,400;14..32,500;14..32,600;14..32,700&display=swap" rel="stylesheet">
    <link href="~/css/site2.css" rel="stylesheet">
    <style>
        /* ---------- GLOBAL RESET & ENHANCED DASHBOARD ---------- */
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }

        body {
            font-family: 'Inter', system-ui, -apple-system, 'Segoe UI', Roboto, sans-serif;
            background: #f0f4f9;
            overflow-x: hidden;
        }

        /* modern navbar */
        .app-navbar {
            background: #ffffff;
            backdrop-filter: blur(0px);
            box-shadow: 0 4px 20px rgba(0, 0, 0, 0.02), 0 1px 2px rgba(0, 0, 0, 0.03);
            height: 68px;
            display: flex;
            align-items: center;
            padding: 0 32px;
            justify-content: space-between;
            position: fixed;
            top: 0;
            left: 0;
            right: 0;
            z-index: 200;
            border-bottom: 1px solid #e9edf2;
        }

            .app-navbar .brand {
                background: linear-gradient(135deg, #0b2b5c, #1e4a76);
                background-clip: text;
                -webkit-background-clip: text;
                color: transparent;
                font-size: 24px;
                font-weight: 700;
                letter-spacing: -0.3px;
                text-decoration: none;
            }

            .app-navbar .welcome {
                color: #2c3e50;
                font-size: 14px;
                font-weight: 500;
                background: #f1f5f9;
                padding: 6px 14px;
                border-radius: 40px;
            }

        /* sidebar premium */
        .app-sidebar {
            width: 260px;
            background: #ffffff;
            position: fixed;
            top: 68px;
            bottom: 0;
            left: 0;
            padding: 24px 12px;
            z-index: 100;
            overflow-y: auto;
            border-right: 1px solid #eef2f6;
            box-shadow: 2px 0 12px rgba(0, 0, 0, 0.02);
        }

            .app-sidebar .nav-section-label {
                padding: 0 16px;
                font-size: 11px;
                font-weight: 600;
                color: #5b6e8c;
                letter-spacing: 0.5px;
                text-transform: uppercase;
                margin: 16px 0 8px 0;
            }

            .app-sidebar .nav-link {
                display: flex;
                align-items: center;
                gap: 12px;
                padding: 10px 16px;
                color: #334155;
                font-size: 14px;
                font-weight: 500;
                border-radius: 12px;
                margin: 4px 8px;
                transition: all 0.2s ease;
                text-decoration: none;
            }

                .app-sidebar .nav-link i {
                    font-size: 1.2rem;
                    width: 24px;
                    color: #5b6e8c;
                }

                .app-sidebar .nav-link:hover {
                    background: #f1f5fe;
                    color: #1e4a76;
                    transform: translateX(2px);
                }

                .app-sidebar .nav-link.active {
                    background: #eef2ff;
                    color: #2563eb;
                    border-left: 3px solid #2563eb;
                }

            .app-sidebar .nav-divider {
                height: 1px;
                background: #e9edf2;
                margin: 16px 12px;
            }

        /* main area */
        .app-main {
            margin-left: 260px;
            margin-top: 68px;
            padding: 32px 36px;
            min-height: calc(100vh - 68px);
            background: #f8fafc;
        }

        /* Profile card - right sidebar */
        .profile-sidebar-card {
            background: white;
            border-radius: 28px;
            border: 1px solid #eef2f8;
            overflow: hidden;
            width: 260px;
            flex-shrink: 0;
            box-shadow: 0 8px 20px rgba(0, 0, 0, 0.02);
            transition: all 0.2s;
        }

            .profile-sidebar-card .p-header {
                background: linear-gradient(145deg, #1e2a47, #0f2b3d);
                padding: 24px 16px;
                text-align: center;
            }

            .profile-sidebar-card .p-avatar {
                width: 70px;
                height: 70px;
                border-radius: 50%;
                background: rgba(255,255,255,0.2);
                backdrop-filter: blur(4px);
                display: flex;
                align-items: center;
                justify-content: center;
                font-size: 28px;
                font-weight: 600;
                color: white;
                margin: 0 auto 12px;
                border: 2px solid rgba(255,255,240,0.5);
            }

            .profile-sidebar-card .p-name {
                color: white;
                font-size: 16px;
                font-weight: 700;
            }

            .profile-sidebar-card .p-email {
                color: #cbd5e6;
                font-size: 12px;
                margin-top: 6px;
                word-break: break-all;
            }

            .profile-sidebar-card .p-body {
                padding: 20px 18px;
            }

        .p-stat {
            display: flex;
            justify-content: space-between;
            align-items: center;
            margin-bottom: 12px;
            font-size: 13px;
            font-weight: 500;
            color: #1e293b;
        }

            .p-stat .badge-stat {
                background: #f1f5f9;
                padding: 4px 12px;
                border-radius: 40px;
                font-weight: 600;
                font-size: 12px;
            }

        .btn-logout {
            display: block;
            margin: 8px 16px 20px;
            padding: 8px;
            text-align: center;
            border: 1px solid #ffcdd2;
            color: #c62828;
            border-radius: 60px;
            font-size: 13px;
            font-weight: 500;
            background: #fff5f5;
            text-decoration: none;
            transition: all 0.2s;
        }

            .btn-logout:hover {
                background: #ffebee;
                color: #b71c1c;
                border-color: #ef9a9a;
            }

        @@media (max-width: 1024px) {
            .app-main {
                padding: 24px 20px;
            }

            .profile-sidebar-card {
                width: 230px;
            }

            .app-sidebar {
                width: 220px;
            }

            .app-main {
                margin-left: 220px;
            }
        }

        @@media (max-width: 768px) {
            .app-sidebar {
                transform: translateX(-100%);
                transition: transform 0.2s;
                z-index: 300;
            }

            .app-main {
                margin-left: 0;
            }

            .profile-sidebar-card {
                display: none;
            }

            .app-navbar .brand {
                font-size: 20px;
            }
        }
    </style>
</head>
<body>

    <nav class="app-navbar">
        <div class="d-flex align-items-center gap-3">
            <span class="welcome">
                <i class="bi bi-calendar-check"></i> Welcome back,
                <strong style="color:#0f2b3d;">Dr. @ViewBag.UserName @ViewBag.UserSurname</strong>
            </span>
        </div>
        <a class="brand" href="#"><i class="bi bi-heart-pulse-fill" style="color:#2563eb;"></i> Apollo+</a>
    </nav>

    <aside class="app-sidebar">
        <span class="nav-section-label">Main</span>
        <a class="nav-link active" asp-controller="Home" asp-action="SurgeonHome"><i class="bi bi-grid-1x2-fill"></i> Dashboard</a>
        <a class="nav-link" asp-controller="Home" asp-action="PatientList"><i class="bi bi-people-fill"></i> Patients</a>
        <a class="nav-link" asp-controller="Home" asp-action="ListSurgery"><i class="bi bi-scissors"></i> Surgeries</a>
        <a class="nav-link" asp-controller="Home" asp-action="patientAddmision"><i class="bi bi-hospital-fill"></i> Admissions</a>
        <a class="nav-link" asp-controller="Home" asp-action="PrescriptionList"><i class="bi bi-capsule"></i> Prescriptions</a>
        <div class="nav-divider"></div>
        <a class="nav-link" asp-controller="Home" asp-action="InfoSurgeon"><i class="bi bi-info-circle"></i> Info</a>
        <a class="nav-link" asp-controller="Home" asp-action="Reports"><i class="bi bi-bar-chart-steps"></i> Reports</a>
    </aside>

    <main class="app-main">
        <div class="d-flex gap-4 align-items-start flex-wrap">
            <div style="flex: 1; min-width: 0;">
                @RenderBody()
            </div>
            <div class="profile-sidebar-card">
                <div class="p-header">
                    <div class="p-avatar">@ViewBag.UserName?.Substring(0, 1)@ViewBag.UserSurname?.Substring(0, 1)</div>
                    <div class="p-name">@ViewBag.UserName @ViewBag.UserSurname</div>
                    <div class="p-email">@ViewBag.UserEmail</div>
                </div>
                <div class="p-body">
                    <div class="p-section fw-semibold text-uppercase small text-secondary">Prescriptions</div>
                    <div class="p-stat"><span>📋 Prescribed</span><span class="badge-stat">@ViewBag.prescribedCount</span></div>
                    <div class="p-stat"><span>✅ Dispensed</span><span class="badge-stat">@ViewBag.dispensedCount</span></div>
                    <div class="p-stat"><span>❌ Rejected</span><span class="badge-stat">@ViewBag.rejectedCount</span></div>
                    <div class="nav-divider" style="margin: 12px 0;"></div>
                    <div class="p-section fw-semibold text-uppercase small text-secondary">Today</div>
                    <div class="p-stat"><span>🩺 Surgeries</span><span class="badge-stat bg-warning-subtle">@ViewBag.surgeryCount</span></div>
                </div>
                <a class="btn-logout" asp-controller="Home" asp-action="Index"><i class="bi bi-box-arrow-right"></i> Log Out</a>
            </div>
        </div>
    </main>

    <script src="https://cdnjs.cloudflare.com/ajax/libs/bootstrap/5.3.0/js/bootstrap.bundle.min.js"></script>
    @RenderSection("Scripts", required: false)
</body>
</html>